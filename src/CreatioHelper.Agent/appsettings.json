{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Hosting": "Information",
        "Microsoft.AspNetCore.Routing": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "CreatioHelper.Agent.Services.SyncthingAutoStopService": "Information",
        "CreatioHelper.Agent.Services.ServiceStateManager": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/agent-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "InstrumentationKey": "",
    "ConnectionString": "",
    "EnableAdaptiveSampling": true,
    "SamplingPercentage": 100.0
  },
  "Metrics": {
    "Enabled": true,
    "PrometheusEnabled": true,
    "CollectionInterval": "00:00:15",
    "RetentionPeriod": "01:00:00"
  },
  "Performance": {
    "BatchOperations": {
      "MaxConcurrentOperations": 4,
      "TimeoutMinutes": 5,
      "RetryAttempts": 3
    },
    "ConnectionPool": {
      "MaxPoolSize": 10,
      "ConnectionTimeout": "00:01:00"
    }
  },
  "_comment_auth": "SECURITY: Configure credentials via environment variables or user secrets. See appsettings.Development.json for development defaults.",
  "Authentication": {
    "Users": []
  },
  "JwtSettings": {
    "Secret": "",
    "Issuer": "CreatioHelper.Agent",
    "Audience": "CreatioHelper.Client",
    "ExpirationHours": 24
  },
  "SwaggerAuth": {
    "Username": "",
    "Password": "",
    "Enabled": false
  },
  "SyncDatabase": {
    "DatabasePath": "Data/sync.db"
  },
  "Heartbeat": {
    "IntervalMinutes": 15
  },
  "SyncthingAutoStop": {
    "Enabled": false,
    "SyncSource": "BuiltIn",
    "_comment_SyncSource": "Sync event source: 'BuiltIn' for built-in sync engine (direct access), 'External' for external Syncthing (long-polling)",
    "SyncthingApiUrl": "http://127.0.0.1:8384",
    "SyncthingApiKey": "",
    "MonitoredFolders": [],
    "IdleTimeoutSeconds": 30,
    "CompletionCheckIntervalSeconds": 5,
    "RequiredStableChecks": 2,
    "Windows": {
      "AppPoolName": "",
      "SiteName": "",
      "ServiceName": ""
    },
    "Linux": {
      "ServiceName": ""
    },
    "MacOS": {
      "ServiceName": ""
    }
  },
  "Sync": {
    "_comment": "Extended Syncthing-compatible sync settings",
    "FsyncEnabled": true,
    "CopyRangeMethod": "Auto",
    "CaseSensitivity": "Auto",
    "TempFilePrefix": ".syncthing.",
    "TempFileSuffix": ".tmp",
    "MaxConflicts": 10,
    "DebugCategories": ""
  },
  "UsageReporting": {
    "_comment": "Telemetry disabled",
    "Enabled": false,
    "ReportUrl": "",
    "ReportIntervalHours": 24,
    "UniqueId": ""
  },
  "Upgrade": {
    "_comment": "Automatic update settings",
    "AutoCheck": true,
    "AutoDownload": false,
    "AutoUpgrade": false,
    "IncludePrereleases": false,
    "CheckIntervalHours": 12,
    "ReleaseUrl": "https://api.github.com/repos/anthropics/creatio-helper/releases",
    "DownloadDirectory": ""
  },
  "Security": {
    "_comment": "Security and authentication settings",
    "TokenStoragePath": "",
    "ApiTokenEnabled": true,
    "RequireApiToken": false,
    "AllowedScopes": [
      "config:read",
      "config:write",
      "status:read",
      "events:read",
      "system:read",
      "db:read"
    ]
  }
}
