{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "InstrumentationKey": "",
    "ConnectionString": "",
    "EnableAdaptiveSampling": true,
    "SamplingPercentage": 100.0
  },
  "Metrics": {
    "Enabled": true,
    "PrometheusEnabled": true,
    "CollectionInterval": "00:00:15",
    "RetentionPeriod": "01:00:00"
  },
  "Performance": {
    "BatchOperations": {
      "MaxConcurrentOperations": 4,
      "TimeoutMinutes": 5,
      "RetryAttempts": 3
    },
    "ConnectionPool": {
      "MaxPoolSize": 10,
      "ConnectionTimeout": "00:01:00"
    }
  }
}
