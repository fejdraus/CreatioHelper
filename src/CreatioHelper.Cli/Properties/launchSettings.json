{
  "profiles": {
    "Help": {
      "commandName": "Project",
      "commandLineArgs": "--help"
    },
    "Deploy from settings.json": {
      "commandName": "Project",
      "commandLineArgs": "--settings ./settings.json",
      "workingDirectory": "$(MSBuildProjectDirectory)"
    },
    "Compile incremental (--site)": {
      "commandName": "Project",
      "commandLineArgs": "--site \"R:\\Web\\AstanaMotors\" --compile incremental"
    },
    "Compile full (--site)": {
      "commandName": "Project",
      "commandLineArgs": "--site \"R:\\Web\\AstanaMotors\" --compile full"
    },
    "Install packages": {
      "commandName": "Project",
      "commandLineArgs": "--site \"R:\\Web\\AstanaMotors\" --packages-path \"C:\\Pkgs\""
    },
    "Delete packages before": {
      "commandName": "Project",
      "commandLineArgs": "--site \"R:\\Web\\AstanaMotors\" --delete-before \"OldPkg1,OldPkg2\""
    },
    "Redis clear": {
      "commandName": "Project",
      "commandLineArgs": "redis-clear --site \"R:\\Web\\AstanaMotors\""
    },
    "IIS restart (from settings)": {
      "commandName": "Project",
      "commandLineArgs": "iis restart --settings ./settings.json"
    },
