<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CreatioHelper.ViewModels"
        x:Class="CreatioHelper.AddServerWindow"
        x:DataType="vm:AddServerViewModel"
        Width="800"
        MinWidth="800"
        MaxWidth="800"
        Height="700"
        Title="Add or Edit Server"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="*,Auto">

    <ScrollViewer Grid.Row="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="15" Spacing="10">

        <TextBlock Text="Server name:" />
        <TextBox Text="{Binding ServerName, Mode=TwoWay}"
                 MaxWidth="770"
                 Watermark="Enter server name (e.g., PROD-SERVER-01)" />

        <TextBlock Text="Site name:" />
        <TextBox Text="{Binding SiteName, Mode=TwoWay}"
                 MaxWidth="770"
                 Watermark="Enter IIS site name (e.g., Default Web Site)" />

        <TextBlock Text="Pool name:" />
        <TextBox Text="{Binding PoolName, Mode=TwoWay}"
                 MaxWidth="770"
                 Watermark="Enter IIS application pool name (e.g., DefaultAppPool)" />

        <!-- File Copy Sync Fields -->
        <Border IsVisible="{Binding IsFileCopyFieldsVisible}"
                BorderBrush="#4CAF50"
                BorderThickness="2"
                CornerRadius="5"
                Padding="10"
                Margin="0,8,0,0"
                MaxWidth="770">
            <StackPanel Spacing="8" MaxWidth="750">
                <TextBlock Text="📁 File Copy Synchronization"
                           FontWeight="Bold"
                           Foreground="#4CAF50"/>

                <TextBlock>
                    <Run Text="Remote site path " /><Run Text="*" Foreground="Red" FontWeight="Bold" />
                </TextBlock>
                <TextBox Text="{Binding NetworkPath, Mode=TwoWay}"
                         Watermark="Windows: \\server\share\site   Linux: /var/www/creatio" />

                <TextBlock Text="Service name (stop/start during sync):" Margin="0,6,0,0" />
                <TextBox Text="{Binding ServiceName, Mode=TwoWay}"
                         Watermark="e.g., creatio  (leave empty to skip)" />

                <TextBlock FontWeight="SemiBold" Margin="0,10,0,2">
                    <Run Text="SSH / SFTP" />
                </TextBlock>

                <Grid ColumnDefinitions="*,140" ColumnSpacing="8">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock>
                            <Run Text="SSH host " /><Run Text="*" Foreground="Red" FontWeight="Bold" />
                        </TextBlock>
                        <TextBox Text="{Binding SshHost, Mode=TwoWay}"
                                 Watermark="IP address or hostname" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Port:" />
                        <TextBox Text="{Binding SshPort, Mode=TwoWay}"
                                 Watermark="22" />
                    </StackPanel>
                </Grid>

                <TextBlock>
                    <Run Text="SSH username " /><Run Text="*" Foreground="Red" FontWeight="Bold" />
                </TextBlock>
                <TextBox Text="{Binding SshUser, Mode=TwoWay}"
                         Watermark="e.g., deploy or root" />

                <TextBlock Text="SSH auth — fill in one:" />
                <TextBox Text="{Binding SshPassword, Mode=TwoWay}"
                         PasswordChar="●"
                         Watermark="SSH auth: enter passphrase here" />
                <TextBox Text="{Binding SshKeyPath, Mode=TwoWay}"
                         Watermark="or path to private key: /home/user/.ssh/id_rsa" />

                <TextBlock Text="Folders to sync (relative to site root):" Margin="0,10,0,0" />
                <TextBlock Text="Leave empty for auto-detection (Terrasoft.Configuration / Terrasoft.WebApp/conf)"
                           FontSize="11" Foreground="Gray" />

                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,4">
                    <TextBox Grid.Column="0"
                             Text="{Binding NewFolderPath, Mode=TwoWay}"
                             Watermark="e.g., Terrasoft.Configuration"
                             Margin="0,0,8,0"/>
                    <Button Grid.Column="1"
                            Content="Add"
                            Click="AddFileCopyFolderButton_Click"
                            IsEnabled="{Binding CanAddFolderPath}"
                            Width="60"/>
                </Grid>

                <Border BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="3"
                        MaxHeight="120"
                        IsVisible="{Binding HasFolderPaths}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FileCopyFolderPaths}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E0E0E0"
                                            BorderThickness="0,0,0,1"
                                            Padding="8,4">
                                        <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1"
                                                    Content="Remove"
                                                    Padding="6,2"
                                                    Width="70"
                                                    Click="RemoveFileCopyFolderButton_Click"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <TextBlock Text="Exclude patterns:" Margin="0,10,0,0" />
                <TextBlock Text="Name-only (e.g. logs, *.log) match at any depth. Path with / (e.g. Terrasoft.WebApp/Web.config) matches from site root."
                           FontSize="11" Foreground="Gray" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,4">
                    <TextBox Grid.Column="0"
                             Text="{Binding NewExcludePattern, Mode=TwoWay}"
                             Watermark="e.g., logs  or  *.log  or  Terrasoft.WebApp/Web.config"
                             Margin="0,0,8,0"/>
                    <Button Grid.Column="1"
                            Content="Add"
                            Click="AddExcludePatternButton_Click"
                            IsEnabled="{Binding CanAddExcludePattern}"
                            Width="60"/>
                </Grid>

                <Border BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="3"
                        MaxHeight="120"
                        IsVisible="{Binding HasExcludePatterns}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FileCopyExcludePatterns}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E0E0E0"
                                            BorderThickness="0,0,0,1"
                                            Padding="8,4">
                                        <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1"
                                                    Content="Remove"
                                                    Padding="6,2"
                                                    Width="70"
                                                    Click="RemoveExcludePatternButton_Click"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Border>

        <!-- Syncthing Configuration Section -->
        <Border IsVisible="{Binding IsSyncthingFieldsVisible}"
                BorderBrush="#4A90E2"
                BorderThickness="2"
                CornerRadius="5"
                Padding="10"
                Margin="0,8,0,0"
                MaxWidth="770">
            <StackPanel Spacing="8" MaxWidth="750">
                <TextBlock Text="📡 Syncthing Synchronization"
                           FontWeight="Bold"
                           Foreground="#4A90E2"/>

                <TextBlock Text="Syncthing Device ID:" />
                <TextBox Text="{Binding SyncthingDeviceId, Mode=TwoWay}"
                         Watermark="Device ID (63 characters, 7 groups separated by hyphens)"/>

                <TextBlock Text="Syncthing Folder IDs:" Margin="0,8,0,0"/>

                <!-- Add new folder section -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,4">
                    <TextBox Grid.Column="0"
                             Text="{Binding NewFolderId, Mode=TwoWay}"
                             Watermark="Enter folder ID (e.g., default, bin-folder)"
                             Margin="0,0,8,0"/>
                    <Button Grid.Column="1"
                            Content="Add"
                            Click="AddFolderButton_Click"
                            IsEnabled="{Binding CanAddFolder}"
                            Width="60"/>
                </Grid>

                <!-- Scrollable folder list -->
                <Border BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="3"
                        MaxHeight="150"
                        IsVisible="{Binding HasFolders}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Name="FolderListScrollViewer">
                        <ItemsControl ItemsSource="{Binding SyncthingFolderIds}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E0E0E0"
                                            BorderThickness="0,0,0,1"
                                            Padding="8,4">
                                        <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1"
                                                    Content="Remove"
                                                    Padding="6,2"
                                                    Width="70"
                                                    Click="RemoveFolderButton_Click"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Border>


    </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10"
                Margin="15,8,15,12">
        <Button Width="80" Content="OK" IsDefault="True" Click="OkButton_Click" />
        <Button Width="80" Content="Cancel" IsCancel="True" Click="CancelButton_Click" />
    </StackPanel>

    </Grid>
</Window>