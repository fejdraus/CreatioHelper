<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CreatioHelper.ViewModels"
        x:Class="CreatioHelper.AddServerWindow"
        x:DataType="vm:AddServerViewModel"
        Width="800"
        MinWidth="800"
        MaxWidth="800"
        MinHeight="400"
        MaxHeight="700"
        SizeToContent="Height"
        Title="Add or Edit Server"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="15" Spacing="10">

        <TextBlock Text="Server name:" />
        <TextBox Text="{Binding ServerName, Mode=TwoWay}"
                 MaxWidth="770"
                 Watermark="Enter server name (e.g., PROD-SERVER-01)" />

        <TextBlock Text="Site name:" />
        <TextBox Text="{Binding SiteName, Mode=TwoWay}"
                 MaxWidth="770"
                 Watermark="Enter IIS site name (e.g., Default Web Site)" />

        <TextBlock Text="Pool name:" />
        <TextBox Text="{Binding PoolName, Mode=TwoWay}"
                 MaxWidth="770"
                 Watermark="Enter IIS application pool name (e.g., DefaultAppPool)" />

        <!-- File Copy Sync Fields -->
        <Border IsVisible="{Binding IsFileCopyFieldsVisible}"
                BorderBrush="#4CAF50"
                BorderThickness="2"
                CornerRadius="5"
                Padding="10"
                Margin="0,8,0,0"
                MaxWidth="770">
            <StackPanel Spacing="8" MaxWidth="750">
                <TextBlock Text="📁 File Copy Synchronization"
                           FontWeight="Bold"
                           Foreground="#4CAF50"/>

                <TextBlock Text="Network path to site:" />
                <TextBox Text="{Binding NetworkPath, Mode=TwoWay}"
                         Watermark="Enter UNC path to site folder (e.g., \\server\share\site)" />
            </StackPanel>
        </Border>

        <!-- Syncthing Configuration Section -->
        <Border IsVisible="{Binding IsSyncthingFieldsVisible}"
                BorderBrush="#4A90E2"
                BorderThickness="2"
                CornerRadius="5"
                Padding="10"
                Margin="0,8,0,0"
                MaxWidth="770">
            <StackPanel Spacing="8" MaxWidth="750">
                <TextBlock Text="📡 Syncthing Synchronization"
                           FontWeight="Bold"
                           Foreground="#4A90E2"/>

                <TextBlock Text="Syncthing Device ID:" />
                <TextBox Text="{Binding SyncthingDeviceId, Mode=TwoWay}"
                         Watermark="Device ID (63 characters, 7 groups separated by hyphens)"/>

                <TextBlock Text="Syncthing Folder IDs:" Margin="0,8,0,0"/>

                <!-- Add new folder section -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,4">
                    <TextBox Grid.Column="0"
                             Text="{Binding NewFolderId, Mode=TwoWay}"
                             Watermark="Enter folder ID (e.g., default, bin-folder)"
                             Margin="0,0,8,0"/>
                    <Button Grid.Column="1"
                            Content="Add"
                            Click="AddFolderButton_Click"
                            IsEnabled="{Binding CanAddFolder}"
                            Width="60"/>
                </Grid>

                <!-- Scrollable folder list -->
                <Border BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="3"
                        MaxHeight="150"
                        IsVisible="{Binding HasFolders}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Name="FolderListScrollViewer">
                        <ItemsControl ItemsSource="{Binding SyncthingFolderIds}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E0E0E0"
                                            BorderThickness="0,0,0,1"
                                            Padding="8,4">
                                        <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1"
                                                    Content="Remove"
                                                    Padding="6,2"
                                                    Width="70"
                                                    Click="RemoveFolderButton_Click"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
            <Button Width="80" Content="OK" IsDefault="True" Click="OkButton_Click" />
            <Button Width="80" Content="Cancel" IsCancel="True" Click="CancelButton_Click" />
        </StackPanel>

    </StackPanel>
</Window>