<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CreatioHelper.SaveLicenseRequestWindow"
        Width="450"
        MinWidth="450"
        MaxWidth="450"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Title="Save License Request" CanResize="False">
    <StackPanel Margin="15" Spacing="10">
        <TextBlock Text="Customer ID:" />
        <TextBox x:Name="CustomerIdTextBox"
                 Watermark="Enter customer ID"
                 MaxWidth="420" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
            <Button Width="80" Content="Save" IsDefault="True" Click="Save_Click" />
            <Button Width="80" Content="Cancel" IsCancel="True" Click="Cancel_Click" />
        </StackPanel>
    </StackPanel>
</Window>
