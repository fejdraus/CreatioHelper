<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CreatioHelper.CloseWarningWindow"
        Width="300" Height="130"
        WindowStartupLocation="CenterOwner"
        Title="Attention" CanResize="False">
    <StackPanel Margin="10" Spacing="10">
        <TextBlock TextWrapping="Wrap" Text="The process is being performed now. Please wait for the completion before closing."/>
        <Button HorizontalAlignment="Right" Width="80" Content="OK" Click="Ok_Click"/>
    </StackPanel>
</Window>