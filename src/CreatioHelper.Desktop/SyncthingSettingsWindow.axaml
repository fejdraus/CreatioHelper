<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CreatioHelper.ViewModels"
        x:Class="CreatioHelper.SyncthingSettingsWindow"
        x:DataType="vm:SyncthingSettingsViewModel"
        Width="550"
        MinWidth="550"
        MaxWidth="550"
        MaxHeight="600"
        SizeToContent="Height"
        Title="Synchronization Settings"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="5" >

        <!-- Title -->
        <TextBlock Text="⚙️ Synchronization Settings"
                   FontWeight="Bold"
                   FontSize="16"
                   Foreground="#4A90E2"
                   Margin="10,0,10,0"/>

        <!-- Synchronization Mode Selection -->
        <Border BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="1"
                CornerRadius="5"
                Padding="10,10, 10, 5"
                Margin="0,0,0,5"
                MaxWidth="540">
            <StackPanel Spacing="5" MaxWidth="520">
                <RadioButton Content="None (Disable Synchronization)"
                             GroupName="SyncMode"
                             IsChecked="{Binding NoSynchronization, Mode=TwoWay}"/>

                <RadioButton Content="File Copy Sync"
                             GroupName="SyncMode"
                             IsChecked="{Binding EnableFileCopySynchronization, Mode=TwoWay}"/>

                <RadioButton Content="Syncthing"
                             GroupName="SyncMode"
                             IsChecked="{Binding UseSyncthingForSync, Mode=TwoWay}"/>

                <RadioButton Content="Built-in Sync (Coming Soon)"
                             GroupName="SyncMode"
                             IsEnabled="False"/>
            </StackPanel>
        </Border>

        <!-- Syncthing Configuration -->
        <Border BorderBrush="#4A90E2"
                BorderThickness="2"
                CornerRadius="5"
                Padding="12"
                Margin="10,0,10,0"
                MaxWidth="520"
                IsVisible="{Binding UseSyncthingForSync}">
            <StackPanel Spacing="10" MaxWidth="496">
                <TextBlock Text="📡 Syncthing Configuration"
                           FontWeight="Bold"
                           FontSize="13"
                           Foreground="#4A90E2"/>

                <TextBlock Text="API URL:"
                           FontSize="12"
                           Margin="0,5,0,0"/>
                <TextBox Text="{Binding SyncthingApiUrl, Mode=TwoWay}"
                         PlaceholderText="http://localhost:8384"
                         FontSize="12"/>

                <TextBlock Text="API Key:"
                           FontSize="12"
                           Margin="0,5,0,0"/>
                <TextBox Text="{Binding SyncthingApiKey, Mode=TwoWay}"
                         PlaceholderText="API Key from Syncthing Settings"
                         FontSize="12"
                         PasswordChar="*"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="10, 10 ,10, 10">
            <Button Width="100"
                    Content="OK"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button Width="100"
                    Content="Cancel"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
