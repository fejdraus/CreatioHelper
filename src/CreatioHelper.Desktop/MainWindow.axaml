<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CreatioHelper.ViewModels"
        xmlns:domain="clr-namespace:CreatioHelper.Domain.Entities;assembly=CreatioHelper.Domain"
        xmlns:converters="clr-namespace:CreatioHelper.Converters"
        xmlns:avalonEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
        xmlns:local="clr-namespace:CreatioHelper"

        x:Class="CreatioHelper.MainWindow"
        x:Name="MainRoot"
        x:DataType="vm:MainWindowViewModel"
        Width="1145" Height="670"
        MinWidth="1145" MinHeight="630"
        Title="Creatio Helper"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <converters:BoolToScrollBarVisibilityConverter x:Key="BoolToScrollBarVisibilityConverter"/>
            <converters:DeleteAppVersionToVisibilityConverter x:Key="DeleteAppVersionToVisibilityConverter"/>
            <converters:NotConverter x:Key="NotConverter"/>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="UpdateBadgeBackground" Color="#C8E6C9"/>
                    <SolidColorBrush x:Key="UpdateBadgeForeground" Color="#1B5E20"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="UpdateBadgeBackground" Color="#2E7D32"/>
                    <SolidColorBrush x:Key="UpdateBadgeForeground" Color="#E8F5E9"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid ColumnDefinitions="*,Auto">
        <TabControl x:Name="MainTabControl" Grid.Column="0">
            <TabItem Header="Deployment">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto" Margin="5">
                    <Grid Grid.Row="0" Margin="0,0,0,5" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" IsVisible="{Binding IsWindows}" IsEnabled="{Binding AreControlsEnabled}">
                    <TextBlock Text="Site path source:" />
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0" VerticalAlignment="Center">
                        <RadioButton Content="IIS" IsChecked="{Binding IsIisMode}" GroupName="SiteSource" VerticalAlignment="Center"/>
                        <RadioButton Content="Folder" IsChecked="{Binding IsFolderMode}" GroupName="SiteSource" Margin="15,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding IsFileDesignModeEnabled}"
                            IsEnabled="{Binding AreControlsEnabled}">
                    <TextBlock Text="Packages:" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="Creatio → FS"
                                Command="{Binding DownloadPackagesOpCommand}"
                                Width="110" Height="32" Margin="0,0,10,0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                ToolTip.Tip="Download packages from database to file system"/>
                        <Button Content="Clean &amp; Validate"
                                Command="{Binding ValidatePackagesOpCommand}"
                                Width="130" Height="32" Margin="0,0,10,0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                ToolTip.Tip="Validate JSON files, dependencies and package structure"/>
                        <Button Content="FS → Creatio"
                                Command="{Binding LoadPackagesToDBOpCommand}"
                                Width="110" Height="32"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                ToolTip.Tip="Load packages from file system to database"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="Redis:" HorizontalAlignment="Right"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Status" Command="{Binding CheckRedisStatusCommand}" Width="80" Height="32" Margin="10,0" ToolTip.Tip="Check Redis status"/>
                        <Button Content="Clear" Command="{Binding ClearRedisCommand}" Width="80" Height="32" ToolTip.Tip="Clear Redis cache"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" IsVisible="{Binding IsFolderMode}" Margin="0,0,0,5" IsEnabled="{Binding AreControlsEnabled}">
                <TextBlock Text="Site Path:" />
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <TextBox x:Name="SitePathTextBox" Text="{Binding SitePath, Mode=TwoWay}"
                             Watermark="Enter path to Creatio application folder"
                             Margin="0,0,5,0"/>
                    <Button x:Name="BrowseSiteButton" Grid.Column="1" Content="Browse" Command="{Binding BrowseSitePathCommand}" Margin="5,0,0,0" Height="32"/>
                </Grid>
                <TextBlock Text="Service Name (for service management):" Margin="0,5,0,0" />
                <TextBox x:Name="ServiceNameTextBox" Text="{Binding ServiceName, Mode=TwoWay}"
                         Watermark="Enter service name for Linux/Windows service management" />
            </StackPanel>

            <StackPanel Grid.Row="2" IsVisible="{Binding IsIisMode}" Margin="0,0,0,5" IsEnabled="{Binding AreControlsEnabled}">
                <TextBlock Text="Site IIS:" />
                <ComboBox x:Name="IisSitesComboBox"
                          HorizontalAlignment="Stretch"
                          IsEnabled="{Binding HasIisSites}"
                          ItemsSource="{Binding IisSites}"
                          SelectedItem="{Binding SelectedIisSite}"
                          PlaceholderText="Select IIS site from the list"
                          IsVisible="{Binding IsWindows}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ShortName}" />
                                <TextBlock Text="{Binding PathSuffix}" Foreground="#888888" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,5" IsEnabled="{Binding AreControlsEnabled}">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Packages Path:" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                        <CheckBox Content="Prevalidate package installation"
                                  IsChecked="{Binding PrevalidateBeforeInstall}"
                                  IsEnabled="{Binding PackagesPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                  VerticalAlignment="Center"
                                  ToolTip.Tip="Run pre-validation before installing packages"/>
                        <CheckBox Content="Reset IsLocked/IsChanged on unlocked packages"
                                  IsChecked="{Binding ResetUnlockedPackageFlags}"
                                  IsEnabled="{Binding PackagesPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                  VerticalAlignment="Center"
                                  ToolTip.Tip="Locked packages (SysPackage.InstallType = 1) are always reset before install. Enable to also reset IsLocked/IsChanged on unlocked (developer) packages."/>
                    </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <TextBox x:Name="PackagesPathTextBox" Text="{Binding PackagesPath, Mode=TwoWay}"
                             Watermark="Enter path to packages folder for installation"
                             Margin="0,0,5,0" />
                    <Button x:Name="BrowsePackagesButton" Grid.Column="1" Content="Browse"
                            Command="{Binding BrowsePackagesPathCommand}" Margin="5,0,0,0" Height="32"/>
                </Grid>
            </StackPanel>

            <Grid Grid.Row="4" ColumnDefinitions="*,10,*" RowDefinitions="Auto,Auto" Margin="0,0,0,5" IsEnabled="{Binding AreControlsEnabled}">
                <Grid.IsVisible>
                    <MultiBinding Converter="{StaticResource DeleteAppVersionToVisibilityConverter}" TargetNullValue="False">
                        <Binding Path="IsIisMode"/>
                        <Binding Path="IsFolderMode"/>
                        <Binding Path="SelectedIisSiteVersion"/>
                        <Binding Path="SitePathWithVersion"/>
                    </MultiBinding>
                </Grid.IsVisible>
                <TextBlock Grid.Column="0" Text="Delete packages before install:" Margin="0,0,5,2" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Delete packages after install:" Margin="0,0,0,2" />

                <TextBox Grid.Row="1" Grid.Column="0"
                         x:Name="PackagesToDeleteBeforeTextBox"
                         Text="{Binding PackagesToDeleteBefore, Mode=TwoWay}"
                         Watermark="Package names to delete before installation (comma-separated or one per line)"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="65" />

                <TextBox Grid.Row="1" Grid.Column="2"
                         x:Name="PackagesToDeleteAfterTextBox"
                         Text="{Binding PackagesToDeleteAfter, Mode=TwoWay}"
                         Watermark="Package names to delete after installation (comma-separated or one per line)"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="65" />
            </Grid>

            <Grid Grid.Row="5" ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" Margin="0,5,0,5">
                <SplitButton x:Name="StartButton"
                             Grid.Column="0"
                             Content="{Binding StartButtonText}"
                             Command="{Binding StartCommand}"
                             IsEnabled="{Binding AreControlsEnabled}"
                             Width="140"
                             Height="32"
                             ToolTip.Tip="Click: incremental install. Dropdown: full rebuild (Compile All).">
                    <SplitButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuItem Header="Start (Compile All)"
                                      Command="{Binding StartFullCommand}"
                                      ToolTip.Tip="Full rebuild: RegenerateSchemaSources + Rebuild + BuildConfiguration -force=True"/>
                        </MenuFlyout>
                    </SplitButton.Flyout>
                </SplitButton>

                <Button x:Name="StopButtonAndKillWorkspaceConsole"
                        Grid.Column="1"
                        Content="Stop and kill WSC"
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsStopButtonEnabled}"
                        IsVisible="{Binding !CanRestartLocalIis}"
                        Width="140"
                        Height="32"
                        Margin="10,0,0,0" />

                <Button x:Name="RestartLocalIisButton"
                        Grid.Column="1"
                        Content="Restart IIS"
                        Command="{Binding RestartLocalIisCommand}"
                        IsVisible="{Binding CanRestartLocalIis}"
                        Width="140"
                        Height="32"
                        Margin="10,0,0,0"
                        ToolTip.Tip="Restart local IIS application pool and website for the selected site."/>

                <Button x:Name="RestoreConfigurationButton"
                        Grid.Column="2"
                        Content="Restore"
                        Command="{Binding RestoreConfigurationCommand}"
                        IsEnabled="{Binding AreControlsEnabled}"
                        HorizontalAlignment="Left"
                        Width="140"
                        Height="32"
                        Margin="10,0,0,0"
                        ToolTip.Tip="Roll back to the state before the last package installation, using the backup Creatio writes automatically."/>


                <Button x:Name="SaveLicenseRequestButton"
                        Grid.Column="3"
                        Content="Save Lic Request"
                        Click="SaveLicenseRequest_Click"
                        IsEnabled="{Binding AreControlsEnabled}"
                        Width="135"
                        Height="32"
                        Margin="0,0,10,0"
                        ToolTip.Tip="Generate license request file (.tlr)"/>

                <Button x:Name="LoadLicenseButton"
                        Grid.Column="4"
                        Content="Load License"
                        Command="{Binding LoadLicenseCommand}"
                        IsEnabled="{Binding AreControlsEnabled}"
                        Width="110"
                        Height="32"
                        Margin="0,0,10,0"
                        ToolTip.Tip="Load license response file (.tls)"/>

                <Button x:Name="ServerPanelButton"
                        Grid.Column="5"
                        Content="{Binding ServerPanelButtonText}"
                        Command="{Binding ToggleServerPanelCommand}"
                        IsVisible="{Binding IsWindows}"
                        IsEnabled="{Binding AreControlsEnabled}"
                        Width="130"
                        Height="32"
                        HorizontalAlignment="Right" />
            </Grid>

            <Grid Grid.Row="6" Margin="0,0,0,5" ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Clear"
                            Command="{Binding ClearLogCommand}"
                            Height="32"
                            Padding="12,0"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"/>
                    <CheckBox x:Name="AutoScrollCheckBox"
                              Content="Auto Scroll"
                              IsChecked="{Binding IsAutoScrollEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"/>
                    <CheckBox x:Name="WrapTextCheckBox"
                              Content="Wrap Text"
                              IsChecked="{Binding IsWrapTextEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"/>
                    <CheckBox x:Name="LogToFileCheckBox"
                              Content="Log To File"
                              IsChecked="{Binding IsLogToFileEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"/>
                    <CheckBox x:Name="SkipRedisClearCheckBox"
                              Content="Skip Redis Clear"
                              ToolTip.Tip="Skip Redis cache clear during compilation (useful when attaching IDE to Creatio)"
                              IsChecked="{Binding SkipRedisClear, Mode=TwoWay}"
                              IsEnabled="{Binding AreControlsEnabled}"
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"/>
                    <CheckBox x:Name="SkipServerRestartCheckBox"
                              Content="{Binding SkipServerRestartText}"
                              ToolTip.Tip="Skip stop/start of the site during compile (keeps the process alive so IDE can stay attached)"
                              IsChecked="{Binding SkipServerRestart, Mode=TwoWay}"
                              IsEnabled="{Binding AreControlsEnabled}"
                              IsVisible="{Binding IsSkipServerRestartAvailable}"
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{DynamicResource UpdateBadgeBackground}"
                        CornerRadius="14"
                        Padding="14,4"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="10,0,10,0"
                        IsVisible="{Binding IsUpdateAvailable}"
                        ToolTip.Tip="Open Settings to install the update">
                    <TextBlock Text="Update available"
                               Foreground="{DynamicResource UpdateBadgeForeground}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Border>

                <Button Grid.Column="2"
                        x:Name="SettingsButton"
                        Content="Settings"
                        Click="Settings_Click"
                        Height="32"
                        Padding="12,0"
                        VerticalAlignment="Center"
                        VerticalContentAlignment="Center"
                        HorizontalAlignment="Right"
                        HorizontalContentAlignment="Center"/>
            </Grid>

            <Border Grid.Row="7" BorderBrush="#D4D4D4" BorderThickness="1" CornerRadius="5" Padding="5">
                <avalonEdit:TextEditor
                    x:Name="LogTextEditor"
                    Background="{DynamicResource TextEditorBackgroundBrush}"
                    Foreground="{DynamicResource TextEditorForegroundBrush}"
                    FontFamily="Cascadia Code,Consolas,Monospace"
                    FontSize="12"
                    IsReadOnly="True"
                    WordWrap="{Binding IsWrapTextEnabled}"
                    HorizontalScrollBarVisibility="{Binding IsWrapTextEnabled, Converter={StaticResource BoolToScrollBarVisibilityConverter}}"
                    VerticalScrollBarVisibility="Auto"/>
            </Border>

            <Grid Grid.Row="8" ColumnDefinitions="*,Auto" Margin="0,3,0,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                            IsVisible="{Binding IsLocalStatusVisible}">
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                IsVisible="{Binding LocalVersionText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock FontSize="12" Foreground="Gray" Text="App version:"/>
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding LocalVersionText}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="4"
                                IsVisible="{Binding LocalDbName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock FontSize="12" Foreground="Gray" Text="· DB:"/>
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding LocalDbName}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="4"
                                IsVisible="{Binding LocalRedisDb, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock FontSize="12" Foreground="Gray" Text="· Redis DB:"/>
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding LocalRedisDb}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="4"
                                IsVisible="{Binding LocalPoolStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock FontSize="12" Foreground="Gray" Text="· Pool:"/>
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding LocalPoolStatus}"
                                   Foreground="{Binding LocalPoolStatus, Converter={x:Static converters:StatusToColorConverter.Instance}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="4"
                                IsVisible="{Binding LocalSiteStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock FontSize="12" Foreground="Gray" Text="· Site:"/>
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding LocalSiteStatus}"
                                   Foreground="{Binding LocalSiteStatus, Converter={x:Static converters:StatusToColorConverter.Instance}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="4"
                                IsVisible="{Binding LocalServiceStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock FontSize="12" Foreground="Gray" Text="· Service:"/>
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding LocalServiceStatus}"
                                   Foreground="{Binding LocalServiceStatus, Converter={x:Static converters:StatusToColorConverter.Instance}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="4"
                                IsVisible="{Binding LocalAppHealth, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock FontSize="12" Foreground="Gray" Text="· App:"/>
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding LocalAppHealth}"
                                   Foreground="{Binding LocalAppHealth, Converter={x:Static converters:StatusToColorConverter.Instance}}"/>
                    </StackPanel>
                </StackPanel>

                <HyperlinkButton Grid.Column="1"
                                 Content="Powered by Banza"
                                 NavigateUri="https://banzait.com/"
                                 FontSize="12"
                                 Foreground="Gray"
                                 Opacity="1"
                                 Padding="0"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"/>
            </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Tools">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,12" Spacing="12" DataContext="{Binding ScriptsVm}">
                        <Border IsVisible="{x:Static converters:PlatformInfo.IsWindows}"
                                BorderBrush="{DynamicResource SystemBaseMediumLowColor}" BorderThickness="1" CornerRadius="4" Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Enable Windows features for Creatio (.NET Framework)"/>
                                <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="12"
                                           Text="Enables IIS, WCF, MSMQ, .NET 3.5 and other Windows components required for Creatio on .NET Framework. Requires administrator rights."/>
                                <Button Content="Run" Command="{Binding RunWindowsFeaturesCommand}" HorizontalAlignment="Left" Width="80"/>
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="{DynamicResource SystemBaseMediumLowColor}" BorderThickness="1" CornerRadius="4" Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Remove redundant module records"/>
                                <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="12"
                                           Text="Deletes orphaned records from SysModuleEdit, SysDetail, SysModuleEntity, SysDetailLcz, SysModuleEditLcz where referenced schemas no longer exist. Supports MSSQL, PostgreSQL and Oracle."/>
                                <Button Content="Run" Command="{Binding RunModuleCleanupCommand}" HorizontalAlignment="Left" Width="80"/>
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="{DynamicResource SystemBaseMediumLowColor}" BorderThickness="1" CornerRadius="4" Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="Remove Terrasoft SVN settings"/>
                                <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="12"
                                           Text="Deletes .svn folders inside Crt* packages under the Pkg directory. These SVN settings belong to the Terrasoft vendor and interfere with configuring your own SVN on the Pkg folder."/>
                                <Button Content="Run" Command="{Binding RunSvnCleanupCommand}" HorizontalAlignment="Left" Width="80"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Web.config" IsVisible="{Binding ToolsVm.IsConfigLoaded}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,12" Spacing="0" DataContext="{Binding ToolsVm}">

                        <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Domain server (IP/name):"
                                       VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ServerPath}"
                                     Margin="0,0,0,8" Height="32"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Distinguished Name:"
                                       VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DistinguishedName}"
                                     Margin="0,0,0,8" Height="32"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Auth providers:"
                                       VerticalAlignment="Top" Margin="0,4,12,8"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" Spacing="4">
                                <CheckBox Content="InternalUserPassword" IsChecked="{Binding InternalUserPassword}"/>
                                <CheckBox Content="SSPUserPassword"      IsChecked="{Binding SspUserPassword}"/>
                                <CheckBox Content="Ldap"                 IsChecked="{Binding Ldap}"/>
                                <CheckBox Content="SSPLdapProvider"      IsChecked="{Binding SspLdapProvider}"/>
                                <CheckBox Content="SsoAuthProvider"      IsChecked="{Binding SsoAuthProvider}"/>
                                <CheckBox Content="SSPSsoAuthProvider"   IsChecked="{Binding SspSsoAuthProvider}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="DB schema name:"
                                       VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CurrentSchemaName}"
                                     Margin="0,0,0,8" Height="32"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="LDAP pass-through auth:"
                                       VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <CheckBox Grid.Row="4" Grid.Column="1" IsChecked="{Binding UsePathThroughAuthentication}"
                                      Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="File system dev mode:"
                                       VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding FileDesignMode}"
                                      Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Enable HTTPS:"
                                       IsVisible="{Binding !IsNetCore}"
                                       VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Spacing="10"
                                        IsVisible="{Binding !IsNetCore}"
                                        Margin="0,0,0,8" VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding HttpsEncrypted}"/>
                                <NumericUpDown Value="{Binding PortForClientConnection}"
                                               Minimum="1" Maximum="65535" Increment="1"
                                               Width="120" Height="32"
                                               IsVisible="{Binding HttpsEncrypted}"
                                               ToolTip.Tip="HTTPS port"/>
                            </StackPanel>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Enable proxy:"
                                       VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" Spacing="10"
                                        Margin="0,0,0,8" VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding EnableProxy}"/>
                                <TextBox Text="{Binding ProxyAddress}"
                                         Width="280" Height="32"
                                         Watermark="http://proxy:port"
                                         IsVisible="{Binding EnableProxy}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Quartz schedulers:"
                                       VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <CheckBox Grid.Row="8" Grid.Column="1" IsChecked="{Binding QuartzEnabled}"
                                      Margin="0,0,0,8"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="ConnectionStrings.config" IsVisible="{Binding ConnStrVm.IsConfigLoaded}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,12" Spacing="12" DataContext="{Binding ConnStrVm}">

                        <StackPanel Spacing="12" IsVisible="{Binding HasDb}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Database" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="{Binding DbType}" FontSize="13" Opacity="0.6"
                                       IsVisible="{Binding DbType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="160,*,80,*" RowDefinitions="Auto,Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Server:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DbServer}" Height="32" Margin="0,0,8,8" Watermark="hostname or IP"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Port:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <NumericUpDown Grid.Row="0" Grid.Column="3" Value="{Binding DbPort}" Minimum="0" Maximum="65535" Increment="1" Height="32" Margin="0,0,0,8" FormatString="0"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Database:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding DbCatalog}" Height="32" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="User:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DbUserId}" Height="32" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Pwd:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding DbPassword}" Height="32" PasswordChar="*" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Other parameters:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding DbExtraParams}" Height="32"
                                     Watermark="Pooling=true; Max Pool Size=100; Async=true"
                                     ToolTip.Tip="Driver-specific parameters as key=value pairs separated by ';'. MSSQL: Pooling, Max Pool Size, Async, MultipleActiveResultSets. PostgreSQL: Timeout, CommandTimeout, MaxPoolSize. Oracle: Statement Cache Size."/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.3" Margin="0,4"/>
                        </StackPanel>

                        <StackPanel Spacing="12" IsVisible="{Binding HasRedisEntry}">
                        <TextBlock Text="Redis" FontWeight="SemiBold" FontSize="13"/>
                        <Grid ColumnDefinitions="160,200">
                            <TextBlock Grid.Column="0" Text="Mode:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding RedisModes}" SelectedItem="{Binding SelectedRedisMode}"
                                      Height="32" HorizontalAlignment="Stretch"
                                      ToolTip.Tip="Cluster requires Creatio 7.18.0 or later"/>
                        </Grid>

                        <Grid ColumnDefinitions="160,*,80,*" RowDefinitions="Auto,Auto,Auto,Auto" IsVisible="{Binding HasRedis}">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Host:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding RedisHost}" Height="32" Margin="0,0,8,8" Watermark="hostname or IP"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Port:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <NumericUpDown Grid.Row="0" Grid.Column="3" Value="{Binding RedisPort}" Minimum="0" Maximum="65535" Increment="1" Height="32" Margin="0,0,0,8" FormatString="0"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="DB index:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding RedisDb}" Minimum="0" Maximum="9999" Increment="1" Height="32" Margin="0,0,8,8" FormatString="0"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Pwd:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding RedisPassword}" Height="32" PasswordChar="*" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Other parameters:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding RedisExtraParams}" Height="32"
                                     Watermark="maxReadPoolSize=10; maxWritePoolSize=500"/>

                            <CheckBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,8,0,0"
                                      IsChecked="{Binding UseRetryRedisOperation}"
                                      Content="Retry failed Redis operations (Feature-UseRetryRedisOperation)"
                                      ToolTip.Tip="Writes Feature-UseRetryRedisOperation to Web.config / Terrasoft.WebHost.dll.config. Always enabled in Cluster mode."/>
                        </Grid>

                        <Expander IsVisible="{Binding HasRedisSection}" IsExpanded="False"
                                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                  Margin="0,16,0,0">
                            <Expander.Header>
                                <TextBlock Text="{Binding RedisSectionHeader}" FontWeight="SemiBold"/>
                            </Expander.Header>

                            <StackPanel>
                            <Button Content="Apply cluster defaults" HorizontalAlignment="Right"
                                    IsVisible="{Binding ShowRedisRecommendations}"
                                    Command="{Binding ApplyRecommendedRedisSettingsCommand}"
                                    ToolTip.Tip="Set the values recommended by Creatio documentation for Redis Cluster."/>

                            <Border IsVisible="{Binding ShowClientsManagerWarning}"
                                    Background="#40FFA000" CornerRadius="4" Padding="8" Margin="0,8,0,0">
                                <StackPanel Spacing="8">
                                    <TextBlock TextWrapping="Wrap"
                                               Text="This site uses a Redis clients manager that cannot work with a cluster. Cluster mode requires the StackExchange adapter."/>
                                    <Button Content="Switch to the StackExchange adapter" HorizontalAlignment="Left"
                                            Command="{Binding UseStackExchangeAdapterCommand}"/>
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding RedisSectionAttributes}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="260,*" Margin="0,0,0,10">
                                            <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Name}" FontSize="10" Opacity="0.5"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <CheckBox IsChecked="{Binding BoolValue}" IsVisible="{Binding IsBoolean}"
                                                          Content="Enabled" MinHeight="32"/>
                                                <TextBox Text="{Binding Value}" IsVisible="{Binding IsText}" Height="32"/>

                                                <TextBlock Text="{Binding Description}" IsVisible="{Binding HasDescription}"
                                                           FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                <TextBlock Text="{Binding RecommendedHint}" IsVisible="{Binding ShowRecommendation}"
                                                           FontSize="11" Foreground="#FFA000" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            </StackPanel>
                        </Expander>

                        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" IsVisible="{Binding HasRedisSentinel}">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Sentinel hosts:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SentinelHosts}" Height="32" Margin="0,0,0,8"
                                     Watermark="host1:26380,host2:26381,host3:26382"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Master name:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SentinelMasterName}" Height="32" Margin="0,0,0,8" Watermark="mymaster"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Scan for sentinels:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding SentinelScanForOther}" Margin="0,0,0,8"
                                      ToolTip.Tip="Automatically discover other sentinel nodes"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="DB index:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding SentinelDb}" Minimum="0" Maximum="9999" Increment="1" Height="32" Margin="0,0,0,8" FormatString="0"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Other parameters:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding SentinelExtraParams}" Height="32"
                                     Watermark="maxReadPoolSize=10; maxWritePoolSize=500"/>
                        </Grid>

                        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto" IsVisible="{Binding HasRedisCluster}">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Cluster nodes:" VerticalAlignment="Top" Margin="0,6,12,8"
                                       ToolTip.Tip="At least 3 master nodes; 6 nodes total recommended for fault tolerance"/>
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" Margin="0,0,0,8">
                                <ItemsControl ItemsSource="{Binding ClusterNodes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:RedisClusterNodeViewModel">
                                            <Grid ColumnDefinitions="*,80,*" Margin="0,0,0,4">
                                                <TextBox Grid.Column="0" Text="{Binding Host}" Height="32" Margin="0,0,8,0" Watermark="hostname or IP"/>
                                                <TextBlock Grid.Column="1" Text="Port:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <Grid Grid.Column="2" ColumnDefinitions="*,Auto">
                                                    <NumericUpDown Grid.Column="0" Value="{Binding Port}" Minimum="0" Maximum="65535" Increment="1" Height="32" Margin="0,0,8,0" FormatString="0"/>
                                                    <Button Grid.Column="1" Content="✕" Width="32" Height="32" Padding="0"
                                                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                            Command="{Binding $parent[ItemsControl].((vm:ConnectionStringsViewModel)DataContext).RemoveClusterNodeCommand, FallbackValue={x:Null}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip.Tip="Remove node"/>
                                                </Grid>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="+ Add node" Height="32" Command="{Binding AddClusterNodeCommand}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Pwd:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RedisPassword}" Height="32" PasswordChar="*" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Other parameters:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RedisExtraParams}" Height="32"
                                     Watermark="useTls=true; certificatePath=...; certificatePassword=..."/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.3" Margin="0,4"/>
                        </StackPanel>

                        <StackPanel Spacing="12" IsVisible="{Binding HasMq}">
                        <TextBlock Text="Message Broker (RabbitMQ / AMQP)" FontWeight="SemiBold" FontSize="13"/>
                        <Grid ColumnDefinitions="160,*,80,*" RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="User:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding MqUser}" Height="32" Margin="0,0,8,8"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Pwd:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding MqPassword}" Height="32" PasswordChar="*" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Host:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MqHost}" Height="32" Margin="0,0,8,8" Watermark="hostname or IP"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Port:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <NumericUpDown Grid.Row="1" Grid.Column="3" Value="{Binding MqPort}" Minimum="0" Maximum="65535" Increment="1" Height="32" Margin="0,0,0,8" FormatString="0" ToolTip.Tip="0 = default (5672)"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Virtual Host:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding MqVirtualHost}" Height="32" Watermark="e.g. BPMonlineSolution"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.3" Margin="0,4"/>
                        </StackPanel>

                        <StackPanel Spacing="12" IsVisible="{Binding HasElastic}">
                        <TextBlock Text="Elasticsearch" FontWeight="SemiBold" FontSize="13"/>
                        <Grid ColumnDefinitions="160,*,80,*" RowDefinitions="Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="User:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ElasticUser}" Height="32" Margin="0,0,8,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Pwd:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding ElasticPassword}" Height="32" PasswordChar="*"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.3" Margin="0,4"/>
                        </StackPanel>

                        <StackPanel Spacing="12" IsVisible="{Binding HasInflux}">
                        <TextBlock Text="InfluxDB (Metrics)" FontWeight="SemiBold" FontSize="13"/>
                        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="URL:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding InfluxUrl}" Height="32" Margin="0,0,0,8" Watermark="http://host:port"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="User:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding InfluxUser}" Height="32" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Pwd:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding InfluxPassword}" Height="32" PasswordChar="*" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Batch interval (ms):" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding InfluxBatchIntervalMs}" Minimum="0" Maximum="600000" Increment="500" Height="32" FormatString="0"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.3" Margin="0,4"/>
                        </StackPanel>

                        <StackPanel Spacing="12" IsVisible="{Binding HasS3}">
                        <TextBlock Text="S3 / Object Storage (MinIO)" FontWeight="SemiBold" FontSize="13"/>
                        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Service URL:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding S3ServiceUrl}" Height="32" Margin="0,0,0,8" Watermark="http://host:port"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Access Key:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding S3AccessKey}" Height="32" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Secret Key:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding S3SecretKey}" Height="32" PasswordChar="*" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Object Bucket:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding S3ObjectBucketName}" Height="32" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Recycle Bucket:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding S3RecycleBucketName}" Height="32"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.3" Margin="0,4"/>
                        </StackPanel>

                        <StackPanel Spacing="12" IsVisible="{Binding HasPaths}">
                        <TextBlock Text="Paths" FontWeight="SemiBold" FontSize="13"/>
                        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Packages working copy:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DefPackagesWorkingCopyPath}" Height="32" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Temp directory:" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TempDirectoryPath}" Height="32" Margin="0,0,0,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Source control auth:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SourceControlAuthPath}" Height="32"/>
                        </Grid>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Statistics">
                <Grid RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Grid.Row="0"
                               Text="{Binding TotalDurationText}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"
                               IsVisible="{Binding TotalDurationText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <Grid Grid.Row="1" ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Margin="5">
                            <TextBlock Text="Operation Durations (seconds)" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <lvc:PieChart Series="{Binding DurationsSeries}" LegendPosition="Hidden" Height="400" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5">
                            <TextBlock Text="Execution Pipeline" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <lvc:CartesianChart Series="{Binding PipelineSeries}" YAxes="{Binding PipelineYAxes}" XAxes="{Binding PipelineXAxes}" TooltipPosition="Center" ZoomMode="X" Height="400">
    <lvc:CartesianChart.Tooltip>
        <local:PipelineTooltip/>
    </lvc:CartesianChart.Tooltip>
</lvc:CartesianChart>
                        </StackPanel>
                    </Grid>
                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding LegendItems}"
                                  HorizontalAlignment="Center"
                                  Margin="0,8,0,4">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="6,3">
                                    <Border Width="12" Height="12" Background="{Binding Brush}" CornerRadius="2" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" FontSize="14" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    <TextBlock Text="{Binding Duration}" FontSize="14" Foreground="Gray" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Column="1"
                Width="350"
                Background="{DynamicResource ThemeBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="1"
                Padding="10"
                IsVisible="{Binding IsServerPanelVisible}">
            <Grid x:Name="ServerPanelStack" RowDefinitions="Auto,*">
                <StackPanel Grid.Row="0" Spacing="10" IsEnabled="{Binding AreControlsEnabled}">
                    <Button x:Name="AddServerButton"
                            Content="Add"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Click="AddServer_Click"
                            Height="32"
                            IsEnabled="{Binding IsServerControlsEnabled}"/>
                    <Button Content="Refresh All Status"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Command="{Binding RefreshAllServersStatusCommand}"
                            Height="32"
                            IsVisible="{Binding IsWindows}" />

                    <Grid ColumnDefinitions="*,Auto" >
                        <Button Grid.Column="0"
                                Content="{Binding SyncModeButtonText}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="32"
                                Click="SyncthingSettings_Click" />
                        <Button Grid.Column="1"
                                Content="🌐" FontSize="20" Padding="2"
                                Margin="5,0,0,0"
                                Click="OpenSyncthingWeb_Click"
                                ToolTip.Tip="Open Syncthing Web UI"
                                Height="32"
                                IsVisible="{Binding UseSyncthingForSync}"
                                IsEnabled="{Binding HasSyncthingApiUrl}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          IsVisible="{Binding CanUseSyncthingBulkOperations}">
                        <Button Grid.Column="0"
                                Content="▶️ Resume Sync"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="32"
                                Margin="0,0,2.5,0"
                                Command="{Binding ResumeAllSyncthingFoldersCommand}"
                                ToolTip.Tip="Resume synchronization for all configured Syncthing folders" />
                        <Button Grid.Column="1"
                                Content="⏸️ Pause Sync"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="32"
                                Margin="2.5,0,0,0"
                                Command="{Binding PauseAllSyncthingFoldersCommand}"
                                ToolTip.Tip="Pause synchronization for all configured Syncthing folders" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          IsVisible="{Binding CanUseIisBulkOperations}">
                        <Button Grid.Column="0"
                                Content="▶️ Start All IIS"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="32"
                                Margin="0,0,2.5,0"
                                Command="{Binding StartAllIisCommand}"
                                ToolTip.Tip="Start all IIS sites and application pools" />
                        <Button Grid.Column="1"
                                Content="⏸️ Stop All IIS"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="32"
                                Margin="2.5,0,0,0"
                                Command="{Binding StopAllIisCommand}"
                                ToolTip.Tip="Stop all IIS sites and application pools" />
                    </Grid>

                    <TextBlock Text="Target servers:"
                               FontWeight="Bold"
                               Margin="0,0,0,5"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ServerList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="domain:ServerInfo">
                                <StackPanel Orientation="Vertical" Margin="0,0,0,15" >
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <Button Content="✖"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemoveServerCommand, FallbackValue={x:Null}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsServerControlsEnabled, FallbackValue=True}"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Width="230" ToolTip.Tip="{Binding NetworkPath}"
                                                   PointerPressed="ServerName_DoubleClick" />
                                        <Button Content="🔄" FontSize="20" Padding="2"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RefreshServerStatusCommand, FallbackValue={x:Null}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding !IsStatusLoading}"
                                                ToolTip.Tip="Refresh Status" />
                                    </StackPanel>

                                    <TextBlock FontSize="11" Foreground="Gray" TextTrimming="CharacterEllipsis" MaxWidth="310">
                                        <Run Text="Network path: " />
                                        <Run Text="{Binding NetworkPath}" />
                                    </TextBlock>

                                    <StackPanel Orientation="Horizontal" MaxWidth="310">
                                        <TextBlock Text="Pool name: " FontSize="11" Width="60" Foreground="Gray" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding PoolName}"
                                                   FontSize="11"
                                                   Foreground="Gray"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="196"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" [" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding PoolStatus}"
                                                   FontSize="11"
                                                   Foreground="{Binding PoolStatus, Converter={x:Static converters:StatusToColorConverter.Instance}}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="]" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" MaxWidth="310">
                                        <TextBlock Text="Site name: " FontSize="11" Width="60" Foreground="Gray" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SiteName}"
                                                   FontSize="11"
                                                   Foreground="Gray"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="196"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" [" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SiteStatus}"
                                                   FontSize="11"
                                                   Foreground="{Binding SiteStatus, Converter={x:Static converters:StatusToColorConverter.Instance}}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="]" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel MaxWidth="310"
                                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).UseSyncthingForSync}"
                                                Spacing="3">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Syncthing: " FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding SyncthingStatus}"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding SyncthingStatus, Converter={x:Static converters:StatusToColorConverter.Instance}}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <ProgressBar Value="{Binding SyncthingCompletionPercent}"
                                                     Maximum="100"
                                                     Height="4"
                                                     IsVisible="{Binding IsSyncthingSyncing}"
                                                     Foreground="#4A90E2"
                                                     Background="#E0E0E0"/>

                                        <TextBlock Text="{Binding SyncthingRemainingFormatted}"
                                                   FontSize="10"
                                                   Foreground="Gray"
                                                   IsVisible="{Binding IsSyncthingSyncing}"/>

                                        <StackPanel Orientation="Horizontal"
                                                    IsVisible="{Binding SyncthingLastSyncedFile, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Text="Last: " FontSize="10" Foreground="Gray"/>
                                            <TextBlock Text="{Binding SyncthingLastSyncedFile}"
                                                       FontSize="10"
                                                       Foreground="Gray"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="250"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,5,0,0">
                                        <Button Content="Start Pool" FontSize="12" Padding="5,2"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).StartPoolCommand, FallbackValue={x:Null}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding !IsStatusLoading}"
                                                Width="70"/>
                                        <Button Content="Stop Pool" FontSize="12" Padding="5,2"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).StopPoolCommand, FallbackValue={x:Null}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding !IsStatusLoading}"
                                                Width="70"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,2,0,0">
                                        <Button Content="Start Site" FontSize="12" Padding="5,2"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).StartSiteCommand, FallbackValue={x:Null}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding !IsStatusLoading}"
                                                Width="70"/>
                                        <Button Content="Stop Site" FontSize="12" Padding="5,2"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).StopSiteCommand, FallbackValue={x:Null}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding !IsStatusLoading}"
                                                Width="70"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
