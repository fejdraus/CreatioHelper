<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CreatioHelper.ViewModels"
        xmlns:domain="clr-namespace:CreatioHelper.Domain.Entities;assembly=CreatioHelper.Domain"
        xmlns:converters="clr-namespace:CreatioHelper.Converters"
        xmlns:avalonEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        x:Class="CreatioHelper.MainWindow"
        x:Name="MainRoot"
        x:DataType="vm:MainWindowViewModel"
        Width="1065" Height="670"
        MinWidth="1065" MinHeight="400"
        Title="Creatio Helper"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <converters:BoolToScrollBarVisibilityConverter x:Key="BoolToScrollBarVisibilityConverter"/>
            <converters:DeleteAppVersionToVisibilityConverter x:Key="DeleteAppVersionToVisibilityConverter"/>
            <converters:NotConverter x:Key="NotConverter"/>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="UpdateBadgeBackground" Color="#C8E6C9"/>
                    <SolidColorBrush x:Key="UpdateBadgeForeground" Color="#1B5E20"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="UpdateBadgeBackground" Color="#2E7D32"/>
                    <SolidColorBrush x:Key="UpdateBadgeForeground" Color="#E8F5E9"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid ColumnDefinitions="*,Auto">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" Margin="10">
            <Grid Grid.Row="0" Margin="0,0,0,5" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" IsVisible="{Binding IsWindows}" IsEnabled="{Binding AreControlsEnabled}">
                    <TextBlock Text="Site path source:" />
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0" VerticalAlignment="Center">
                        <RadioButton Content="IIS" IsChecked="{Binding IsIisMode}" GroupName="SiteSource" VerticalAlignment="Center"/>
                        <RadioButton Content="Folder" IsChecked="{Binding IsFolderMode}" GroupName="SiteSource" Margin="15,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding IsFileDesignModeEnabled}"
                            IsEnabled="{Binding AreControlsEnabled}">
                    <TextBlock Text="Packages:" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="Creatio → FS"
                                Command="{Binding DownloadPackagesOpCommand}"
                                Width="110" Height="32" Margin="0,0,10,0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                ToolTip.Tip="Download packages from database to file system"/>
                        <Button Content="Clean &amp; Validate"
                                Command="{Binding ValidatePackagesOpCommand}"
                                Width="130" Height="32" Margin="0,0,10,0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                ToolTip.Tip="Validate JSON files, dependencies and package structure"/>
                        <Button Content="FS → Creatio"
                                Command="{Binding LoadPackagesToDBOpCommand}"
                                Width="110" Height="32"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                ToolTip.Tip="Load packages from file system to database"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="Redis:" HorizontalAlignment="Right"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Status" Command="{Binding CheckRedisStatusCommand}" Width="80" Height="32" Margin="10,0" ToolTip.Tip="Check Redis status"/>
                        <Button Content="Clear" Command="{Binding ClearRedisCommand}" Width="80" Height="32" ToolTip.Tip="Clear Redis cache"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
            
            <!-- Row 1: Folder Mode -->
            <StackPanel Grid.Row="1" IsVisible="{Binding IsFolderMode}" Margin="0,0,0,5" IsEnabled="{Binding AreControlsEnabled}">
                <TextBlock Text="Site Path:" />
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <TextBox x:Name="SitePathTextBox" Text="{Binding SitePath, Mode=TwoWay}" 
                             PlaceholderText="Enter path to Creatio application folder"
                             Margin="0,0,5,0"/>
                    <Button x:Name="BrowseSiteButton" Grid.Column="1" Content="Browse" Command="{Binding BrowseSitePathCommand}" Margin="5,0,0,0" Height="32"/>
                </Grid>
                <TextBlock Text="Service Name (for service management):" Margin="0,5,0,0" />
                <TextBox x:Name="ServiceNameTextBox" Text="{Binding ServiceName, Mode=TwoWay}" 
                         PlaceholderText="Enter service name for Linux/Windows service management" />
            </StackPanel>

            <!-- Row 2: IIS Mode -->
            <StackPanel Grid.Row="2" IsVisible="{Binding IsIisMode}" Margin="0,0,0,5" IsEnabled="{Binding AreControlsEnabled}">
                <TextBlock Text="Site IIS:" />
                <ComboBox x:Name="IisSitesComboBox"
                          HorizontalAlignment="Stretch"
                          IsEnabled="{Binding HasIisSites}"
                          ItemsSource="{Binding IisSites}"
                          SelectedItem="{Binding SelectedIisSite}"
                          PlaceholderText="Select IIS site from the list"
                          IsVisible="{Binding IsWindows}" />
            </StackPanel>

            <!-- Row 3: Packages Path with Prevalidate checkbox -->
            <StackPanel Grid.Row="3" Margin="0,0,0,5" IsEnabled="{Binding AreControlsEnabled}">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Packages Path:" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1"
                              Content="Prevalidate package installation"
                              IsChecked="{Binding PrevalidateBeforeInstall}"
                              IsEnabled="{Binding PackagesPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Right"
                              ToolTip.Tip="Run pre-validation before installing packages"/>
                </Grid>
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <TextBox x:Name="PackagesPathTextBox" Text="{Binding PackagesPath, Mode=TwoWay}"
                             PlaceholderText="Enter path to packages folder for installation"
                             Margin="0,0,5,0" />
                    <Button x:Name="BrowsePackagesButton" Grid.Column="1" Content="Browse"
                            Command="{Binding BrowsePackagesPathCommand}" Margin="5,0,0,0" Height="32"/>
                </Grid>
            </StackPanel>

            <!-- Row 4: Delete packages before / after -->
            <Grid Grid.Row="4" ColumnDefinitions="*,10,*" RowDefinitions="Auto,Auto" Margin="0,0,0,5" IsEnabled="{Binding AreControlsEnabled}">
                <Grid.IsVisible>
                    <MultiBinding Converter="{StaticResource DeleteAppVersionToVisibilityConverter}" TargetNullValue="False">
                        <Binding Path="IsIisMode"/>
                        <Binding Path="IsFolderMode"/>
                        <Binding Path="SelectedIisSiteVersion"/>
                        <Binding Path="SitePathWithVersion"/>
                    </MultiBinding>
                </Grid.IsVisible>
                <TextBlock Grid.Column="0" Text="Delete packages before install:" Margin="0,0,5,2" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Delete packages after install:" Margin="0,0,0,2" />

                <TextBox Grid.Row="1" Grid.Column="0"
                         x:Name="PackagesToDeleteBeforeTextBox"
                         Text="{Binding PackagesToDeleteBefore, Mode=TwoWay}"
                         PlaceholderText="Package names to delete before installation (comma-separated or one per line)"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="65" />

                <TextBox Grid.Row="1" Grid.Column="2"
                         x:Name="PackagesToDeleteAfterTextBox"
                         Text="{Binding PackagesToDeleteAfter, Mode=TwoWay}"
                         PlaceholderText="Package names to delete after installation (comma-separated or one per line)"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="65" />
            </Grid>

            <!-- Row 5: Start/Stop buttons, Load License, and server sync -->
            <Grid Grid.Row="5" ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" Margin="0,5,0,5">
                <!-- Start button -->
                <Button x:Name="StartButton"
                        Grid.Column="0"
                        Content="{Binding StartButtonText}"
                        Command="{Binding StartCommand}"
                        IsEnabled="{Binding AreControlsEnabled}"
                        Width="140"
                        Height="32"/>

                <!-- Stop and kill WSC button -->
                <Button x:Name="StopButtonAndKillWorkspaceConsole"
                        Grid.Column="1"
                        Content="Stop and kill WSC"
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsStopButtonEnabled}"
                        Width="140"
                        Height="32"
                        Margin="10,0,0,0" />

                <!-- Empty spacer (Grid.Column="2") for alignment -->

                <!-- Save License Request button (Grid.Column="3") -->
                <Button x:Name="SaveLicenseRequestButton"
                        Grid.Column="3"
                        Content="Save Lic Request"
                        Click="SaveLicenseRequest_Click"
                        IsEnabled="{Binding AreControlsEnabled}"
                        Width="135"
                        Height="32"
                        Margin="0,0,10,0"
                        ToolTip.Tip="Generate license request file (.tlr)"/>

                <!-- Load License button (Grid.Column="4") -->
                <Button x:Name="LoadLicenseButton"
                        Grid.Column="4"
                        Content="Load License"
                        Command="{Binding LoadLicenseCommand}"
                        IsEnabled="{Binding AreControlsEnabled}"
                        Width="110"
                        Height="32"
                        Margin="0,0,10,0"
                        ToolTip.Tip="Load license response file (.tls)"/>

                <!-- ServerPanel button (Grid.Column="5") -->
                <Button x:Name="ServerPanelButton"
                        Grid.Column="5"
                        Content="{Binding ServerPanelButtonText}"
                        Command="{Binding ToggleServerPanelCommand}"
                        IsVisible="{Binding IsWindows}"
                        IsEnabled="{Binding AreControlsEnabled}"
                        Width="130"
                        Height="32"
                        HorizontalAlignment="Right" />
            </Grid>

            <!-- Row 6: log toolbar — Clear/checkboxes left, optional update banner middle, Settings right -->
            <Grid Grid.Row="6" Margin="0,0,0,5" ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Clear"
                            Command="{Binding ClearLogCommand}"
                            Height="32"
                            Padding="12,0"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"/>
                    <CheckBox x:Name="AutoScrollCheckBox"
                              Content="Auto Scroll"
                              IsChecked="{Binding IsAutoScrollEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"/>
                    <CheckBox x:Name="WrapTextCheckBox"
                              Content="Wrap Text"
                              IsChecked="{Binding IsWrapTextEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"/>
                    <CheckBox x:Name="LogToFileCheckBox"
                              Content="Log To File"
                              IsChecked="{Binding IsLogToFileEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{DynamicResource UpdateBadgeBackground}"
                        CornerRadius="14"
                        Padding="14,4"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="10,0,10,0"
                        IsVisible="{Binding IsUpdateAvailable}"
                        ToolTip.Tip="Open Settings to install the update">
                    <TextBlock Text="Update available"
                               Foreground="{DynamicResource UpdateBadgeForeground}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Border>

                <Button Grid.Column="2"
                        x:Name="SettingsButton"
                        Content="Settings"
                        Click="Settings_Click"
                        Height="32"
                        Padding="12,0"
                        VerticalAlignment="Center"
                        VerticalContentAlignment="Center"
                        HorizontalAlignment="Right"
                        HorizontalContentAlignment="Center"/>
            </Grid>

            <!-- Row 7: Log list box (star "*" stretches to fill remaining space) -->
            <Border Grid.Row="7" BorderBrush="#D4D4D4" BorderThickness="1" CornerRadius="5" Padding="5">
                <avalonEdit:TextEditor
                    x:Name="LogTextEditor"
                    Background="{DynamicResource TextEditorBackgroundBrush}"
                    Foreground="{DynamicResource TextEditorForegroundBrush}"
                    FontFamily="Cascadia Code,Consolas,Monospace"
                    FontSize="12"
                    IsReadOnly="True"
                    WordWrap="{Binding IsWrapTextEnabled}"
                    HorizontalScrollBarVisibility="{Binding IsWrapTextEnabled, Converter={StaticResource BoolToScrollBarVisibilityConverter}}"
                    VerticalScrollBarVisibility="Auto"/>
            </Border>
        </Grid>

        <!-- Right panel: server list (static) -->
        <Border Grid.Column="1"
                Width="350"
                Background="{DynamicResource ThemeBackgroundBrush}"
                BorderBrush="{DynamicResource ThemeBorderBrush}"
                BorderThickness="1"
                Padding="10"
                IsVisible="{Binding IsServerPanelVisible}">
            <Grid x:Name="ServerPanelStack" RowDefinitions="Auto,*">
                <!-- Top section: Add button, header, etc. -->
                <StackPanel Grid.Row="0" Spacing="10" IsEnabled="{Binding AreControlsEnabled}">
                    <Button x:Name="AddServerButton"
                            Content="Add"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Click="AddServer_Click" 
                            Height="32"
                            IsEnabled="{Binding IsServerControlsEnabled}"/>
                    <Button Content="Refresh All Status"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Command="{Binding RefreshAllServersStatusCommand}"
                            Height="32"
                            IsVisible="{Binding IsWindows}" />

                    <!-- Syncthing buttons: Settings and Web UI -->
                    <Grid ColumnDefinitions="*,Auto" >
                        <Button Grid.Column="0"
                                Content="{Binding SyncModeButtonText}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="32"
                                Click="SyncthingSettings_Click" />
                        <Button Grid.Column="1"
                                Content="🌐" FontSize="20" Padding="2"
                                Margin="5,0,0,0"
                                Click="OpenSyncthingWeb_Click"
                                ToolTip.Tip="Open Syncthing Web UI"
                                Height="32"
                                IsVisible="{Binding UseSyncthingForSync}"
                                IsEnabled="{Binding HasSyncthingApiUrl}" />
                    </Grid>

                    <!-- Syncthing Bulk Operations: Start/Stop All -->
                    <Grid ColumnDefinitions="*,*"
                          IsVisible="{Binding CanUseSyncthingBulkOperations}">
                        <Button Grid.Column="0"
                                Content="▶️ Resume Sync"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="32"
                                Margin="0,0,2.5,0"
                                Command="{Binding ResumeAllSyncthingFoldersCommand}"
                                ToolTip.Tip="Resume synchronization for all configured Syncthing folders" />
                        <Button Grid.Column="1"
                                Content="⏸️ Pause Sync"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="32"
                                Margin="2.5,0,0,0"
                                Command="{Binding PauseAllSyncthingFoldersCommand}"
                                ToolTip.Tip="Pause synchronization for all configured Syncthing folders" />
                    </Grid>

                    <!-- IIS Bulk Operations: Start/Stop All Sites and Pools -->
                    <Grid ColumnDefinitions="*,*"
                          IsVisible="{Binding CanUseIisBulkOperations}">
                        <Button Grid.Column="0"
                                Content="▶️ Start All IIS"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="32"
                                Margin="0,0,2.5,0"
                                Command="{Binding StartAllIisCommand}"
                                ToolTip.Tip="Start all IIS sites and application pools" />
                        <Button Grid.Column="1"
                                Content="⏸️ Stop All IIS"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Height="32"
                                Margin="2.5,0,0,0"
                                Command="{Binding StopAllIisCommand}"
                                ToolTip.Tip="Stop all IIS sites and application pools" />
                    </Grid>

                    <TextBlock Text="Target servers:"
                               FontWeight="Bold"
                               Margin="0,0,0,5"/>
                </StackPanel>

                <!-- Bottom section: scrollable server list -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ServerList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="domain:ServerInfo">
                                <StackPanel Orientation="Vertical" Margin="0,0,0,15" >
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <Button Content="✖"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemoveServerCommand, FallbackValue={x:Null}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsServerControlsEnabled, FallbackValue=True}"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Width="230" ToolTip.Tip="{Binding NetworkPath}"
                                                   PointerPressed="ServerName_DoubleClick" />
                                        <Button Content="🔄" FontSize="20" Padding="2"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RefreshServerStatusCommand, FallbackValue={x:Null}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding !IsStatusLoading}"
                                                ToolTip.Tip="Refresh Status" />
                                    </StackPanel>
                                    
                                    <TextBlock FontSize="11" Foreground="Gray" TextTrimming="CharacterEllipsis" MaxWidth="310">
                                        <Run Text="Network path: " />
                                        <Run Text="{Binding NetworkPath}" />
                                    </TextBlock>
                                    
                                    <StackPanel Orientation="Horizontal" MaxWidth="310">
                                        <TextBlock Text="Pool name: " FontSize="11" Width="60" Foreground="Gray" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding PoolName}"
                                                   FontSize="11"
                                                   Foreground="Gray"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="196"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" [" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding PoolStatus}"
                                                   FontSize="11"
                                                   Foreground="{Binding PoolStatus, Converter={x:Static converters:StatusToColorConverter.Instance}}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="]" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal" MaxWidth="310">
                                        <TextBlock Text="Site name: " FontSize="11" Width="60" Foreground="Gray" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SiteName}" 
                                                   FontSize="11" 
                                                   Foreground="Gray" 
                                                   TextTrimming="CharacterEllipsis" 
                                                   MaxWidth="196"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" [" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SiteStatus}" 
                                                   FontSize="11" 
                                                   Foreground="{Binding SiteStatus, Converter={x:Static converters:StatusToColorConverter.Instance}}" 
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="]" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <!-- Syncthing Status Section with Enhanced Details -->
                                    <StackPanel MaxWidth="310"
                                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).UseSyncthingForSync}"
                                                Spacing="3">
                                        <!-- Status Line -->
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Syncthing: " FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding SyncthingStatus}"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding SyncthingStatus, Converter={x:Static converters:StatusToColorConverter.Instance}}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Progress Bar (visible only when syncing) -->
                                        <ProgressBar Value="{Binding SyncthingCompletionPercent}"
                                                     Maximum="100"
                                                     Height="4"
                                                     IsVisible="{Binding IsSyncthingSyncing}"
                                                     Foreground="#4A90E2"
                                                     Background="#E0E0E0"/>

                                        <!-- Remaining Data Info (visible when syncing) -->
                                        <TextBlock Text="{Binding SyncthingRemainingFormatted}"
                                                   FontSize="10"
                                                   Foreground="Gray"
                                                   IsVisible="{Binding IsSyncthingSyncing}"/>

                                        <!-- Last Synced File (visible when has value) -->
                                        <StackPanel Orientation="Horizontal"
                                                    IsVisible="{Binding SyncthingLastSyncedFile, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Text="Last: " FontSize="10" Foreground="Gray"/>
                                            <TextBlock Text="{Binding SyncthingLastSyncedFile}"
                                                       FontSize="10"
                                                       Foreground="Gray"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="250"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Buttons to control pool and site -->
                                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,5,0,0">
                                        <Button Content="Start Pool" FontSize="12" Padding="5,2"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).StartPoolCommand, FallbackValue={x:Null}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding !IsStatusLoading}"
                                                Width="70"/>
                                        <Button Content="Stop Pool" FontSize="12" Padding="5,2"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).StopPoolCommand, FallbackValue={x:Null}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding !IsStatusLoading}"
                                                Width="70"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,2,0,0">
                                        <Button Content="Start Site" FontSize="12" Padding="5,2"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).StartSiteCommand, FallbackValue={x:Null}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding !IsStatusLoading}"
                                                Width="70"/>
                                        <Button Content="Stop Site" FontSize="12" Padding="5,2"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).StopSiteCommand, FallbackValue={x:Null}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding !IsStatusLoading}"
                                                Width="70"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
