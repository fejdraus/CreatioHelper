@page "/login"
@layout Layout.AuthLayout
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IStringLocalizer<Localization> L

<PageTitle>@L["Login_Title"] - CreatioHelper</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex justify-center align-center">
    <MudPaper Elevation="4" Class="pa-8 rounded-xl" Style="width: 100%; max-width: 420px;">

        @* Logo *@
        <MudStack AlignItems="AlignItems.Center" Class="mb-6">
            <div class="logo-container">
                <div class="logo-ring"></div>
                <div class="logo-ring ring-2"></div>
                <div class="logo-icon">
                    <MudIcon Icon="@Icons.Material.Filled.Sync" Size="Size.Large" Color="Color.Primary" />
                </div>
            </div>

            <MudText Typo="Typo.h4" Align="Align.Center">CreatioHelper</MudText>
            <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                @L["Login_SignInToContinue"]
            </MudText>
        </MudStack>

        @* Error message *@
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">
                @_errorMessage
            </MudAlert>
        }

        @* Login form *@
        <EditForm Model="@_loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <MudStack Spacing="3">
                <MudTextField @bind-Value="_loginModel.Username"
                              Label="@L["Login_Username"]"
                              Variant="Variant.Outlined"
                              InputType="InputType.Text"
                              Required="true"
                              RequiredError="@L["Login_UsernameRequired"]"
                              Disabled="@_isLoading"
                              Class="rounded-lg" />

                <MudTextField @bind-Value="_loginModel.Password"
                              Label="@L["Login_Password"]"
                              Variant="Variant.Outlined"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="TogglePasswordVisibility"
                              Required="true"
                              RequiredError="@L["Login_PasswordRequired"]"
                              Disabled="@_isLoading"
                              Class="rounded-lg" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Disabled="@_isLoading"
                           Class="mt-2">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        @L["Login_SigningIn"]
                    }
                    else
                    {
                        @L["Login_SignIn"]
                    }
                </MudButton>
            </MudStack>
        </EditForm>

        <div class="or-divider my-4">
            <span>@L["Common_Or"]</span>
        </div>

        @* API Key login *@
        <MudExpansionPanels Elevation="0">
            <MudExpansionPanel Text="@L["Login_LoginWithApiKey"]" Dense="true">
                <MudStack Spacing="3">
                    <MudTextField @bind-Value="_apiKey"
                                  Label="@L["Login_ApiKey"]"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Password"
                                  Disabled="@_isLoading" />

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               FullWidth="true"
                               OnClick="HandleApiKeyLogin"
                               Disabled="@(_isLoading || string.IsNullOrWhiteSpace(_apiKey))">
                        @L["Login_LoginWithApiKey"]
                    </MudButton>
                </MudStack>
            </MudExpansionPanel>
        </MudExpansionPanels>

        <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary" Class="mt-4 d-block">
            @L["Login_DefaultCredentials"]
        </MudText>
    </MudPaper>
</MudContainer>

<style>
    .logo-container {
        position: relative;
        width: 80px;
        height: 80px;
        margin-bottom: 16px;
    }

    .logo-ring {
        position: absolute;
        inset: 0;
        border: 2px solid transparent;
        border-top-color: var(--mud-palette-primary);
        border-radius: 50%;
        animation: login-spin 2s linear infinite;
    }

    .logo-ring.ring-2 {
        inset: 8px;
        border-top-color: transparent;
        border-right-color: var(--mud-palette-secondary);
        animation-direction: reverse;
        animation-duration: 1.5s;
    }

    .logo-icon {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    @@keyframes login-spin {
        to { transform: rotate(360deg); }
    }

    .or-divider {
        display: flex;
        align-items: center;
        text-align: center;
    }

    .or-divider::before,
    .or-divider::after {
        content: '';
        flex: 1;
        border-bottom: 1px solid var(--mud-palette-lines-default);
    }

    .or-divider span {
        padding: 0 12px;
        color: var(--mud-palette-text-secondary);
        font-size: 0.875rem;
    }
</style>

@code {
    private LoginModel _loginModel = new();
    private string? _apiKey;
    private bool _isLoading;
    private bool _showPassword;
    private string? _errorMessage;

    [Parameter]
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.IsAuthenticated)
        {
            NavigateToReturnUrl();
            return;
        }

        if (await AuthService.ValidateSessionAsync())
        {
            NavigateToReturnUrl();
        }
    }

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var success = await AuthService.LoginAsync(_loginModel.Username, _loginModel.Password);

            if (success)
            {
                Snackbar.Add(L["Login_Welcome", _loginModel.Username], Severity.Success);
                NavigateToReturnUrl();
            }
            else
            {
                _errorMessage = AuthService.ErrorMessage ?? L["Login_Failed"];
            }
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleApiKeyLogin()
    {
        if (string.IsNullOrWhiteSpace(_apiKey))
            return;

        _isLoading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var success = await AuthService.LoginWithApiKeyAsync(_apiKey);

            if (success)
            {
                Snackbar.Add(L["Login_AuthenticatedWithApiKey"], Severity.Success);
                NavigateToReturnUrl();
            }
            else
            {
                _errorMessage = AuthService.ErrorMessage ?? L["Login_ApiKeyFailed"];
            }
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private void NavigateToReturnUrl()
    {
        var url = string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl;
        Navigation.NavigateTo(url);
    }

    private class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
