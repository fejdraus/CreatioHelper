@page "/"
@inject IApiClient ApiClient
@inject StateContainer State
@inject ISnackbar Snackbar
@inject IStringLocalizer<Localization> L

<PageTitle>@L["Dashboard_Title"] - CreatioHelper</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L["Dashboard_Title"]</MudText>

@* System Status Cards *@
<MudGrid>
    @* Status Card *@
    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2">
            <MudCardContent Class="stats-card">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                         Color="@GetStatusColor()"
                         Size="Size.Large"
                         Class="mb-2" />
                <div class="value">@GetStatusText()</div>
                <div class="label">@L["Dashboard_SystemStatus"]</div>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* Folders Card *@
    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2" Class="cursor-pointer" @onclick="@(() => NavigateTo("/folders"))">
            <MudCardContent Class="stats-card">
                <MudIcon Icon="@Icons.Material.Filled.Folder"
                         Color="Color.Primary"
                         Size="Size.Large"
                         Class="mb-2" />
                <div class="value">@State.Folders.Length</div>
                <div class="label">@L["Dashboard_TotalFolders"]</div>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* Devices Card *@
    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2" Class="cursor-pointer" @onclick="@(() => NavigateTo("/devices"))">
            <MudCardContent Class="stats-card">
                <MudIcon Icon="@Icons.Material.Filled.Devices"
                         Color="Color.Secondary"
                         Size="Size.Large"
                         Class="mb-2" />
                <div class="value">@_connectedDevices / @_remoteDevicesCount</div>
                <div class="label">@L["Dashboard_ConnectedDevices"]</div>
            </MudCardContent>
        </MudCard>
    </MudItem>

    @* Transfer Rate Card *@
    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2">
            <MudCardContent Class="stats-card">
                <MudIcon Icon="@Icons.Material.Filled.SwapVert"
                         Color="Color.Info"
                         Size="Size.Large"
                         Class="mb-2" />
                <div class="value transfer-rate">
                    <span class="up">@FormatRate(State.TransferStats.CurrentRateOut)</span>
                    /
                    <span class="down">@FormatRate(State.TransferStats.CurrentRateIn)</span>
                </div>
                <div class="label">@L["Devices_Upload"] / @L["Devices_Download"]</div>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@* Folders Summary *@
<MudText Typo="Typo.h5" Class="mt-6 mb-3">@L["Nav_Folders"]</MudText>
<MudGrid>
    @if (State.Folders.Length == 0)
    {
        <MudItem xs="12">
            <MudAlert Severity="Severity.Info">
                @L["Folders_NoFolders"]. <MudLink Href="/folders">@L["Folders_AddFolder"]</MudLink>
            </MudAlert>
        </MudItem>
    }
    else
    {
        @foreach (var folder in State.Folders.Take(6))
        {
            <MudItem xs="12" sm="6" md="4">
                <FolderSummaryCard Folder="@folder"
                                   Status="@GetFolderStatus(folder.Id)"
                                   OnClick="@(() => NavigateTo("/folders"))" />
            </MudItem>
        }
        @if (State.Folders.Length > 6)
        {
            <MudItem xs="12">
                <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/folders">
                    @L["Common_ViewAll"] (@State.Folders.Length)
                </MudButton>
            </MudItem>
        }
    }
</MudGrid>

@* Recent Activity *@
<MudText Typo="Typo.h5" Class="mt-6 mb-3">@L["Nav_Events"]</MudText>
<MudPaper Elevation="2" Class="pa-4">
    @if (State.RecentEvents.Count == 0)
    {
        <MudText Color="Color.Default" Typo="Typo.body2">@L["Events_NoEvents"]</MudText>
    }
    else
    {
        <MudList T="SyncEvent" Dense="true">
            @foreach (var evt in State.RecentEvents.Take(10))
            {
                <MudListItem>
                    <div class="d-flex align-center">
                        <MudIcon Icon="@GetEventIcon(evt)"
                                 Color="@GetEventColor(evt)"
                                 Size="Size.Small"
                                 Class="mr-3" />
                        <div class="flex-grow-1">
                            <MudText Typo="Typo.body2">@evt.Summary</MudText>
                        </div>
                        <MudText Typo="Typo.caption" Color="Color.Default">
                            @evt.Time.ToLocalTime().ToString("HH:mm:ss")
                        </MudText>
                    </div>
                </MudListItem>
            }
        </MudList>
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/events" Class="mt-2">
            @L["Common_ViewAll"]
        </MudButton>
    }
</MudPaper>

@* System Info *@
@if (State.SystemStatus != null)
{
    <MudText Typo="Typo.h5" Class="mt-6 mb-3">@L["Dashboard_SystemStatus"]</MudText>
    <MudPaper Elevation="2" Class="pa-4">
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudText Typo="Typo.caption" Color="Color.Default">@L["Dashboard_DeviceId"]</MudText>
                <MudText Typo="Typo.body2" Class="device-id">@(State.SystemStatus.MyId?.Length > 20 ? State.SystemStatus.MyId[..20] + "..." : State.SystemStatus.MyId)</MudText>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudText Typo="Typo.caption" Color="Color.Default">@L["Dashboard_Uptime"]</MudText>
                <MudText Typo="Typo.body2">@FormatUptime(State.SystemStatus.UptimeSpan)</MudText>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudText Typo="Typo.caption" Color="Color.Default">@L["Dashboard_Memory"]</MudText>
                <MudText Typo="Typo.body2">@FormatBytes(State.SystemStatus.Alloc ?? 0)</MudText>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudText Typo="Typo.caption" Color="Color.Default">@L["Dashboard_CPU"]</MudText>
                <MudText Typo="Typo.body2">@((State.SystemStatus.CpuPercent ?? 0).ToString("F1"))%</MudText>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

@code {
    [Inject]
    private NavigationManager NavigationManager { get; set; } = null!;

    private int _connectedDevices;
    private int _remoteDevicesCount;
    private Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += OnStateChanged;
        UpdateCounts();
        await LoadFolderStatusesAsync();

        // Auto-refresh folder statuses every 2 seconds
        _refreshTimer = new Timer(async _ =>
        {
            try
            {
                await LoadFolderStatusesAsync();
                await InvokeAsync(StateHasChanged);
            }
            catch
            {
                // Ignore errors during auto-refresh
            }
        }, null, TimeSpan.FromSeconds(2), TimeSpan.FromSeconds(2));
    }

    private void OnStateChanged()
    {
        UpdateCounts();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateCounts()
    {
        _connectedDevices = State.Connections.Values.Count(c => c.Connected);
        var myId = State.SystemStatus?.MyId;
        _remoteDevicesCount = State.Devices.Count(d => d.DeviceId != myId);
    }

    private async Task LoadFolderStatusesAsync()
    {
        try
        {
            foreach (var folder in State.Folders)
            {
                var status = await ApiClient.GetFolderStatusAsync(folder.Id);
                if (status != null)
                {
                    State.UpdateFolderStatus(status);
                }
            }
        }
        catch
        {
            // Ignore errors during load
        }
    }

    private FolderStatus? GetFolderStatus(string folderId)
    {
        return State.FolderStatuses.TryGetValue(folderId, out var status) ? status : null;
    }

    private Color GetStatusColor()
    {
        if (!State.IsConnected) return Color.Error;
        if (State.FolderStatuses.Values.Any(s => s.State == "error")) return Color.Error;
        if (State.FolderStatuses.Values.Any(s => s.State == "syncing")) return Color.Info;
        return Color.Success;
    }

    private string GetStatusText()
    {
        if (!State.IsConnected) return L["Status_Offline"];
        if (State.FolderStatuses.Values.Any(s => s.State == "error")) return L["Common_Error"];
        if (State.FolderStatuses.Values.Any(s => s.State == "syncing")) return L["FolderState_Syncing"];
        return L["Status_Online"];
    }

    private string GetEventIcon(SyncEvent evt) => evt.Severity switch
    {
        EventSeverity.Error => Icons.Material.Filled.Error,
        EventSeverity.Warning => Icons.Material.Filled.Warning,
        EventSeverity.Success => Icons.Material.Filled.CheckCircle,
        _ => Icons.Material.Filled.Info
    };

    private Color GetEventColor(SyncEvent evt) => evt.Severity switch
    {
        EventSeverity.Error => Color.Error,
        EventSeverity.Warning => Color.Warning,
        EventSeverity.Success => Color.Success,
        _ => Color.Info
    };

    private void NavigateTo(string url)
    {
        NavigationManager.NavigateTo(url);
    }

    private string FormatRate(double bytesPerSecond)
    {
        if (bytesPerSecond < 1024) return $"{bytesPerSecond:F0} B/s";
        if (bytesPerSecond < 1024 * 1024) return $"{bytesPerSecond / 1024:F1} KB/s";
        if (bytesPerSecond < 1024 * 1024 * 1024) return $"{bytesPerSecond / (1024 * 1024):F1} MB/s";
        return $"{bytesPerSecond / (1024 * 1024 * 1024):F2} GB/s";
    }

    private string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F2} GB";
    }

    private string FormatUptime(TimeSpan uptime)
    {
        if (uptime.TotalDays >= 1)
            return $"{(int)uptime.TotalDays}{L["Time_Days"]} {uptime.Hours}{L["Time_Hours"]} {uptime.Minutes}{L["Time_Minutes"]}";
        if (uptime.TotalHours >= 1)
            return $"{uptime.Hours}{L["Time_Hours"]} {uptime.Minutes}{L["Time_Minutes"]}";
        return $"{uptime.Minutes}{L["Time_Minutes"]} {uptime.Seconds}{L["Time_Seconds"]}";
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        State.OnChange -= OnStateChanged;
    }
}
