@page "/devices"
@inject IApiClient ApiClient
@inject StateContainer State
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IStringLocalizer<Localization> L
@inject IErrorMessageHelper ErrorHelper
@inject NavigationManager Navigation
@inject ISignalRService SignalR
@implements IDisposable

<PageTitle>@L["Devices_Title"] - CreatioHelper</PageTitle>

<div class="d-flex align-center mb-4">
    <MudText Typo="Typo.h4" Class="flex-grow-1">@L["Devices_Title"]</MudText>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="@AddDevice">
        @L["Devices_AddDevice"]
    </MudButton>
</div>

@if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    @* This Device *@
    @if (_thisDevice != null)
    {
        <MudText Typo="Typo.h6" Class="mb-2">@L["Devices_ThisDevice"]</MudText>
        <MudPaper Elevation="2" Class="mb-4">
            @* Header row - always visible *@
            <div class="d-flex align-center pa-3 cursor-pointer" @onclick="@(() => _thisDeviceExpanded = !_thisDeviceExpanded)">
                <MudIcon Icon="@Icons.Material.Filled.Computer" Color="Color.Primary" Class="mr-3" />
                <div class="flex-grow-1">
                    <MudText Typo="Typo.subtitle1">@_thisDevice.DisplayName</MudText>
                </div>
                <MudText Typo="Typo.body2" Color="Color.Success" Class="mr-2">
                    @L["Devices_Running"]
                </MudText>
                @if (State.SystemStatus != null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Default" Class="mr-2">
                        <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Style="vertical-align: middle;" />
                        <UptimeDisplay StartTime="@State.SystemStatus?.StartTime" />
                    </MudText>
                }
                <MudIconButton Icon="@(_thisDeviceExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                               Size="Size.Small" />
            </div>

            @* Expandable details *@
            <MudCollapse Expanded="@_thisDeviceExpanded">
                <MudDivider />
                <div class="pa-3">
                    <MudSimpleTable Dense="true" Hover="true" Style="background: transparent;">
                        <tbody>
                            <tr>
                                <td style="width: 40%;"><MudText Typo="Typo.body2" Color="Color.Default">@L["Dashboard_DeviceId"]</MudText></td>
                                <td>
                                    <div class="d-flex align-center">
                                        <MudText Typo="Typo.body2" Style="font-family: monospace; font-size: 0.7rem;">@_thisDevice.DeviceId</MudText>
                                        <MudTooltip Text="@L["Action_Copy"]">
                                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                           Size="Size.Small"
                                                           OnClick="@(() => CopyDeviceId(_thisDevice.DeviceId))" />
                                        </MudTooltip>
                                        <MudTooltip Text="@L["Action_ShowQR"]">
                                            <MudIconButton Icon="@Icons.Material.Filled.QrCode"
                                                           Size="Size.Small"
                                                           OnClick="@(() => ShowQrCode(_thisDevice.DeviceId))" />
                                        </MudTooltip>
                                    </div>
                                </td>
                            </tr>
                            @if (State.SystemStatus != null)
                            {
                                <tr>
                                    <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Dashboard_Uptime"]</MudText></td>
                                    <td><MudText Typo="Typo.body2"><UptimeDisplay StartTime="@State.SystemStatus?.StartTime" /></MudText></td>
                                </tr>
                                @if (State.SystemStatus.AppMemory.HasValue)
                                {
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Devices_MemoryUsage"]</MudText></td>
                                        <td><MudText Typo="Typo.body2">@FormatBytes(State.SystemStatus.AppMemory.Value)</MudText></td>
                                    </tr>
                                }
                                @if (State.SystemStatus.CpuPercent.HasValue)
                                {
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Devices_CpuUsage"]</MudText></td>
                                        <td><MudText Typo="Typo.body2">@State.SystemStatus.CpuPercent.Value.ToString("F1")%</MudText></td>
                                    </tr>
                                }
                            }
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Folders_GlobalState"]</MudText></td>
                                <td>
                                    @{
                                        var (globalFiles, globalDirs, globalBytes) = GetTotalGlobalState();
                                    }
                                    <MudText Typo="Typo.body2">
                                        <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" Size="Size.Small" Class="mr-1" />@globalFiles.ToString("N0")
                                        <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Class="ml-2 mr-1" />@globalDirs.ToString("N0")
                                        <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small" Class="ml-2 mr-1" />~@FormatBytes(globalBytes)
                                    </MudText>
                                </td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Folders_LocalState"]</MudText></td>
                                <td>
                                    @{
                                        var (localFiles, localDirs, localBytes) = GetTotalLocalState();
                                    }
                                    <MudText Typo="Typo.body2">
                                        <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" Size="Size.Small" Class="mr-1" />@localFiles.ToString("N0")
                                        <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Class="ml-2 mr-1" />@localDirs.ToString("N0")
                                        <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small" Class="ml-2 mr-1" />~@FormatBytes(localBytes)
                                    </MudText>
                                </td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Devices_Listeners"]</MudText></td>
                                <td><MudText Typo="Typo.body2">@GetListenersDisplay()</MudText></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Devices_Discovery"]</MudText></td>
                                <td><MudText Typo="Typo.body2">@GetDiscoveryDisplay()</MudText></td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Dashboard_ConnectedDevices"]</MudText></td>
                                <td><MudText Typo="Typo.body2">@GetConnectedDevicesCount() / @_remoteDevices.Length</MudText></td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>
                </div>
            </MudCollapse>
        </MudPaper>
    }

    @* Remote Devices *@
    <MudText Typo="Typo.h6" Class="mb-2">@L["Devices_RemoteDevices"]</MudText>

    @if (_remoteDevices.Length == 0)
    {
        <MudPaper Elevation="2" Class="pa-8 text-center">
            <MudIcon Icon="@Icons.Material.Filled.DevicesOther"
                     Size="Size.Large"
                     Color="Color.Default"
                     Class="mb-4" />
            <MudText Typo="Typo.h6" Class="mb-2">@L["Devices_NoRemoteDevices"]</MudText>
            <MudText Color="Color.Default" Class="mb-4">
                @L["Devices_AddDeviceHint"]
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@AddDevice">
                @L["Devices_AddDevice"]
            </MudButton>
        </MudPaper>
    }
    else
    {
        @foreach (var device in _remoteDevices)
        {
            var connection = GetConnection(device.DeviceId);
            var isExpanded = _expandedDevices.Contains(device.DeviceId);
            var isSyncing = IsSyncingWithDevice(device.DeviceId);
            var hasActiveTransfer = connection?.Connected == true && (connection.InBytesPerSec > 0 || connection.OutBytesPerSec > 0);
            <MudPaper Elevation="2" Class="mb-3">
                @* Header row - always visible *@
                <div class="d-flex align-center pa-3 cursor-pointer" @onclick="@(() => ToggleDeviceExpand(device.DeviceId))">
                    <MudTooltip Text="@GetConnectionTooltip(device, connection)" Placement="Placement.Right">
                        <span class="connection-dot @(GetConnectionStatusClass(device, connection, isSyncing, hasActiveTransfer)) mr-3"></span>
                    </MudTooltip>
                    <div class="flex-grow-1">
                        <MudText Typo="Typo.subtitle1">@device.DisplayName</MudText>
                        @if (connection?.Connected != true && !device.Paused)
                        {
                            <MudText Typo="Typo.caption" Class="last-seen">
                                @GetLastSeenText(device.DeviceId)
                            </MudText>
                        }
                    </div>
                    <span class="connection-status-badge @(GetConnectionStatusClass(device, connection, isSyncing, hasActiveTransfer)) mr-2">
                        @GetStatusText(device, connection)
                        @if (connection?.IsRelay == true)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.CloudQueue" Size="Size.Small" Class="ml-1" />
                        }
                    </span>
                    @if (connection?.Connected == true)
                    {
                        <span class="transfer-indicator @(hasActiveTransfer ? "active" : "") mr-2">
                            <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small" Color="@(connection.InBytesPerSec > 0 ? Color.Info : Color.Default)" />
                            <span class="rate-down">@FormatRate(connection.InBytesPerSec)</span>
                            <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" Class="ml-1" Color="@(connection.OutBytesPerSec > 0 ? Color.Success : Color.Default)" />
                            <span class="rate-up">@FormatRate(connection.OutBytesPerSec)</span>
                        </span>
                    }
                    <MudIconButton Icon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                   Size="Size.Small" />
                </div>

                @* Expandable details *@
                <MudCollapse Expanded="@isExpanded">
                    <MudDivider />
                    <div class="pa-3">
                        <MudSimpleTable Dense="true" Hover="true" Style="background: transparent;">
                            <tbody>
                                <tr>
                                    <td style="width: 40%;"><MudText Typo="Typo.body2" Color="Color.Default">@L["Dashboard_DeviceId"]</MudText></td>
                                    <td><MudText Typo="Typo.body2" Style="font-family: monospace; font-size: 0.75rem;">@device.DeviceId</MudText></td>
                                </tr>
                                @if (connection?.Connected == true)
                                {
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Devices_Address"]</MudText></td>
                                        <td><MudText Typo="Typo.body2">@connection.Address (@GetConnectionTypeDisplay(connection.Type))</MudText></td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(connection.ClientVersion))
                                    {
                                        <tr>
                                            <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Dashboard_Version"]</MudText></td>
                                            <td><MudText Typo="Typo.body2">@connection.ClientVersion</MudText></td>
                                        </tr>
                                    }
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Devices_DownloadRate"]</MudText></td>
                                        <td><MudText Typo="Typo.body2">@FormatRate(connection.InBytesPerSec) (@FormatBytes(connection.InBytesTotal) total)</MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Devices_UploadRate"]</MudText></td>
                                        <td><MudText Typo="Typo.body2">@FormatRate(connection.OutBytesPerSec) (@FormatBytes(connection.OutBytesTotal) total)</MudText></td>
                                    </tr>
                                    @if (connection.ConnectedAt.HasValue)
                                    {
                                        <tr>
                                            <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Devices_ConnectedSince"]</MudText></td>
                                            <td><MudText Typo="Typo.body2">@connection.ConnectedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") (@FormatDuration(connection.ConnectionDuration))</MudText></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Devices_Addresses"]</MudText></td>
                                        <td><MudText Typo="Typo.body2">@string.Join(", ", device.Addresses)</MudText></td>
                                    </tr>
                                }
                                <tr>
                                    <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Devices_Compression"]</MudText></td>
                                    <td><MudText Typo="Typo.body2">@GetCompressionDisplay(device.Compression)</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Devices_SyncStatus"]</MudText></td>
                                    <td><MudText Typo="Typo.body2">@GetSyncStatus(device.DeviceId)</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Devices_SharedFolders"]</MudText></td>
                                    <td>
                                        @{
                                            var sharedFolders = GetSharedFolders(device.DeviceId);
                                        }
                                        @if (sharedFolders.Any())
                                        {
                                            @foreach (var folder in sharedFolders)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text" Class="ma-0 mr-1">@folder</MudChip>
                                            }
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.body2" Color="Color.Default">@L["Common_None"]</MudText>
                                        }
                                    </td>
                                </tr>
                                @if (device.Introducer)
                                {
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Devices_Introducer"]</MudText></td>
                                        <td><MudText Typo="Typo.body2" Color="Color.Info">@L["Common_Yes"]</MudText></td>
                                    </tr>
                                }
                                @if (device.AutoAcceptFolders)
                                {
                                    <tr>
                                        <td><MudText Typo="Typo.body2" Color="Color.Default">@L["Devices_AutoAccept"]</MudText></td>
                                        <td><MudText Typo="Typo.body2" Color="Color.Warning">@L["Common_Enabled"]</MudText></td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>

                        @* Action buttons *@
                        <div class="d-flex gap-2 mt-3">
                            <MudButton Variant="Variant.Filled"
                                       Size="Size.Small"
                                       Color="@(device.Paused ? Color.Success : Color.Warning)"
                                       StartIcon="@(device.Paused ? Icons.Material.Filled.PlayArrow : Icons.Material.Filled.Pause)"
                                       OnClick="@(() => TogglePause(device))">
                                @(device.Paused ? L["Action_Resume"] : L["Action_Pause"])
                            </MudButton>
                            <MudButton Variant="Variant.Filled"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       OnClick="@(() => EditDevice(device))">
                                @L["Action_Edit"]
                            </MudButton>
                            <MudButton Variant="Variant.Filled"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Delete"
                                       OnClick="@(() => DeleteDevice(device))">
                                @L["Action_Delete"]
                            </MudButton>
                        </div>
                    </div>
                </MudCollapse>
            </MudPaper>
        }
    }

    @* Pending Devices *@
    @if (_pendingDevices.Length > 0)
    {
        <MudText Typo="Typo.h6" Class="mt-6 mb-2">@L["Devices_PendingDevices"]</MudText>
        <MudPaper Elevation="2" Class="pa-4">
            @foreach (var pending in _pendingDevices)
            {
                <div class="d-flex align-center pa-2">
                    <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Color="Color.Warning" Class="mr-3" />
                    <div class="flex-grow-1">
                        <MudText Typo="Typo.subtitle2">@pending.DisplayName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Default">@pending.Address</MudText>
                    </div>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               Size="Size.Small"
                               Class="mr-2"
                               OnClick="@(() => AcceptDevice(pending))">
                        @L["Common_Confirm"]
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Error"
                               Size="Size.Small"
                               OnClick="@(() => RejectDevice(pending))">
                        @L["Action_Delete"]
                    </MudButton>
                </div>
                <MudDivider />
            }
        </MudPaper>
    }
}

@code {
    [Inject]
    private IJSRuntime JSRuntime { get; set; } = null!;

    private bool _isLoading;
    private DeviceConfig? _thisDevice;
    private DeviceConfig[] _remoteDevices = [];
    private PendingDevice[] _pendingDevices = [];
    private HashSet<string> _expandedDevices = new();
    private bool _thisDeviceExpanded;
    private Dictionary<string, DateTime> _lastSeenTimes = new();

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += OnStateChanged;
        SignalR.OnConnectionChanged += OnConnectionChanged;
        await LoadDevicesAsync();
    }

    private void OnConnectionChanged(ConnectionInfo conn)
    {
        var wasConnected = State.Connections.TryGetValue(conn.DeviceId, out var prevConn) && prevConn.Connected;

        if (conn.Connected)
        {
            _lastSeenTimes[conn.DeviceId] = DateTime.UtcNow;
        }
        else if (wasConnected)
        {
            _lastSeenTimes[conn.DeviceId] = DateTime.UtcNow;
        }

        State.UpdateConnection(conn);
        InvokeAsync(StateHasChanged);
    }

    private void OnStateChanged()
    {
        UpdateDeviceLists();
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadDevicesAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var connections = await ApiClient.GetConnectionsAsync();
            foreach (var conn in connections)
            {
                State.UpdateConnection(conn);
                if (conn.Connected)
                {
                    _lastSeenTimes[conn.DeviceId] = conn.ConnectedAt ?? DateTime.UtcNow;
                }
            }

            _pendingDevices = await ApiClient.GetPendingDevicesAsync();
            UpdateDeviceLists();
        }
        catch (Exception ex)
        {
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            Snackbar.Add($"{L["Msg_LoadFailed", ErrorHelper.GetUserFriendlyMessage(ex)]}", Severity.Warning);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void UpdateDeviceLists()
    {
        var myId = State.SystemStatus?.MyId;
        _thisDevice = State.Devices.FirstOrDefault(d => d.DeviceId == myId);
        _remoteDevices = State.Devices.Where(d => d.DeviceId != myId).ToArray();
    }

    private ConnectionInfo? GetConnection(string deviceId)
    {
        return State.Connections.TryGetValue(deviceId, out var conn) ? conn : null;
    }

    private async Task CopyDeviceId(string deviceId)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", deviceId);
            Snackbar.Add(L["Msg_DeviceIdCopied"], Severity.Success);
        }
        catch
        {
            Snackbar.Add(L["Msg_CopyFailed"], Severity.Error);
        }
    }

    private async Task ShowQrCode(string deviceId)
    {
        var parameters = new DialogParameters<QrCodeDialog>
        {
            { x => x.DeviceId, deviceId }
        };
        await DialogService.ShowAsync<QrCodeDialog>(L["Devices_QrCodeTitle"], parameters);
    }

    private async Task TogglePause(DeviceConfig device)
    {
        try
        {
            device.Paused = !device.Paused;
            await ApiClient.UpdateDeviceAsync(device);
            Snackbar.Add(device.Paused ? L["Msg_DevicePaused"] : L["Msg_DeviceResumed"], Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            device.Paused = !device.Paused;
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            Snackbar.Add($"{L["Msg_TogglePauseFailed", ErrorHelper.GetUserFriendlyMessage(ex)]}", Severity.Error);
        }
    }

    private async Task DeleteDevice(DeviceConfig device)
    {
        var confirmed = await DialogService.ShowMessageBox(
            L["Devices_RemoveDevice"],
            L["Msg_DeleteDeviceConfirm", device.DisplayName],
            yesText: L["Action_Delete"],
            cancelText: L["Settings_Cancel"]);

        if (confirmed == true)
        {
            try
            {
                await ApiClient.DeleteDeviceAsync(device.DeviceId);
                State.Devices = State.Devices.Where(d => d.DeviceId != device.DeviceId).ToArray();
                UpdateDeviceLists();
                Snackbar.Add(L["Msg_DeviceRemoved"], Severity.Success);
            }
            catch (Exception ex)
            {
                if (ErrorHelper.IsAuthenticationError(ex))
                {
                    Navigation.NavigateTo("/login", forceLoad: true);
                    return;
                }
                Snackbar.Add($"{L["Common_Error"]}: {ErrorHelper.GetUserFriendlyMessage(ex)}", Severity.Error);
            }
        }
    }

    private async Task AcceptDevice(PendingDevice pending)
    {
        try
        {
            await ApiClient.AcceptDeviceAsync(pending.DeviceId);
            _pendingDevices = _pendingDevices.Where(p => p.DeviceId != pending.DeviceId).ToArray();
            Snackbar.Add(L["Msg_DeviceAccepted"], Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            Snackbar.Add($"{L["Common_Error"]}: {ErrorHelper.GetUserFriendlyMessage(ex)}", Severity.Error);
        }
    }

    private async Task RejectDevice(PendingDevice pending)
    {
        try
        {
            await ApiClient.RejectDeviceAsync(pending.DeviceId);
            _pendingDevices = _pendingDevices.Where(p => p.DeviceId != pending.DeviceId).ToArray();
            Snackbar.Add(L["Msg_DeviceRejected"], Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            Snackbar.Add($"{L["Common_Error"]}: {ErrorHelper.GetUserFriendlyMessage(ex)}", Severity.Error);
        }
    }

    private async Task AddDevice()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<AddDeviceDialog>(L["Devices_AddDevice"], options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: DeviceConfig newDevice })
        {
            State.Devices = [.. State.Devices, newDevice];
            UpdateDeviceLists();
            await LoadDevicesAsync();
        }
    }

    private async Task EditDevice(DeviceConfig device)
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var parameters = new DialogParameters<AddDeviceDialog>
        {
            { x => x.Device, device }
        };

        var dialog = await DialogService.ShowAsync<AddDeviceDialog>(L["Devices_EditDevice"], parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: DeviceConfig updatedDevice })
        {
            var devices = State.Devices.ToList();
            var index = devices.FindIndex(d => d.DeviceId == updatedDevice.DeviceId);
            if (index >= 0)
            {
                devices[index] = updatedDevice;
                State.Devices = devices.ToArray();
            }
            UpdateDeviceLists();
            await LoadDevicesAsync();
        }
    }

    private string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        if (bytes < 1024L * 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024 * 1024):F2} GB";
        return $"{bytes / (1024.0 * 1024 * 1024 * 1024):F2} TB";
    }

    private string FormatRate(long bytesPerSec)
    {
        if (bytesPerSec < 1024) return $"{bytesPerSec} B/s";
        if (bytesPerSec < 1024 * 1024) return $"{bytesPerSec / 1024.0:F1} KB/s";
        if (bytesPerSec < 1024 * 1024 * 1024) return $"{bytesPerSec / (1024.0 * 1024):F1} MB/s";
        return $"{bytesPerSec / (1024.0 * 1024 * 1024):F2} GB/s";
    }

    private string FormatDuration(TimeSpan? duration)
    {
        if (!duration.HasValue) return "";
        var d = duration.Value;
        if (d.TotalDays >= 1) return $"{(int)d.TotalDays}{L["Time_Days"]} {d.Hours}{L["Time_Hours"]}";
        if (d.TotalHours >= 1) return $"{(int)d.TotalHours}{L["Time_Hours"]} {d.Minutes}{L["Time_Minutes"]}";
        return $"{(int)d.TotalMinutes}{L["Time_Minutes"]}";
    }

    private void ToggleDeviceExpand(string deviceId)
    {
        if (_expandedDevices.Contains(deviceId))
            _expandedDevices.Remove(deviceId);
        else
            _expandedDevices.Add(deviceId);
    }

    private string GetConnectionStatusClass(DeviceConfig device, ConnectionInfo? connection, bool isSyncing = false, bool hasActiveTransfer = false)
    {
        if (device.Paused) return "paused";
        if (connection?.Connected == true)
        {
            var classes = new List<string> { "connected" };
            if (connection.IsRelay) classes.Add("relay");
            if (isSyncing) classes.Add("syncing");
            else if (hasActiveTransfer) classes.Add("active-transfer");
            return string.Join(" ", classes);
        }
        return "disconnected";
    }

    private bool IsSyncingWithDevice(string deviceId)
    {
        var sharedFolderIds = State.Folders
            .Where(f => f.Devices?.Any(d => d.DeviceId == deviceId) == true)
            .Select(f => f.Id)
            .ToList();

        foreach (var folderId in sharedFolderIds)
        {
            if (State.FolderStatuses.TryGetValue(folderId, out var status))
            {
                if (status.State == "syncing" || status.State == "sync-preparing" || status.NeedBytes > 0)
                    return true;
            }
        }
        return false;
    }

    private string GetConnectionTooltip(DeviceConfig device, ConnectionInfo? connection)
    {
        if (device.Paused)
            return L["Devices_Paused"];

        if (connection?.Connected == true)
        {
            var parts = new List<string>();
            parts.Add($"{L["Devices_Connected"]} ({GetConnectionTypeDisplay(connection.Type)})");
            if (connection.IsRelay)
                parts.Add("Relay");
            if (!string.IsNullOrEmpty(connection.Address))
                parts.Add($"{L["Devices_Address"]}: {connection.Address}");
            if (connection.ConnectedAt.HasValue)
                parts.Add($"{FormatDuration(connection.ConnectionDuration)}");
            return string.Join("\n", parts);
        }

        return L["Devices_Disconnected"];
    }

    private string GetLastSeenText(string deviceId)
    {
        if (_lastSeenTimes.TryGetValue(deviceId, out var lastSeen))
        {
            var elapsed = DateTime.UtcNow - lastSeen;
            if (elapsed.TotalMinutes < 1) return $"{L["Devices_LastSeen"]}: {L["Time_JustNow"]}";
            if (elapsed.TotalHours < 1) return $"{L["Devices_LastSeen"]}: {L["Time_MinutesAgo", (int)elapsed.TotalMinutes]}";
            if (elapsed.TotalDays < 1) return $"{L["Devices_LastSeen"]}: {L["Time_HoursAgo", (int)elapsed.TotalHours]}";
            return $"{L["Devices_LastSeen"]}: {L["Time_DaysAgo", (int)elapsed.TotalDays]}";
        }
        return L["Devices_NeverConnected"];
    }

    private Color GetStatusColor(DeviceConfig device, ConnectionInfo? connection)
    {
        if (device.Paused) return Color.Warning;
        if (connection?.Connected == true) return Color.Success;
        return Color.Default;
    }

    private string GetStatusText(DeviceConfig device, ConnectionInfo? connection)
    {
        if (device.Paused) return L["Devices_Paused"];
        if (connection?.Connected == true)
        {
            return connection.IsRelay ? L["Devices_ConnectedRelay"] : L["Devices_Connected"];
        }
        return L["Devices_Disconnected"];
    }

    private string GetConnectionTypeDisplay(string type)
    {
        return type switch
        {
            "tcp-client" => L["ConnectionType_TcpClient"],
            "tcp-server" => L["ConnectionType_TcpServer"],
            "quic-client" => L["ConnectionType_QuicClient"],
            "quic-server" => L["ConnectionType_QuicServer"],
            "relay-client" => L["ConnectionType_RelayClient"],
            "relay-server" => L["ConnectionType_RelayServer"],
            _ => type
        };
    }

    private string GetCompressionDisplay(string compression)
    {
        return compression switch
        {
            "metadata" => L["Compression_Metadata"],
            "always" => L["Compression_Always"],
            "never" => L["Compression_Never"],
            _ => compression
        };
    }

    private string GetSyncStatus(string deviceId)
    {
        var sharedFolderIds = State.Folders
            .Where(f => f.Devices?.Any(d => d.DeviceId == deviceId) == true)
            .Select(f => f.Id)
            .ToList();

        if (!sharedFolderIds.Any()) return L["Devices_NoSharedFolders"];

        var allSynced = true;
        var totalBytes = 0L;
        var syncedBytes = 0L;

        foreach (var folderId in sharedFolderIds)
        {
            if (State.FolderStatuses.TryGetValue(folderId, out var status))
            {
                totalBytes += status.GlobalBytes;
                syncedBytes += status.InSyncBytes;
                if (status.NeedBytes > 0) allSynced = false;
            }
        }

        if (allSynced) return L["Folders_UpToDate"];
        if (totalBytes > 0)
        {
            var percent = (syncedBytes * 100.0 / totalBytes);
            return $"{percent:F0}% {L["FolderState_Syncing"].ToString().ToLower()}";
        }
        return L["FolderState_Syncing"];
    }

    private IEnumerable<string> GetSharedFolders(string deviceId)
    {
        return State.Folders
            .Where(f => f.Devices?.Any(d => d.DeviceId == deviceId) == true)
            .Select(f => f.DisplayName);
    }

    private (long files, long dirs, long bytes) GetTotalGlobalState()
    {
        long files = 0, dirs = 0, bytes = 0;
        foreach (var status in State.FolderStatuses.Values)
        {
            files += status.GlobalFiles;
            dirs += status.GlobalDirectories;
            bytes += status.GlobalBytes;
        }
        return (files, dirs, bytes);
    }

    private (long files, long dirs, long bytes) GetTotalLocalState()
    {
        long files = 0, dirs = 0, bytes = 0;
        foreach (var status in State.FolderStatuses.Values)
        {
            files += status.LocalFiles;
            dirs += status.LocalDirectories;
            bytes += status.LocalBytes;
        }
        return (files, dirs, bytes);
    }

    private string GetListenersDisplay()
    {
        return "TCP, QUIC, Relay";
    }

    private string GetDiscoveryDisplay()
    {
        var parts = new List<string>();
        if (State.SystemStatus?.DiscoveryEnabled == true)
            parts.Add(L["Settings_GlobalDiscovery"]);
        parts.Add(L["Settings_LocalDiscovery"]);
        return parts.Count > 0 ? string.Join(", ", parts) : L["Common_Disabled"];
    }

    private int GetConnectedDevicesCount()
    {
        return State.Connections.Values.Count(c => c.Connected);
    }

    public void Dispose()
    {
        State.OnChange -= OnStateChanged;
        SignalR.OnConnectionChanged -= OnConnectionChanged;
    }
}
