@page "/settings"
@page "/settings/general"
@inject IApiClient ApiClient
@inject StateContainer State
@inject ISnackbar Snackbar
@inject IStringLocalizer<Localization> L
@inject IErrorMessageHelper ErrorHelper
@inject NavigationManager Navigation

<PageTitle>@L["Settings_General"] - CreatioHelper</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L["Settings_General"]</MudText>

@if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_config != null)
{
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-4">@L["Settings_General_DeviceInfo"]</MudText>

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_deviceName"
                              Label="@L["Settings_General_DeviceName"]"
                              Variant="Variant.Filled"
                              HelperText="@L["Settings_General_DeviceNameDesc"]" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Value="@State.SystemStatus?.MyId"
                              Label="@L["Settings_General_DeviceId"]"
                              Variant="Variant.Filled"
                              ReadOnly="true"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                              OnAdornmentClick="CopyDeviceId" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-4">@L["Settings_General_SyncDefaults"]</MudText>

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_defaultFolderPath"
                              Label="@L["Settings_General_DefaultFolderPath"]"
                              Variant="Variant.Filled"
                              HelperText="@L["Settings_General_DefaultFolderPathDesc"]" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect @bind-Value="_folderType"
                           Label="@L["FolderEdit_FolderType"]"
                           Variant="Variant.Filled">
                    <MudSelectItem Value="@FolderType.SendReceive">@L["FolderEdit_Type_SendReceive"]</MudSelectItem>
                    <MudSelectItem Value="@FolderType.SendOnly">@L["FolderEdit_Type_SendOnly"]</MudSelectItem>
                    <MudSelectItem Value="@FolderType.ReceiveOnly">@L["FolderEdit_Type_ReceiveOnly"]</MudSelectItem>
                    <MudSelectItem Value="@FolderType.ReceiveEncrypted">@L["FolderEdit_Type_ReceiveEncrypted"]</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />

        <MudSwitch @bind-Value="_ignorePerms"
                   Color="Color.Primary"
                   Label="@L["Settings_Advanced_IgnorePerms"]" />
        <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-2">
            @L["Settings_Advanced_IgnorePermsDesc"]
        </MudText>

        <MudSwitch @bind-Value="_autoNormalize"
                   Color="Color.Primary"
                   Label="@L["Folders_AutoNormalize"]" />
        <MudText Typo="Typo.caption" Color="Color.Default">
            @L["Folders_AutoNormalizeDesc"]
        </MudText>
    </MudPaper>

    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-4">@L["Settings_General_ApiSettings"]</MudText>

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_apiKey"
                              Label="@L["Settings_General_ApiKey"]"
                              Variant="Variant.Filled"
                              InputType="@(_showApiKey ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showApiKey ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="ToggleApiKeyVisibility" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="GenerateNewApiKey"
                           Class="mt-2">
                    @L["Settings_General_GenerateKey"]
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-4">@L["Settings_General_Startup"]</MudText>

        <MudSwitch @bind-Value="_startMinimized"
                   Color="Color.Primary"
                   Label="@L["Settings_General_StartMinimized"]" />
        <MudText Typo="Typo.caption" Color="Color.Default">
            @L["Settings_General_StartMinimizedDesc"]
        </MudText>
    </MudPaper>

    <div class="d-flex justify-end gap-2">
        <MudButton Variant="Variant.Filled" OnClick="ResetToDefaults">
            @L["Common_ResetDefaults"]
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="SaveSettingsAsync"
                   Disabled="@_isSaving">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @L["Common_Save"]
        </MudButton>
    </div>
}

@code {
    [Inject]
    private IJSRuntime JSRuntime { get; set; } = null!;

    private bool _isLoading;
    private bool _isSaving;
    private SystemConfig? _config;

    // Settings values
    private string _deviceName = string.Empty;
    private string _defaultFolderPath = string.Empty;
    private FolderType _folderType = FolderType.SendReceive;
    private bool _ignorePerms;
    private bool _autoNormalize = true;
    private string _apiKey = string.Empty;
    private bool _showApiKey;
    private bool _startMinimized;

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
    }

    private async Task LoadSettingsAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            _config = await ApiClient.GetConfigAsync();
            if (_config != null)
            {
                _deviceName = _config.Options?.DeviceName ?? string.Empty;
                _defaultFolderPath = _config.Options?.DefaultFolderPath ?? string.Empty;
                _ignorePerms = _config.Options?.IgnorePerms ?? false;
                _autoNormalize = _config.Options?.AutoNormalizeFilenames ?? true;
                _apiKey = _config.Gui?.ApiKey ?? string.Empty;
                _startMinimized = !(_config.Options?.StartBrowser ?? true);
            }
        }
        catch (Exception ex)
        {
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            Snackbar.Add(L["Msg_LoadFailed", ErrorHelper.GetUserFriendlyMessage(ex)], Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveSettingsAsync()
    {
        if (_config == null) return;

        _isSaving = true;
        StateHasChanged();

        try
        {
            // Update config with new values
            if (_config.Options != null)
            {
                _config.Options.DeviceName = _deviceName;
                _config.Options.DefaultFolderPath = _defaultFolderPath;
                _config.Options.IgnorePerms = _ignorePerms;
                _config.Options.AutoNormalizeFilenames = _autoNormalize;
                _config.Options.StartBrowser = !_startMinimized;
            }

            if (_config.Gui != null)
            {
                _config.Gui.ApiKey = _apiKey;
            }

            await ApiClient.UpdateConfigAsync(_config);
            Snackbar.Add(L["Msg_SaveSuccess"], Severity.Success);
        }
        catch (Exception ex)
        {
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            Snackbar.Add(L["Msg_SaveFailed", ErrorHelper.GetUserFriendlyMessage(ex)], Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task CopyDeviceId()
    {
        if (State.SystemStatus?.MyId == null) return;

        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", State.SystemStatus.MyId);
            Snackbar.Add(L["Settings_General_IdCopied"], Severity.Success);
        }
        catch
        {
            Snackbar.Add(L["Msg_CopyFailed"], Severity.Error);
        }
    }

    private void ToggleApiKeyVisibility()
    {
        _showApiKey = !_showApiKey;
    }

    private void GenerateNewApiKey()
    {
        _apiKey = Guid.NewGuid().ToString("N");
        Snackbar.Add(L["Msg_ApiKeyGenerated"], Severity.Info);
    }

    private async Task ResetToDefaults()
    {
        _deviceName = Environment.MachineName;
        _defaultFolderPath = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.UserProfile), "Sync");
        _folderType = FolderType.SendReceive;
        _ignorePerms = false;
        _autoNormalize = true;
        _startMinimized = false;

        Snackbar.Add(L["Msg_ResetToDefaults"], Severity.Info);
        await Task.CompletedTask;
    }
}
