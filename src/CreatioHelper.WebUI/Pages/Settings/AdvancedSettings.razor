@page "/settings/advanced"
@inject IApiClient ApiClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IStringLocalizer<Localization> L
@inject IErrorMessageHelper ErrorHelper
@inject NavigationManager Navigation

<PageTitle>@L["Settings_Advanced_Title"] - CreatioHelper</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L["Settings_Advanced_Title"]</MudText>

<MudAlert Severity="Severity.Warning" Class="mb-4">
    @L["Settings_Advanced_Warning"]
</MudAlert>

@if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_config != null)
{
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-4">@L["Settings_Advanced_SyncDefaults"]</MudText>

        <MudTextField @bind-Value="_defaultFolderPath"
                      Label="@L["Settings_Advanced_DefaultFolderPath"]"
                      Variant="Variant.Filled"
                      HelperText="@L["Settings_Advanced_DefaultFolderPath_Help"]" />

        <MudDivider Class="my-4" />

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudSwitch @bind-Value="_ignorePerms"
                           Color="Color.Primary"
                           Label="@L["Settings_Advanced_IgnorePermissions"]" />
                <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-2">
                    @L["Settings_Advanced_IgnorePermissions_Help"]
                </MudText>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSwitch @bind-Value="_autoNormalizeFilenames"
                           Color="Color.Primary"
                           Label="@L["Settings_Advanced_AutoNormalizeFilenames"]" />
                <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-2">
                    @L["Settings_Advanced_AutoNormalizeFilenames_Help"]
                </MudText>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-4">@L["Settings_Advanced_FileHandling"]</MudText>

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudNumericField @bind-Value="_hashers"
                                 Label="@L["Settings_Advanced_ConcurrentHashers"]"
                                 Variant="Variant.Filled"
                                 Min="1"
                                 Max="64"
                                 HelperText="@L["Settings_Advanced_ConcurrentHashers_Help"]" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudNumericField @bind-Value="_maxFolderConcurrency"
                                 Label="@L["Settings_Advanced_MaxFolderConcurrency"]"
                                 Variant="Variant.Filled"
                                 Min="1"
                                 Max="64"
                                 HelperText="@L["Settings_Advanced_MaxFolderConcurrency_Help"]" />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />

        <MudSwitch @bind-Value="_setLowPriority"
                   Color="Color.Primary"
                   Label="@L["Settings_Advanced_LowPriority"]" />
        <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-3">
            @L["Settings_Advanced_LowPriority_Help"]
        </MudText>

        <MudSwitch @bind-Value="_progressUpdateIntervalReduced"
                   Color="Color.Primary"
                   Label="@L["Settings_Advanced_ReduceProgressUpdates"]" />
        <MudText Typo="Typo.caption" Color="Color.Default">
            @L["Settings_Advanced_ReduceProgressUpdates_Help"]
        </MudText>
    </MudPaper>

    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-4">@L["Settings_Advanced_Database"]</MudText>

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudNumericField @bind-Value="_databaseTuning"
                                 Label="@L["Settings_Advanced_DatabaseBlockSize"]"
                                 Variant="Variant.Filled"
                                 Min="4096"
                                 Max="131072"
                                 Step="4096" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect @bind-Value="_compressionLevel"
                           Label="@L["Settings_Advanced_CompressionLevel"]"
                           Variant="Variant.Filled">
                    <MudSelectItem Value="@("none")">@L["Settings_Advanced_Compression_None"]</MudSelectItem>
                    <MudSelectItem Value="@("lz4")">@L["Settings_Advanced_Compression_LZ4"]</MudSelectItem>
                    <MudSelectItem Value="@("zstd")">@L["Settings_Advanced_Compression_Zstd"]</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-4">@L["Settings_Advanced_Protocol"]</MudText>

        <MudGrid>
            <MudItem xs="12" md="4">
                <MudNumericField @bind-Value="_pingTimeout"
                                 Label="@L["Settings_Advanced_PingTimeout"]"
                                 Variant="Variant.Filled"
                                 Min="10"
                                 Max="300"
                                 HelperText="@L["Settings_Advanced_PingTimeout_Help"]" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudNumericField @bind-Value="_reconnectionIntervalS"
                                 Label="@L["Settings_Advanced_ReconnectionInterval"]"
                                 Variant="Variant.Filled"
                                 Min="10"
                                 Max="600"
                                 HelperText="@L["Settings_Advanced_ReconnectionInterval_Help"]" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudNumericField @bind-Value="_maxPendingKiB"
                                 Label="@L["Settings_Advanced_MaxPendingData"]"
                                 Variant="Variant.Filled"
                                 Min="1024"
                                 Max="1048576"
                                 HelperText="@L["Settings_Advanced_MaxPendingData_Help"]" />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />

        <MudSwitch @bind-Value="_keepTemporaries"
                   Color="Color.Primary"
                   Label="@L["Settings_Advanced_KeepTempFiles"]" />
        <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-3">
            @L["Settings_Advanced_KeepTempFiles_Help"]
        </MudText>

        <MudSwitch @bind-Value="_copyOwnershipFromParent"
                   Color="Color.Primary"
                   Label="@L["Settings_Advanced_CopyOwnership"]" />
        <MudText Typo="Typo.caption" Color="Color.Default">
            @L["Settings_Advanced_CopyOwnership_Help"]
        </MudText>
    </MudPaper>

    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-4">@L["Settings_General_Startup"]</MudText>

        <MudSwitch @bind-Value="_startBrowser"
                   Color="Color.Primary"
                   Label="@L["Settings_Advanced_OpenBrowserOnStart"]" />
        <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-3">
            @L["Settings_Advanced_OpenBrowserOnStart_Help"]
        </MudText>
    </MudPaper>

    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-4">@L["Settings_Advanced_Debugging"]</MudText>

        <MudSelect @bind-Value="_logLevel"
                   Label="@L["Settings_Advanced_LogLevel"]"
                   Variant="Variant.Filled">
            <MudSelectItem Value="@("error")">@L["Settings_Advanced_LogLevel_Error"]</MudSelectItem>
            <MudSelectItem Value="@("warning")">@L["Settings_Advanced_LogLevel_Warning"]</MudSelectItem>
            <MudSelectItem Value="@("info")">@L["Settings_Advanced_LogLevel_Info"]</MudSelectItem>
            <MudSelectItem Value="@("debug")">@L["Settings_Advanced_LogLevel_Debug"]</MudSelectItem>
            <MudSelectItem Value="@("verbose")">@L["Settings_Advanced_LogLevel_Verbose"]</MudSelectItem>
        </MudSelect>
    </MudPaper>

    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-4">@L["Settings_Advanced_DangerZone"]</MudText>

        <MudAlert Severity="Severity.Error" Class="mb-4">
            @L["Settings_Advanced_DangerZone_Warning"]
        </MudAlert>

        <div class="d-flex flex-wrap gap-3">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Warning"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="ResetDatabase">
                @L["Settings_Advanced_ResetDb"]
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.DeleteForever"
                       OnClick="FactoryReset">
                @L["Settings_Advanced_FactoryReset"]
            </MudButton>
        </div>
    </MudPaper>

    <div class="d-flex justify-end gap-2">
        <MudButton Variant="Variant.Filled" OnClick="ResetToDefaults">
            @L["Common_ResetToDefaults"]
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="SaveSettingsAsync"
                   Disabled="@_isSaving">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @L["Common_SaveChanges"]
        </MudButton>
    </div>
}

@code {
    private bool _isLoading;
    private bool _isSaving;
    private SystemConfig? _config;

    // Sync defaults
    private string _defaultFolderPath = string.Empty;
    private bool _ignorePerms;
    private bool _autoNormalizeFilenames = true;

    // File handling
    private int _hashers = 2;
    private int _maxFolderConcurrency = 4;
    private bool _setLowPriority;
    private bool _progressUpdateIntervalReduced;

    // Database
    private int _databaseTuning = 16384;
    private string _compressionLevel = "lz4";

    // Protocol
    private int _pingTimeout = 90;
    private int _reconnectionIntervalS = 60;
    private int _maxPendingKiB = 131072;
    private bool _keepTemporaries;
    private bool _copyOwnershipFromParent;

    // Startup
    private bool _startBrowser = true;

    // Debugging
    private string _logLevel = "info";

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
    }

    private async Task LoadSettingsAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            _config = await ApiClient.GetConfigAsync();
            if (_config?.Options != null)
            {
                // Sync defaults
                _defaultFolderPath = _config.Options.DefaultFolderPath ?? string.Empty;
                _ignorePerms = _config.Options.IgnorePerms ?? false;
                _autoNormalizeFilenames = _config.Options.AutoNormalizeFilenames ?? true;

                // File handling
                _hashers = _config.Options.Hashers ?? 2;
                _maxFolderConcurrency = _config.Options.MaxFolderConcurrency ?? 4;
                _setLowPriority = _config.Options.SetLowPriority ?? false;
                _progressUpdateIntervalReduced = _config.Options.ProgressUpdateIntervalS > 5;

                // Protocol
                _reconnectionIntervalS = _config.Options.ReconnectionIntervalS ?? 60;

                // Startup
                _startBrowser = _config.Options.StartBrowser ?? true;
            }
        }
        catch (Exception ex)
        {
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            Snackbar.Add(string.Format(L["Msg_LoadSettingsFailed"], ErrorHelper.GetUserFriendlyMessage(ex)), Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveSettingsAsync()
    {
        if (_config == null) return;

        _isSaving = true;
        StateHasChanged();

        try
        {
            if (_config.Options != null)
            {
                // Sync defaults
                _config.Options.DefaultFolderPath = string.IsNullOrWhiteSpace(_defaultFolderPath) ? null : _defaultFolderPath;
                _config.Options.IgnorePerms = _ignorePerms;
                _config.Options.AutoNormalizeFilenames = _autoNormalizeFilenames;

                // File handling
                _config.Options.Hashers = _hashers;
                _config.Options.MaxFolderConcurrency = _maxFolderConcurrency;
                _config.Options.SetLowPriority = _setLowPriority;
                _config.Options.ProgressUpdateIntervalS = _progressUpdateIntervalReduced ? 10 : 2;

                // Protocol
                _config.Options.ReconnectionIntervalS = _reconnectionIntervalS;

                // Startup
                _config.Options.StartBrowser = _startBrowser;
            }

            await ApiClient.UpdateConfigAsync(_config);
            Snackbar.Add(L["Msg_AdvancedSettingsSaved"], Severity.Success);
        }
        catch (Exception ex)
        {
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            Snackbar.Add(string.Format(L["Msg_SaveSettingsFailed"], ErrorHelper.GetUserFriendlyMessage(ex)), Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task ResetDatabase()
    {
        var confirmed = await DialogService.ShowMessageBox(
            L["Settings_Advanced_ResetDb"],
            L["Settings_Advanced_ResetDbConfirm"],
            yesText: L["Common_Reset"],
            cancelText: L["Common_Cancel"]);

        if (confirmed == true)
        {
            try
            {
                await ApiClient.ResetDatabaseAsync();
                Snackbar.Add(L["Msg_DatabaseResetInitiated"], Severity.Warning);
            }
            catch (Exception ex)
            {
                if (ErrorHelper.IsAuthenticationError(ex))
                {
                    Navigation.NavigateTo("/login", forceLoad: true);
                    return;
                }
                Snackbar.Add(string.Format(L["Msg_ResetDatabaseFailed"], ErrorHelper.GetUserFriendlyMessage(ex)), Severity.Error);
            }
        }
    }

    private async Task FactoryReset()
    {
        var confirmed = await DialogService.ShowMessageBox(
            L["Settings_Advanced_FactoryReset"],
            L["Settings_Advanced_FactoryResetConfirm"],
            yesText: L["Settings_Advanced_FactoryResetYes"],
            cancelText: L["Common_Cancel"]);

        if (confirmed == true)
        {
            // Double confirmation for destructive action
            var doubleConfirmed = await DialogService.ShowMessageBox(
                L["Settings_Advanced_FactoryResetConfirmTitle"],
                L["Settings_Advanced_FactoryResetConfirmMessage"],
                yesText: L["Common_Reset"],
                cancelText: L["Common_Cancel"]);

            if (doubleConfirmed == true)
            {
                try
                {
                    await ApiClient.FactoryResetAsync();
                    Snackbar.Add(L["Msg_FactoryResetComplete"], Severity.Warning);
                }
                catch (Exception ex)
                {
                    if (ErrorHelper.IsAuthenticationError(ex))
                    {
                        Navigation.NavigateTo("/login", forceLoad: true);
                        return;
                    }
                    Snackbar.Add(string.Format(L["Msg_FactoryResetFailed"], ErrorHelper.GetUserFriendlyMessage(ex)), Severity.Error);
                }
            }
        }
    }

    private void ResetToDefaults()
    {
        // Sync defaults
        _defaultFolderPath = string.Empty;
        _ignorePerms = false;
        _autoNormalizeFilenames = true;

        // File handling
        _hashers = 2;
        _maxFolderConcurrency = 4;
        _setLowPriority = false;
        _progressUpdateIntervalReduced = false;

        // Database
        _databaseTuning = 16384;
        _compressionLevel = "lz4";

        // Protocol
        _pingTimeout = 90;
        _reconnectionIntervalS = 60;
        _maxPendingKiB = 131072;
        _keepTemporaries = false;
        _copyOwnershipFromParent = false;

        // Startup
        _startBrowser = true;

        // Debugging
        _logLevel = "info";

        Snackbar.Add(L["Msg_SettingsResetToDefaults"], Severity.Info);
    }
}
