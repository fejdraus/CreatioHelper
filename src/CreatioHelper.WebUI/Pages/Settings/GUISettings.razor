@page "/settings/gui"
@inject IThemeService ThemeService
@inject ILocalizationService LocalizationService
@inject ISnackbar Snackbar
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject IStringLocalizer<Localization> L
@inject IErrorMessageHelper ErrorHelper
@inject NavigationManager Navigation

<PageTitle>@L["Settings_GUI"] - CreatioHelper</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L["Settings_GUI"]</MudText>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-4">@L["Settings_Appearance"]</MudText>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.subtitle2" Class="mb-2">@L["Settings_Theme"]</MudText>
            <MudToggleGroup T="string" @bind-Value="_selectedTheme" SelectionMode="SelectionMode.SingleSelection" Color="Color.Primary">
                <MudToggleItem Value="@("light")" UnselectedIcon="@Icons.Material.Filled.LightMode" SelectedIcon="@Icons.Material.Filled.LightMode" Text="@L["Settings_ThemeLight"]" />
                <MudToggleItem Value="@("dark")" UnselectedIcon="@Icons.Material.Filled.DarkMode" SelectedIcon="@Icons.Material.Filled.DarkMode" Text="@L["Settings_ThemeDark"]" />
                <MudToggleItem Value="@("system")" UnselectedIcon="@Icons.Material.Filled.SettingsBrightness" SelectedIcon="@Icons.Material.Filled.SettingsBrightness" Text="@L["Settings_ThemeSystem"]" />
            </MudToggleGroup>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudSelect @bind-Value="_language"
                       Label="@L["Settings_Language"]"
                       Variant="Variant.Outlined">
                <MudSelectItem Value="@("en")">English</MudSelectItem>
                <MudSelectItem Value="@("ru")">Русский</MudSelectItem>
                <MudSelectItem Value="@("de")">Deutsch</MudSelectItem>
                <MudSelectItem Value="@("fr")">Français</MudSelectItem>
                <MudSelectItem Value="@("es")">Español</MudSelectItem>
            </MudSelect>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-4">@L["Nav_Dashboard"]</MudText>

    <MudSwitch @bind-Value="_showTransferChart"
               Color="Color.Primary"
               Label="@L["Settings_ShowTransferChart"]" />
    <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-3">
        @L["Settings_ShowTransferChartHint"]
    </MudText>

    <MudSwitch @bind-Value="_showRecentEvents"
               Color="Color.Primary"
               Label="@L["Settings_ShowRecentEvents"]" />
    <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-3">
        @L["Settings_ShowRecentEventsHint"]
    </MudText>

    <MudNumericField @bind-Value="_maxRecentEvents"
                     Label="@L["Settings_MaxRecentEvents"]"
                     Variant="Variant.Outlined"
                     Min="5"
                     Max="50"
                     Class="mt-3"
                     Style="max-width: 200px;" />
</MudPaper>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-4">@L["Settings_Notifications"]</MudText>

    <MudSwitch @bind-Value="_notifyOnSyncComplete"
               Color="Color.Primary"
               Label="@L["Settings_NotifySyncComplete"]" />
    <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-3">
        @L["Settings_NotifySyncCompleteHint"]
    </MudText>

    <MudSwitch @bind-Value="_notifyOnDeviceConnect"
               Color="Color.Primary"
               Label="@L["Settings_NotifyDeviceConnect"]" />
    <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-3">
        @L["Settings_NotifyDeviceConnectHint"]
    </MudText>

    <MudSwitch @bind-Value="_notifyOnError"
               Color="Color.Primary"
               Label="@L["Settings_NotifyError"]" />
    <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-3">
        @L["Settings_NotifyErrorHint"]
    </MudText>

    <MudSwitch @bind-Value="_notifyOnPendingDevice"
               Color="Color.Primary"
               Label="@L["Settings_NotifyPendingDevice"]" />
    <MudText Typo="Typo.caption" Color="Color.Default">
        @L["Settings_NotifyPendingDeviceHint"]
    </MudText>
</MudPaper>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-4">@L["Settings_DisplayOptions"]</MudText>

    <MudSelect @bind-Value="_dateFormat"
               Label="@L["Settings_DateFormat"]"
               Variant="Variant.Outlined"
               Class="mb-3">
        <MudSelectItem Value="@("short")">@L["Settings_DateShort"] (01/20/26)</MudSelectItem>
        <MudSelectItem Value="@("medium")">@L["Settings_DateMedium"] (Jan 20, 2026)</MudSelectItem>
        <MudSelectItem Value="@("long")">@L["Settings_DateLong"] (January 20, 2026)</MudSelectItem>
        <MudSelectItem Value="@("iso")">ISO (2026-01-20)</MudSelectItem>
    </MudSelect>

    <MudSelect @bind-Value="_sizeFormat"
               Label="@L["Settings_SizeFormat"]"
               Variant="Variant.Outlined">
        <MudSelectItem Value="@("binary")">@L["Settings_SizeBinary"] (KiB, MiB, GiB)</MudSelectItem>
        <MudSelectItem Value="@("decimal")">@L["Settings_SizeDecimal"] (KB, MB, GB)</MudSelectItem>
    </MudSelect>
</MudPaper>

<div class="d-flex justify-end gap-2">
    <MudButton Variant="Variant.Outlined" OnClick="ResetToDefaults">
        @L["Settings_ResetDefaults"]
    </MudButton>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               OnClick="SaveSettingsAsync"
               Disabled="@_isSaving">
        @if (_isSaving)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
        }
        @L["Settings_Save"]
    </MudButton>
</div>

@code {
    private bool _isSaving;
    private string _initialLanguage = "en";

    // Appearance
    private string _selectedTheme = "system";
    private string _language = "en";

    // Dashboard
    private bool _showTransferChart = true;
    private bool _showRecentEvents = true;
    private int _maxRecentEvents = 10;

    // Notifications
    private bool _notifyOnSyncComplete = true;
    private bool _notifyOnDeviceConnect = true;
    private bool _notifyOnError = true;
    private bool _notifyOnPendingDevice = true;

    // Display
    private string _dateFormat = "medium";
    private string _sizeFormat = "binary";

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
    }

    private async Task LoadSettingsAsync()
    {
        _selectedTheme = await LocalStorage.GetItemAsync<string>("gui_theme") ?? "system";
        _language = await LocalStorage.GetItemAsync<string>("gui_language") ?? "en";
        _initialLanguage = _language;
        _showTransferChart = await LocalStorage.GetItemAsync<bool?>("gui_showTransferChart") ?? true;
        _showRecentEvents = await LocalStorage.GetItemAsync<bool?>("gui_showRecentEvents") ?? true;
        _maxRecentEvents = await LocalStorage.GetItemAsync<int?>("gui_maxRecentEvents") ?? 10;
        _notifyOnSyncComplete = await LocalStorage.GetItemAsync<bool?>("gui_notifyOnSyncComplete") ?? true;
        _notifyOnDeviceConnect = await LocalStorage.GetItemAsync<bool?>("gui_notifyOnDeviceConnect") ?? true;
        _notifyOnError = await LocalStorage.GetItemAsync<bool?>("gui_notifyOnError") ?? true;
        _notifyOnPendingDevice = await LocalStorage.GetItemAsync<bool?>("gui_notifyOnPendingDevice") ?? true;
        _dateFormat = await LocalStorage.GetItemAsync<string>("gui_dateFormat") ?? "medium";
        _sizeFormat = await LocalStorage.GetItemAsync<string>("gui_sizeFormat") ?? "binary";
    }

    private async Task SaveSettingsAsync()
    {
        _isSaving = true;
        StateHasChanged();

        try
        {
            await LocalStorage.SetItemAsync("gui_theme", _selectedTheme);
            await LocalStorage.SetItemAsync("gui_language", _language);
            await LocalStorage.SetItemAsync("gui_showTransferChart", _showTransferChart);
            await LocalStorage.SetItemAsync("gui_showRecentEvents", _showRecentEvents);
            await LocalStorage.SetItemAsync("gui_maxRecentEvents", _maxRecentEvents);
            await LocalStorage.SetItemAsync("gui_notifyOnSyncComplete", _notifyOnSyncComplete);
            await LocalStorage.SetItemAsync("gui_notifyOnDeviceConnect", _notifyOnDeviceConnect);
            await LocalStorage.SetItemAsync("gui_notifyOnError", _notifyOnError);
            await LocalStorage.SetItemAsync("gui_notifyOnPendingDevice", _notifyOnPendingDevice);
            await LocalStorage.SetItemAsync("gui_dateFormat", _dateFormat);
            await LocalStorage.SetItemAsync("gui_sizeFormat", _sizeFormat);

            // Apply theme immediately
            switch (_selectedTheme)
            {
                case "dark":
                    await ThemeService.SetDarkModeAsync(true);
                    break;
                case "light":
                    await ThemeService.SetDarkModeAsync(false);
                    break;
                // "system" would need to check system preference
            }

            // Apply language change (requires page reload)
            if (_language != _initialLanguage)
            {
                Snackbar.Add(L["Settings_ApplyingLanguage"], Severity.Info);
                await LocalizationService.SetLanguageAsync(_language);
                // SetLanguageAsync will reload the page, code below won't execute
                return;
            }

            Snackbar.Add(L["Msg_SaveSuccess"], Severity.Success);
        }
        catch (Exception ex)
        {
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            Snackbar.Add($"{L["Msg_SaveFailed", ErrorHelper.GetUserFriendlyMessage(ex)]}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task ResetToDefaults()
    {
        _selectedTheme = "system";
        _language = "en";
        _showTransferChart = true;
        _showRecentEvents = true;
        _maxRecentEvents = 10;
        _notifyOnSyncComplete = true;
        _notifyOnDeviceConnect = true;
        _notifyOnError = true;
        _notifyOnPendingDevice = true;
        _dateFormat = "medium";
        _sizeFormat = "binary";

        Snackbar.Add(L["Settings_ResetToDefaultsHint"], Severity.Info);
        await Task.CompletedTask;
    }
}
