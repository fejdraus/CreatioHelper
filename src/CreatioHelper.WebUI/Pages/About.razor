@page "/about"
@inject IApiClient ApiClient
@inject IStringLocalizer<Localization> L
@inject IErrorMessageHelper ErrorHelper
@inject NavigationManager Navigation

<PageTitle>@L["About_Title"] - CreatioHelper</PageTitle>

<style>
    .logo-container {
        position: relative;
        width: 80px;
        height: 80px;
        margin: 0 auto 24px;
    }

    .logo-ring {
        position: absolute;
        inset: 0;
        border: 2px solid transparent;
        border-top-color: var(--mud-palette-primary);
        border-radius: 50%;
        animation: about-spin 2s linear infinite;
    }

    .logo-ring.ring-2 {
        inset: 8px;
        border-top-color: transparent;
        border-right-color: var(--mud-palette-secondary);
        animation-direction: reverse;
        animation-duration: 1.5s;
    }

    .logo-icon {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    @@keyframes about-spin {
        to { transform: rotate(360deg); }
    }
</style>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex justify-center py-8">
    <MudPaper Elevation="3" Class="pa-8 rounded-xl" Style="width: 100%; max-width: 600px;">

        <MudStack AlignItems="AlignItems.Center" Class="mb-6">
            <div class="logo-container">
                <div class="logo-ring"></div>
                <div class="logo-ring ring-2"></div>
                <div class="logo-icon">
                    <MudIcon Icon="@Icons.Material.Filled.Sync" Size="Size.Large" Color="Color.Primary" />
                </div>
            </div>

            <MudText Typo="Typo.h4" Align="Align.Center">CreatioHelper</MudText>
            <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                @L["About_Subtitle"]
            </MudText>
        </MudStack>

        @if (_isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
        }
        else if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4">@_errorMessage</MudAlert>
        }
        else
        {
            <MudStack Spacing="2" Class="mb-6">
                <MudPaper Elevation="0" Class="pa-3 rounded-lg" Style="background: var(--mud-palette-background-grey);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["About_Version"]</MudText>
                        <MudText Typo="Typo.body2">@(_version ?? "Unknown")</MudText>
                    </MudStack>
                </MudPaper>

                <MudPaper Elevation="0" Class="pa-3 rounded-lg" Style="background: var(--mud-palette-background-grey);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["About_Os"]</MudText>
                        <MudText Typo="Typo.body2">@(_os ?? "Unknown")</MudText>
                    </MudStack>
                </MudPaper>

                <MudPaper Elevation="0" Class="pa-3 rounded-lg" Style="background: var(--mud-palette-background-grey);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["About_Architecture"]</MudText>
                        <MudText Typo="Typo.body2">@(_arch ?? "Unknown")</MudText>
                    </MudStack>
                </MudPaper>
            </MudStack>
        }

        <MudDivider Class="my-4" />

        <MudStack Row="true" Spacing="2" Justify="Justify.Center" Class="mb-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Code"
                       Href="https://github.com/fejdraus/CreatioHelper"
                       Target="_blank">
                GitHub
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.BugReport"
                       Href="https://github.com/fejdraus/CreatioHelper/issues"
                       Target="_blank">
                @L["About_ReportIssue"]
            </MudButton>
        </MudStack>

        <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary" Class="d-block text-center">
            @L["About_LicenseText"]
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    private bool _isLoading = true;
    private string? _version;
    private string? _os;
    private string? _arch;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadSystemInfoAsync();
    }

    private async Task LoadSystemInfoAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var versionInfo = await ApiClient.GetVersionInfoAsync();
            if (versionInfo != null)
            {
                _version = versionInfo.Version;
                _os = versionInfo.Os;
                _arch = versionInfo.Arch;
            }
        }
        catch (HttpRequestException ex)
        {
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            _errorMessage = ErrorHelper.GetUserFriendlyMessage(ex);
        }
        catch (Exception ex)
        {
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            _errorMessage = ErrorHelper.GetUserFriendlyMessage(ex);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
}
