@page "/monitoring/events"
@inject IApiClient ApiClient
@inject ISignalRService SignalR
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IStringLocalizer<Localization> L
@inject IErrorMessageHelper ErrorHelper
@implements IDisposable

<PageTitle>@L["Events_Title"] - CreatioHelper</PageTitle>

<div class="d-flex align-center mb-4">
    <MudText Typo="Typo.h4" Class="flex-grow-1">@L["Events_Title"]</MudText>
    <MudSwitch @bind-Value="_liveUpdates"
               Color="Color.Primary"
               Label="@L["Events_LiveUpdates"]" />
</div>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudSelect T="string"
                       Value="_selectedEventType"
                       ValueChanged="OnEventTypeChanged"
                       Label="@L["Events_FilterByType"]"
                       Variant="Variant.Outlined"
                       Dense="true">
                <MudSelectItem Value="@("all")">@L["Events_AllTypes"]</MudSelectItem>
                <MudSelectItem Value="@("StateChanged")">@L["EventType_StateChanged"]</MudSelectItem>
                <MudSelectItem Value="@("ItemStarted")">@L["EventType_ItemStarted"]</MudSelectItem>
                <MudSelectItem Value="@("ItemFinished")">@L["EventType_ItemFinished"]</MudSelectItem>
                <MudSelectItem Value="@("FolderCompletion")">@L["EventType_FolderCompletion"]</MudSelectItem>
                <MudSelectItem Value="@("DeviceConnected")">@L["EventType_DeviceConnected"]</MudSelectItem>
                <MudSelectItem Value="@("DeviceDisconnected")">@L["EventType_DeviceDisconnected"]</MudSelectItem>
                <MudSelectItem Value="@("FolderErrors")">@L["EventType_FolderErrors"]</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudSelect T="string"
                       Value="_selectedFolder"
                       ValueChanged="OnFolderChanged"
                       Label="@L["Common_Folder"]"
                       Variant="Variant.Outlined"
                       Dense="true">
                <MudSelectItem Value="@("all")">@L["Events_AllFolders"]</MudSelectItem>
                @foreach (var folder in _folders)
                {
                    <MudSelectItem Value="@folder.Id">@folder.DisplayName</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudSelect T="string"
                       Value="_selectedDevice"
                       ValueChanged="OnDeviceChanged"
                       Label="@L["Common_Device"]"
                       Variant="Variant.Outlined"
                       Dense="true">
                <MudSelectItem Value="@("all")">@L["Events_AllDevices"]</MudSelectItem>
                @foreach (var device in _devices)
                {
                    <MudSelectItem Value="@device.DeviceId">@device.DisplayName</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_isLoading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_filteredEvents.Count == 0)
{
    <MudPaper Elevation="2" Class="pa-8 text-center">
        <MudIcon Icon="@Icons.Material.Filled.EventNote"
                 Size="Size.Large"
                 Color="Color.Default"
                 Class="mb-4" />
        <MudText Typo="Typo.h6" Class="mb-2">@L["Events_NoEvents"]</MudText>
        <MudText Color="Color.Default">
            @L["Events_WaitingForEvents"]
        </MudText>
    </MudPaper>
}
else
{
    <MudPaper Elevation="2">
        <MudTable Items="@_filteredEvents"
                  Dense="true"
                  Hover="true"
                  FixedHeader="true"
                  Height="calc(100vh - 350px)">
            <HeaderContent>
                <MudTh Style="width: 160px;">@L["Events_Time"]</MudTh>
                <MudTh Style="width: 140px;">@L["Events_EventType"]</MudTh>
                <MudTh>@L["Events_Data"]</MudTh>
                <MudTh Style="width: 50px;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Time">
                    <MudText Typo="Typo.body2">@context.Timestamp.ToString("HH:mm:ss")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">@context.Timestamp.ToString("yyyy-MM-dd")</MudText>
                </MudTd>
                <MudTd DataLabel="Type">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@GetEventColor(context)"
                             Variant="Variant.Outlined">
                        @GetEventTypeDisplay(context.Type)
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Details">
                    @GetEventDescription(context)
                </MudTd>
                <MudTd>
                    @if (CanNavigate(context))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                       Size="Size.Small"
                                       OnClick="@(() => NavigateToRelated(context))" />
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

    <div class="d-flex justify-center mt-4">
        <MudButton Variant="Variant.Text"
                   OnClick="LoadMoreEvents"
                   Disabled="@(!_hasMore || _isLoadingMore)">
            @if (_isLoadingMore)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @L["Common_LoadMore"]
        </MudButton>
    </div>
}

@code {
    private bool _isLoading;
    private bool _isLoadingMore;
    private bool _liveUpdates = true;
    private bool _hasMore = true;
    private int _lastEventId;

    private string _selectedEventType = "all";
    private string _selectedFolder = "all";
    private string _selectedDevice = "all";

    private List<SyncEvent> _events = new();
    private List<SyncEvent> _filteredEvents = new();
    private FolderConfig[] _folders = [];
    private DeviceConfig[] _devices = [];

    protected override async Task OnInitializedAsync()
    {
        SignalR.OnSyncEvent += OnSyncEvent;
        await LoadInitialData();
    }

    private async Task LoadInitialData()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            _folders = await ApiClient.GetFoldersAsync();
            _devices = await ApiClient.GetDevicesAsync();
            var events = await ApiClient.GetEventsAsync(0, 100);
            _events = events.ToList();
            _lastEventId = _events.LastOrDefault()?.Id ?? 0;
            FilterEvents();
        }
        catch (Exception ex)
        {
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            Snackbar.Add(L["Msg_FailedToLoadEvents", ErrorHelper.GetUserFriendlyMessage(ex)], Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void OnSyncEvent(SyncEvent evt)
    {
        if (!_liveUpdates) return;

        _events.Insert(0, evt);
        if (_events.Count > 1000)
        {
            _events.RemoveRange(1000, _events.Count - 1000);
        }

        FilterEvents();
        InvokeAsync(StateHasChanged);
    }

    private void FilterEvents()
    {
        _filteredEvents = _events.Where(e =>
        {
            if (_selectedEventType != "all" && e.Type.ToString() != _selectedEventType)
                return false;

            if (_selectedFolder != "all" && e.FolderId != _selectedFolder)
                return false;

            if (_selectedDevice != "all" && e.DeviceId != _selectedDevice)
                return false;

            return true;
        }).ToList();
    }

    private void OnEventTypeChanged(string value)
    {
        _selectedEventType = value;
        FilterEvents();
    }

    private void OnFolderChanged(string value)
    {
        _selectedFolder = value;
        FilterEvents();
    }

    private void OnDeviceChanged(string value)
    {
        _selectedDevice = value;
        FilterEvents();
    }

    private async Task LoadMoreEvents()
    {
        _isLoadingMore = true;
        StateHasChanged();

        try
        {
            var moreEvents = await ApiClient.GetEventsAsync(_lastEventId, 100);
            if (moreEvents.Length == 0)
            {
                _hasMore = false;
            }
            else
            {
                _events.AddRange(moreEvents);
                _lastEventId = moreEvents.Last().Id;
                FilterEvents();
            }
        }
        catch (Exception ex)
        {
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            Snackbar.Add(L["Msg_FailedToLoadMoreEvents", ErrorHelper.GetUserFriendlyMessage(ex)], Severity.Error);
        }
        finally
        {
            _isLoadingMore = false;
            StateHasChanged();
        }
    }

    private Color GetEventColor(SyncEvent evt)
    {
        return evt.Type switch
        {
            EventType.FolderCompletion => Color.Success,
            EventType.ItemFinished => Color.Success,
            EventType.DeviceConnected => Color.Info,
            EventType.DeviceDisconnected => Color.Warning,
            EventType.FolderErrors => Color.Error,
            EventType.StateChanged => Color.Default,
            _ => Color.Default
        };
    }

    private string GetEventTypeDisplay(EventType type)
    {
        return type switch
        {
            EventType.StateChanged => L["EventType_State"],
            EventType.ItemStarted => L["EventType_Started"],
            EventType.ItemFinished => L["EventType_Finished"],
            EventType.FolderCompletion => L["EventType_Complete"],
            EventType.DeviceConnected => L["EventType_Connected"],
            EventType.DeviceDisconnected => L["EventType_Disconnected"],
            EventType.FolderErrors => L["EventType_Error"],
            EventType.Unknown => L["EventType_Unknown"],
            EventType.Starting => L["EventType_Starting"],
            EventType.StartupComplete => L["EventType_StartupComplete"],
            EventType.FolderWatchStateChanged => L["EventType_WatchState"],
            EventType.ConfigSaved => L["EventType_ConfigSaved"],
            EventType.DevicePaused => L["EventType_Paused"],
            EventType.DeviceResumed => L["EventType_Resumed"],
            EventType.FolderPaused => L["EventType_Paused"],
            EventType.FolderResumed => L["EventType_Resumed"],
            EventType.LocalChangeDetected => L["EventType_LocalChange"],
            EventType.RemoteChangeDetected => L["EventType_RemoteChange"],
            EventType.DownloadProgress => L["EventType_Downloading"],
            EventType.FolderScanProgress => L["EventType_Scanning"],
            _ => type.ToString()
        };
    }

    private string GetEventDescription(SyncEvent evt)
    {
        var folder = _folders.FirstOrDefault(f => f.Id == evt.FolderId)?.DisplayName ?? evt.FolderId ?? "";
        var device = _devices.FirstOrDefault(d => d.DeviceId == evt.DeviceId)?.DisplayName ?? evt.DeviceId ?? "";

        // Debug: if device/folder is empty but we expect data, show available keys
        var deviceDisplay = !string.IsNullOrEmpty(device) ? device : $"[keys: {evt.DataKeys}]";
        var folderDisplay = !string.IsNullOrEmpty(folder) ? folder : $"[keys: {evt.DataKeys}]";

        return evt.Type switch
        {
            EventType.FolderCompletion => L["EventDesc_FolderCompletion", folderDisplay, deviceDisplay],
            EventType.ItemFinished => L["EventDesc_ItemFinished", evt.FileName ?? "", folderDisplay],
            EventType.ItemStarted => L["EventDesc_ItemStarted", evt.FileName ?? "", folderDisplay],
            EventType.DeviceConnected => L["EventDesc_DeviceConnected", deviceDisplay],
            EventType.DeviceDisconnected => L["EventDesc_DeviceDisconnected", deviceDisplay],
            EventType.FolderErrors => L["EventDesc_FolderErrors", folderDisplay, evt.Error ?? ""],
            EventType.StateChanged => L["EventDesc_StateChanged", evt.From ?? "", evt.To ?? ""],
            EventType.Starting => L["EventDesc_Starting"],
            EventType.StartupComplete => L["EventDesc_StartupComplete"],
            EventType.FolderWatchStateChanged => L["EventDesc_WatchStateChanged", folderDisplay],
            EventType.DevicePaused => L["EventDesc_DevicePaused", deviceDisplay],
            EventType.DeviceResumed => L["EventDesc_DeviceResumed", deviceDisplay],
            EventType.FolderPaused => L["EventDesc_FolderPaused", folderDisplay],
            EventType.FolderResumed => L["EventDesc_FolderResumed", folderDisplay],
            EventType.LocalChangeDetected => L["EventDesc_LocalChange", evt.FileName ?? ""],
            EventType.RemoteChangeDetected => L["EventDesc_RemoteChange", evt.FileName ?? "", deviceDisplay],
            EventType.ConfigSaved => L["EventDesc_ConfigSaved"],
            EventType.Unknown => $"{L["EventDesc_UnknownEvent"]}: {evt.RawType} [keys: {evt.DataKeys}]",
            _ => evt.Message ?? $"{evt.RawType} [keys: {evt.DataKeys}]"
        };
    }

    private bool CanNavigate(SyncEvent evt)
    {
        return !string.IsNullOrEmpty(evt.FolderId) || !string.IsNullOrEmpty(evt.DeviceId);
    }

    private void NavigateToRelated(SyncEvent evt)
    {
        if (!string.IsNullOrEmpty(evt.FolderId))
        {
            Navigation.NavigateTo("/folders");
        }
        else if (!string.IsNullOrEmpty(evt.DeviceId))
        {
            Navigation.NavigateTo($"/devices/{evt.DeviceId}");
        }
    }

    public void Dispose()
    {
        SignalR.OnSyncEvent -= OnSyncEvent;
    }
}
