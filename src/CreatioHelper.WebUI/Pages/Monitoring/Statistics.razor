@page "/monitoring/statistics"
@inject IApiClient ApiClient
@inject ISignalRService SignalR
@inject StateContainer State
@inject ISnackbar Snackbar
@inject IStringLocalizer<Localization> L
@inject IErrorMessageHelper ErrorHelper
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>@L["Statistics_Title"] - CreatioHelper</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L["Statistics_Title"]</MudText>

<MudGrid>
    @* Overview Cards *@
    <MudItem xs="12" md="6" lg="3">
        <MudPaper Elevation="2" Class="pa-4">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Folder" Color="Color.Primary" Size="Size.Large" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Default">@L["Statistics_TotalFolders"]</MudText>
                    <MudText Typo="Typo.h4">@_totalFolders</MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6" lg="3">
        <MudPaper Elevation="2" Class="pa-4">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" Color="Color.Secondary" Size="Size.Large" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Default">@L["Statistics_TotalFiles"]</MudText>
                    <MudText Typo="Typo.h4">@_totalFiles.ToString("N0")</MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6" lg="3">
        <MudPaper Elevation="2" Class="pa-4">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Tertiary" Size="Size.Large" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Default">@L["Statistics_TotalData"]</MudText>
                    <MudText Typo="Typo.h4">@FormatBytes(_totalBytes)</MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6" lg="3">
        <MudPaper Elevation="2" Class="pa-4">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Devices" Color="Color.Info" Size="Size.Large" Class="mr-3" />
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Default">@L["Statistics_ConnectedDevices"]</MudText>
                    <MudText Typo="Typo.h4">@_connectedDevices / @_totalDevices</MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudGrid Class="mt-4">
    @* Transfer Statistics *@
    <MudItem xs="12" md="6">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">@L["Statistics_TransferStats"]</MudText>
            <MudSimpleTable Dense="true" Bordered="true">
                <tbody>
                    <tr>
                        <td>@L["Statistics_TotalDownloaded"]</td>
                        <td class="text-right font-weight-bold">@FormatBytes(_totalDownloaded)</td>
                    </tr>
                    <tr>
                        <td>@L["Statistics_TotalUploaded"]</td>
                        <td class="text-right font-weight-bold">@FormatBytes(_totalUploaded)</td>
                    </tr>
                    <tr>
                        <td>@L["Statistics_CurrentDownloadRate"]</td>
                        <td class="text-right font-weight-bold">@FormatBytes(_downloadRate)/s</td>
                    </tr>
                    <tr>
                        <td>@L["Statistics_CurrentUploadRate"]</td>
                        <td class="text-right font-weight-bold">@FormatBytes(_uploadRate)/s</td>
                    </tr>
                    <tr>
                        <td>@L["Statistics_FilesSynced"]</td>
                        <td class="text-right font-weight-bold">@_filesSynced.ToString("N0")</td>
                    </tr>
                    <tr>
                        <td>@L["Statistics_BytesSynced"]</td>
                        <td class="text-right font-weight-bold">@FormatBytes(_bytesSynced)</td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudItem>

    @* System Statistics *@
    <MudItem xs="12" md="6">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">@L["Statistics_SystemStats"]</MudText>
            <MudSimpleTable Dense="true" Bordered="true">
                <tbody>
                    <tr>
                        <td>@L["Statistics_Uptime"]</td>
                        <td class="text-right font-weight-bold"><UptimeDisplay StartTime="@_systemStartTime" /></td>
                    </tr>
                    <tr>
                        <td>@L["Statistics_MemoryUsage"]</td>
                        <td class="text-right font-weight-bold">@FormatBytes(_memoryUsage)</td>
                    </tr>
                    <tr>
                        <td>@L["Statistics_DatabaseSize"]</td>
                        <td class="text-right font-weight-bold">@FormatBytes(_databaseSize)</td>
                    </tr>
                    <tr>
                        <td>@L["Statistics_GoroutineCount"]</td>
                        <td class="text-right font-weight-bold">@_goroutines</td>
                    </tr>
                    <tr>
                        <td>@L["Statistics_Version"]</td>
                        <td class="text-right font-weight-bold">@_version</td>
                    </tr>
                    <tr>
                        <td>@L["Statistics_Started"]</td>
                        <td class="text-right font-weight-bold">@_startedAt.ToString("g")</td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@* Folder Statistics *@
<MudPaper Elevation="2" Class="pa-4 mt-4">
    <MudText Typo="Typo.h6" Class="mb-4">@L["Statistics_FolderStats"]</MudText>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudTable Items="@_folderStats" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>@L["Statistics_Folder"]</MudTh>
                <MudTh Style="text-align: right;">@L["Statistics_LocalFiles"]</MudTh>
                <MudTh Style="text-align: right;">@L["Statistics_TotalDirs"]</MudTh>
                <MudTh Style="text-align: right;">@L["Statistics_TotalData"]</MudTh>
                <MudTh Style="text-align: right;">@L["Statistics_SyncPercent"]</MudTh>
                <MudTh>@L["Statistics_State"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@L["Statistics_Folder"]">
                    <MudLink Href="/folders">@context.Name</MudLink>
                </MudTd>
                <MudTd DataLabel="@L["Statistics_LocalFiles"]" Style="text-align: right;">@context.Files.ToString("N0")</MudTd>
                <MudTd DataLabel="@L["Statistics_TotalDirs"]" Style="text-align: right;">@context.Directories.ToString("N0")</MudTd>
                <MudTd DataLabel="@L["Statistics_TotalData"]" Style="text-align: right;">@FormatBytes(context.Bytes)</MudTd>
                <MudTd DataLabel="@L["Statistics_SyncPercent"]" Style="text-align: right;">
                    <div class="d-flex align-center justify-end">
                        <MudProgressLinear Value="@context.SyncPercent"
                                           Color="@(context.SyncPercent >= 100 ? Color.Success : Color.Primary)"
                                           Style="width: 60px; margin-right: 8px;" />
                        <span>@context.SyncPercent.ToString("F0")%</span>
                    </div>
                </MudTd>
                <MudTd DataLabel="@L["Statistics_State"]">
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@GetStatusColor(context.State)"
                             Variant="Variant.Outlined">
                        @GetLocalizedState(context.State)
                    </MudChip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@* Device Statistics *@
<MudPaper Elevation="2" Class="pa-4 mt-4">
    <MudText Typo="Typo.h6" Class="mb-4">@L["Statistics_DeviceStats"]</MudText>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudTable Items="@_deviceStats" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>@L["Statistics_Device"]</MudTh>
                <MudTh Style="text-align: right;">@L["Statistics_BytesRecv"]</MudTh>
                <MudTh Style="text-align: right;">@L["Statistics_BytesSent"]</MudTh>
                <MudTh Style="text-align: right;">@L["Statistics_LastSeen"]</MudTh>
                <MudTh>@L["Statistics_Status"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@L["Statistics_Device"]">
                    <MudLink Href="@($"/devices/{context.DeviceId}")">@context.Name</MudLink>
                </MudTd>
                <MudTd DataLabel="@L["Statistics_BytesRecv"]" Style="text-align: right;">@FormatBytes(context.Downloaded)</MudTd>
                <MudTd DataLabel="@L["Statistics_BytesSent"]" Style="text-align: right;">@FormatBytes(context.Uploaded)</MudTd>
                <MudTd DataLabel="@L["Statistics_LastSeen"]" Style="text-align: right;">
                    @if (context.LastSeen.HasValue)
                    {
                        <MudTooltip Text="@context.LastSeen.Value.ToString("g")">
                            @FormatTimeAgo(context.LastSeen.Value)
                        </MudTooltip>
                    }
                    else
                    {
                        <span>@L["Statistics_Never"]</span>
                    }
                </MudTd>
                <MudTd DataLabel="@L["Statistics_Status"]">
                    @if (context.Connected)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">@L["Statistics_Connected"]</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@L["Statistics_Disconnected"]</MudChip>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudPaper>

@code {
    private bool _isLoading;
    private bool _initialLoadComplete;

    // Overview
    private int _totalFolders;
    private long _totalFiles;
    private long _totalBytes;
    private int _totalDevices;
    private int _connectedDevices;

    // Transfer stats
    private long _totalDownloaded;
    private long _totalUploaded;
    private long _downloadRate;
    private long _uploadRate;
    private long _filesSynced = 0;
    private long _bytesSynced = 0;

    // System stats
    private DateTime? _systemStartTime;
    private long _memoryUsage;
    private long _databaseSize = 0;
    private int _goroutines;
    private string _version = "...";
    private DateTime _startedAt = DateTime.UtcNow;

    private List<FolderStat> _folderStats = new();
    private List<DeviceStat> _deviceStats = new();

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += OnStateChanged;

        // Subscribe to SignalR events for real-time updates
        SignalR.OnSystemStatusChanged += OnSystemStatusChanged;
        SignalR.OnFolderStatusChanged += OnFolderStatusChanged;
        SignalR.OnConnectionChanged += OnConnectionChanged;
        SignalR.OnSyncEvent += OnSyncEvent;

        // Initial load only - subsequent updates come from SignalR events
        await RefreshStatistics();
    }

    private void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnSystemStatusChanged(SystemStatus status)
    {
        // Update system stats - only override with non-null values
        if (status.StartTime.HasValue) _systemStartTime = status.StartTime;
        if (status.Sys.HasValue) _memoryUsage = status.Sys.Value;
        if (status.Goroutines.HasValue) _goroutines = status.Goroutines.Value;
        if (status.DbSize is > 0) _databaseSize = status.DbSize.Value;
        InvokeAsync(StateHasChanged);
    }

    private void OnFolderStatusChanged(FolderStatus status)
    {
        // Update folder stat if exists
        var folderStat = _folderStats.FirstOrDefault(f => f.Id == status.Folder);
        if (folderStat != null)
        {
            // Only update with non-zero values to avoid overwriting good data
            if (status.GlobalFiles > 0) folderStat.Files = status.GlobalFiles;
            if (status.GlobalDirectories > 0) folderStat.Directories = status.GlobalDirectories;
            if (status.GlobalBytes > 0) folderStat.Bytes = status.GlobalBytes;
            folderStat.SyncPercent = status.SyncPercentage;
            if (!string.IsNullOrEmpty(status.State)) folderStat.State = status.State;
        }
        else if (!string.IsNullOrEmpty(status.Folder))
        {
            // Add new folder
            _folderStats.Add(new FolderStat
            {
                Id = status.Folder,
                Name = status.Folder,
                Files = status.GlobalFiles,
                Directories = status.GlobalDirectories,
                Bytes = status.GlobalBytes,
                SyncPercent = status.SyncPercentage,
                State = status.State
            });
        }

        // Recalculate totals
        _totalFolders = _folderStats.Count;
        _totalFiles = _folderStats.Sum(f => f.Files);
        _totalBytes = _folderStats.Sum(f => f.Bytes);

        InvokeAsync(StateHasChanged);
    }

    private void OnConnectionChanged(ConnectionInfo info)
    {
        // Update device stat if exists
        var deviceStat = _deviceStats.FirstOrDefault(d => d.DeviceId == info.DeviceId);
        if (deviceStat != null)
        {
            deviceStat.Connected = info.Connected;
            deviceStat.Downloaded = info.InBytesTotal;
            deviceStat.Uploaded = info.OutBytesTotal;
        }
        else
        {
            // Add new device
            _deviceStats.Add(new DeviceStat
            {
                DeviceId = info.DeviceId,
                Name = info.DeviceId.Length > 7 ? info.DeviceId[..7] + "..." : info.DeviceId,
                Connected = info.Connected,
                Downloaded = info.InBytesTotal,
                Uploaded = info.OutBytesTotal
            });
        }

        // Recalculate all connection stats
        _totalDevices = _deviceStats.Count;
        _connectedDevices = _deviceStats.Count(d => d.Connected);
        _totalDownloaded = _deviceStats.Sum(d => d.Downloaded);
        _totalUploaded = _deviceStats.Sum(d => d.Uploaded);
        _downloadRate = info.InBytesPerSec;
        _uploadRate = info.OutBytesPerSec;

        InvokeAsync(StateHasChanged);
    }

    private void OnSyncEvent(SyncEvent evt)
    {
        // Update synced stats on item finished
        if (evt.Type == EventType.ItemFinished)
        {
            _filesSynced++;
            InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshStatistics()
    {
        // Only run on initial load - SignalR handles all updates after that
        if (_initialLoadComplete)
        {
            return;
        }

        _isLoading = true;
        StateHasChanged();

        try
        {
            var status = await ApiClient.GetSystemStatusAsync();
            var folders = await ApiClient.GetFoldersAsync();
            var devices = await ApiClient.GetDevicesAsync();
            var connections = await ApiClient.GetConnectionsAsync();

            var myId = status?.MyId;

            // Overview
            _totalFolders = folders.Length;
            _totalDevices = devices.Count(d => d.DeviceId != myId);
            _connectedDevices = connections.Count(c => c.Connected);

            // System stats
            _systemStartTime = status?.StartTime;
            _memoryUsage = status?.Sys ?? 0;
            _goroutines = status?.Goroutines ?? 0;
            if (status?.DbSize is > 0)
                _databaseSize = status.DbSize.Value;

            // Folder stats - update in place to avoid flickering
            var newFolderStats = new List<FolderStat>();
            _totalFiles = 0;
            _totalBytes = 0;

            foreach (var folder in folders)
            {
                var folderStatus = await ApiClient.GetFolderStatusAsync(folder.Id);
                if (folderStatus != null)
                {
                    _totalFiles += folderStatus.GlobalFiles;
                    _totalBytes += folderStatus.GlobalBytes;

                    newFolderStats.Add(new FolderStat
                    {
                        Id = folder.Id,
                        Name = folder.DisplayName,
                        Files = folderStatus.GlobalFiles,
                        Directories = folderStatus.GlobalDirectories,
                        Bytes = folderStatus.GlobalBytes,
                        SyncPercent = folderStatus.SyncPercentage,
                        State = folderStatus.State
                    });
                }
            }
            _folderStats = newFolderStats;

            // Device stats - update in place to avoid flickering
            var newDeviceStats = new List<DeviceStat>();
            _totalDownloaded = 0;
            _totalUploaded = 0;
            _downloadRate = 0;
            _uploadRate = 0;

            foreach (var device in devices.Where(d => d.DeviceId != myId))
            {
                var conn = connections.FirstOrDefault(c => c.DeviceId == device.DeviceId);
                var stats = await ApiClient.GetDeviceStatsAsync(device.DeviceId);

                _totalDownloaded += conn?.InBytesTotal ?? 0;
                _totalUploaded += conn?.OutBytesTotal ?? 0;
                _downloadRate += conn?.InBytesPerSec ?? 0;
                _uploadRate += conn?.OutBytesPerSec ?? 0;

                newDeviceStats.Add(new DeviceStat
                {
                    DeviceId = device.DeviceId,
                    Name = device.DisplayName,
                    Downloaded = conn?.InBytesTotal ?? 0,
                    Uploaded = conn?.OutBytesTotal ?? 0,
                    LastSeen = stats?.LastSeen,
                    Connected = conn?.Connected ?? false
                });
            }
            _deviceStats = newDeviceStats;

            // B1: Fetch real version
            var ver = await ApiClient.GetVersionAsync();
            if (!string.IsNullOrEmpty(ver)) _version = ver;

            // B2: Calculate bytesSynced
            _bytesSynced = _totalDownloaded + _totalUploaded;

            _initialLoadComplete = true;
        }
        catch (Exception ex)
        {
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            Snackbar.Add(L["Msg_FailedToRefreshStatistics", ErrorHelper.GetUserFriendlyMessage(ex)], Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        if (bytes < 1024L * 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024 * 1024):F2} GB";
        return $"{bytes / (1024.0 * 1024 * 1024 * 1024):F2} TB";
    }

    private string FormatTimeAgo(DateTime time)
    {
        var diff = DateTime.UtcNow - time;
        if (diff.TotalSeconds < 60) return L["Time_JustNow"];
        if (diff.TotalMinutes < 60) return L["Time_MinutesAgo", (int)diff.TotalMinutes];
        if (diff.TotalHours < 24) return L["Time_HoursAgo", (int)diff.TotalHours];
        if (diff.TotalDays < 7) return L["Time_DaysAgo", (int)diff.TotalDays];
        return time.ToString("MMM d");
    }

    private Color GetStatusColor(string state)
    {
        return state.ToLower() switch
        {
            "idle" => Color.Success,
            "syncing" => Color.Info,
            "scanning" => Color.Info,
            "error" => Color.Error,
            _ => Color.Default
        };
    }

    private string GetLocalizedState(string state)
    {
        return state.ToLower() switch
        {
            "idle" => L["FolderState_Idle"],
            "syncing" => L["FolderState_Syncing"],
            "scanning" => L["FolderState_Scanning"],
            "error" => L["FolderState_Error"],
            _ => L["FolderState_Unknown"]
        };
    }

    public void Dispose()
    {
        State.OnChange -= OnStateChanged;
        SignalR.OnSystemStatusChanged -= OnSystemStatusChanged;
        SignalR.OnFolderStatusChanged -= OnFolderStatusChanged;
        SignalR.OnConnectionChanged -= OnConnectionChanged;
        SignalR.OnSyncEvent -= OnSyncEvent;
    }
}

@code {
    private class FolderStat
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public long Files { get; set; }
        public long Directories { get; set; }
        public long Bytes { get; set; }
        public double SyncPercent { get; set; }
        public string State { get; set; } = string.Empty;
    }

    private class DeviceStat
    {
        public string DeviceId { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public long Downloaded { get; set; }
        public long Uploaded { get; set; }
        public DateTime? LastSeen { get; set; }
        public bool Connected { get; set; }
    }
}
