@* Sync Status Indicator Chip *@
@inject IStringLocalizer<Localization> L

<MudTooltip Text="@GetTooltip()">
    <MudChip T="string"
             Color="@GetColor()"
             Size="Size.Small"
             Icon="@GetIcon()"
             Variant="Variant.Filled">
        @GetLabel()
    </MudChip>
</MudTooltip>

@code {
    [Parameter]
    public string Status { get; set; } = "idle";

    private Color GetColor() => Status switch
    {
        "idle" => Color.Success,
        "syncing" or "scanning" => Color.Info,
        "error" => Color.Error,
        "paused" => Color.Warning,
        _ => Color.Default
    };

    private string GetIcon() => Status switch
    {
        "idle" => Icons.Material.Filled.CheckCircle,
        "syncing" => Icons.Material.Filled.Sync,
        "scanning" => Icons.Material.Filled.Search,
        "error" => Icons.Material.Filled.Error,
        "paused" => Icons.Material.Filled.Pause,
        _ => Icons.Material.Filled.HelpOutline
    };

    private string GetLabel() => Status switch
    {
        "idle" => L["Status_UpToDate"],
        "syncing" => L["Status_Syncing"],
        "scanning" => L["Status_Scanning"],
        "error" => L["Status_Error"],
        "paused" => L["Status_Paused"],
        _ => L["Status_Unknown"]
    };

    private string GetTooltip() => Status switch
    {
        "idle" => L["Status_AllFoldersSynced"],
        "syncing" => L["Status_SyncingFiles"],
        "scanning" => L["Status_ScanningFolders"],
        "error" => L["Status_FoldersHaveErrors"],
        "paused" => L["Status_SyncPaused"],
        _ => L["Status_StatusUnknown"]
    };
}
