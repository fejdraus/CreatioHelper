@inject IApiClient ApiClient
@inject ISnackbar Snackbar
@inject StateContainer State
@inject IStringLocalizer<Localization> L
@inject IErrorMessageHelper ErrorHelper
@inject NavigationManager Navigation

<MudDialog Style="max-height: 90vh;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(IsEditMode ? Icons.Material.Filled.Edit : Icons.Material.Filled.CreateNewFolder)" Class="mr-2" />
            @(IsEditMode ? L["FolderDialog_EditFolder"] : L["FolderDialog_AddFolder"])
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true">
            @* ===== GENERAL TAB ===== *@
            <MudTabPanel Text="@L["FolderDialog_TabGeneral"]" Icon="@Icons.Material.Filled.Info" Class="pa-4">
                <MudForm @ref="_form" @bind-IsValid="@_isValid">
                    <MudTextField @bind-Value="_folderId"
                                  Label="@L["FolderDialog_FolderId"]"
                                  HelperText="@(IsEditMode ? L["FolderDialog_FolderIdHintEdit"] : L["FolderDialog_FolderIdHint"])"
                                  Required="true"
                                  RequiredError="@L["FolderDialog_FolderIdRequired"]"
                                  Immediate="true"
                                  ReadOnly="@IsEditMode"
                                  Validation="@(new Func<string, string?>(ValidateFolderId))"
                                  Class="mb-4" />

                    <MudTextField @bind-Value="_label"
                                  Label="@L["FolderDialog_FolderLabel"]"
                                  HelperText="@L["FolderDialog_FolderLabelHint"]"
                                  Class="mb-4" />

                    <MudTextField @bind-Value="_path"
                                  Label="@L["FolderDialog_FolderPath"]"
                                  HelperText="@L["FolderDialog_FolderPathHint"]"
                                  Required="true"
                                  RequiredError="@L["FolderDialog_FolderPathRequired"]"
                                  Immediate="true"
                                  Class="mb-4" />
                </MudForm>
            </MudTabPanel>

            @* ===== SHARING TAB ===== *@
            <MudTabPanel Text="@L["FolderDialog_TabSharing"]" Icon="@Icons.Material.Filled.Share" Class="pa-4">
                <MudText Typo="Typo.body2" Class="mb-4">
                    @L["FolderDialog_SelectDevices"]
                </MudText>

                @if (State.Devices.Length == 0)
                {
                    <MudAlert Severity="Severity.Info">
                        @L["FolderDialog_NoDevices"]
                    </MudAlert>
                }
                else
                {
                    <MudList T="string" Dense="true">
                        @foreach (var device in State.Devices.Where(d => d.DeviceId != State.MyDeviceId))
                        {
                            <MudListItem>
                                <MudCheckBox T="bool"
                                             Value="@_selectedDevices.Contains(device.DeviceId)"
                                             ValueChanged="@(v => ToggleDevice(device.DeviceId, v))"
                                             Label="@device.DisplayName"
                                             Color="Color.Primary" />
                            </MudListItem>
                        }
                    </MudList>
                }
            </MudTabPanel>

            @* ===== FILE VERSIONING TAB ===== *@
            <MudTabPanel Text="@L["FolderDialog_TabVersioning"]" Icon="@Icons.Material.Filled.History" Class="pa-4">
                <MudSelect @bind-Value="_versioningType"
                           Label="@L["FolderDialog_VersioningType"]"
                           HelperText="@L["FolderDialog_VersioningTypeHint"]"
                           Class="mb-4">
                    <MudSelectItem Value="@("none")">@L["FolderDialog_VersioningNone"]</MudSelectItem>
                    <MudSelectItem Value="@("trashcan")">@L["FolderDialog_VersioningTrashcan"]</MudSelectItem>
                    <MudSelectItem Value="@("simple")">@L["FolderDialog_VersioningSimple"]</MudSelectItem>
                    <MudSelectItem Value="@("staggered")">@L["FolderDialog_VersioningStaggered"]</MudSelectItem>
                    <MudSelectItem Value="@("external")">@L["FolderDialog_VersioningExternal"]</MudSelectItem>
                </MudSelect>

                @if (_versioningType != "none")
                {
                    <MudTextField @bind-Value="_versioningPath"
                                  Label="@L["FolderDialog_VersionsPath"]"
                                  HelperText="@L["FolderDialog_VersionsPathHint"]"
                                  Class="mb-4" />

                    <MudNumericField @bind-Value="_cleanupIntervalS"
                                     Label="@L["FolderDialog_CleanupInterval"]"
                                     HelperText="@L["FolderDialog_CleanupIntervalHint"]"
                                     Min="0"
                                     Class="mb-4" />
                }

                @if (_versioningType == "trashcan")
                {
                    <MudNumericField @bind-Value="_cleanoutDays"
                                     Label="@L["FolderDialog_CleanOutAfter"]"
                                     HelperText="@L["FolderDialog_CleanOutAfterHint"]"
                                     Min="0"
                                     Class="mb-4" />
                }
                else if (_versioningType == "simple")
                {
                    <MudNumericField @bind-Value="_keepVersions"
                                     Label="@L["FolderDialog_KeepVersions"]"
                                     HelperText="@L["FolderDialog_KeepVersionsHint"]"
                                     Min="1"
                                     Class="mb-4" />

                    <MudNumericField @bind-Value="_cleanoutDays"
                                     Label="@L["FolderDialog_CleanOutAfter"]"
                                     HelperText="@L["FolderDialog_CleanOutAfterHintSimple"]"
                                     Min="0"
                                     Class="mb-4" />
                }
                else if (_versioningType == "staggered")
                {
                    <MudNumericField @bind-Value="_maxAgeDays"
                                     Label="@L["FolderDialog_MaxAge"]"
                                     HelperText="@L["FolderDialog_MaxAgeHint"]"
                                     Min="0"
                                     Class="mb-4" />
                }
                else if (_versioningType == "external")
                {
                    <MudTextField @bind-Value="_externalCommand"
                                  Label="@L["FolderDialog_Command"]"
                                  HelperText="@L["FolderDialog_CommandHint"]"
                                  Class="mb-4" />
                }
            </MudTabPanel>

            @* ===== ADVANCED TAB ===== *@
            <MudTabPanel Text="@L["FolderDialog_TabAdvanced"]" Icon="@Icons.Material.Filled.Settings" Class="pa-4">
                @* Folder Type *@
                <MudText Typo="Typo.subtitle2" Class="mb-2">@L["FolderDialog_FolderType"]</MudText>
                <MudSelect @bind-Value="_folderType"
                           Label="@L["FolderDialog_FolderType"]"
                           HelperText="@L["FolderDialog_FolderTypeHint"]"
                           Class="mb-4">
                    <MudSelectItem Value="@("sendreceive")">@L["FolderDialog_TypeSendReceive"]</MudSelectItem>
                    <MudSelectItem Value="@("sendonly")">@L["FolderDialog_TypeSendOnly"]</MudSelectItem>
                    <MudSelectItem Value="@("receiveonly")">@L["FolderDialog_TypeReceiveOnly"]</MudSelectItem>
                    <MudSelectItem Value="@("receiveencrypted")">@L["FolderDialog_TypeReceiveEncrypted"]</MudSelectItem>
                </MudSelect>

                <MudSelect @bind-Value="_pullOrder"
                           Label="@L["FolderDialog_PullOrder"]"
                           HelperText="@L["FolderDialog_PullOrderHint"]"
                           Disabled="@(_folderType == "sendonly")"
                           Class="mb-4">
                    <MudSelectItem Value="@("random")">@L["FolderDialog_OrderRandom"]</MudSelectItem>
                    <MudSelectItem Value="@("alphabetic")">@L["FolderDialog_OrderAlphabetic"]</MudSelectItem>
                    <MudSelectItem Value="@("smallestFirst")">@L["FolderDialog_OrderSmallestFirst"]</MudSelectItem>
                    <MudSelectItem Value="@("largestFirst")">@L["FolderDialog_OrderLargestFirst"]</MudSelectItem>
                    <MudSelectItem Value="@("oldestFirst")">@L["FolderDialog_OrderOldestFirst"]</MudSelectItem>
                    <MudSelectItem Value="@("newestFirst")">@L["FolderDialog_OrderNewestFirst"]</MudSelectItem>
                </MudSelect>

                <MudDivider Class="my-4" />

                @* Scanning *@
                <MudText Typo="Typo.subtitle2" Class="mb-2">@L["FolderDialog_Scanning"]</MudText>

                <MudSwitch @bind-Value="_fsWatcherEnabled"
                           Label="@L["FolderDialog_WatchForChanges"]"
                           Color="Color.Primary"
                           Class="mb-2" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
                    @L["FolderDialog_WatchForChangesHint"]
                </MudText>

                @if (_fsWatcherEnabled)
                {
                    <MudNumericField @bind-Value="_fsWatcherDelayS"
                                     Label="@L["FolderDialog_FsWatcherDelay"]"
                                     HelperText="@L["FolderDialog_FsWatcherDelayHint"]"
                                     Min="0.01"
                                     Step="0.1"
                                     Class="mb-4" />
                }

                <MudNumericField @bind-Value="_rescanIntervalS"
                                 Label="@L["FolderDialog_RescanInterval"]"
                                 HelperText="@L["FolderDialog_RescanIntervalHint"]"
                                 Min="0"
                                 Class="mb-4" />

                <MudDivider Class="my-4" />

                @* Disk & Permissions *@
                <MudText Typo="Typo.subtitle2" Class="mb-2">@L["FolderDialog_DiskPermissions"]</MudText>

                <MudGrid>
                    <MudItem xs="8">
                        <MudNumericField @bind-Value="_minDiskFreeValue"
                                         Label="@L["FolderDialog_MinDiskFree"]"
                                         Min="0"
                                         Class="mb-4" />
                    </MudItem>
                    <MudItem xs="4">
                        <MudSelect @bind-Value="_minDiskFreeUnit" Label="@L["FolderDialog_Unit"]" Class="mb-4">
                            <MudSelectItem Value="@("%")">%</MudSelectItem>
                            <MudSelectItem Value="@("kB")">kB</MudSelectItem>
                            <MudSelectItem Value="@("MB")">MB</MudSelectItem>
                            <MudSelectItem Value="@("GB")">GB</MudSelectItem>
                            <MudSelectItem Value="@("TB")">TB</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>

                <MudSwitch @bind-Value="_ignorePerms"
                           Label="@L["FolderDialog_IgnorePermissions"]"
                           Color="Color.Primary"
                           Disabled="@(_folderType == "receiveencrypted")"
                           Class="mb-2" />

                <MudSwitch @bind-Value="_ignoreDelete"
                           Label="@L["FolderDialog_IgnoreDeletes"]"
                           Color="Color.Primary"
                           Class="mb-2" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
                    @L["FolderDialog_IgnoreDeletesHint"]
                </MudText>

                <MudDivider Class="my-4" />

                @* Other Options *@
                <MudText Typo="Typo.subtitle2" Class="mb-2">@L["FolderDialog_OtherOptions"]</MudText>

                <MudSwitch @bind-Value="_autoNormalize"
                           Label="@L["FolderDialog_AutoNormalize"]"
                           Color="Color.Primary"
                           Class="mb-2" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
                    @L["FolderDialog_AutoNormalizeHint"]
                </MudText>

                <MudNumericField @bind-Value="_maxConflicts"
                                 Label="@L["FolderDialog_MaxConflicts"]"
                                 HelperText="@L["FolderDialog_MaxConflictsHint"]"
                                 Min="-1"
                                 Class="mb-4" />

                <MudNumericField @bind-Value="_maxConcurrentWrites"
                                 Label="@L["FolderDialog_MaxConcurrentWrites"]"
                                 HelperText="@L["FolderDialog_MaxConcurrentWritesHint"]"
                                 Min="1"
                                 Max="256"
                                 Class="mb-4" />

                <MudSwitch @bind-Value="_caseSensitiveFS"
                           Label="@L["FolderDialog_CaseSensitiveFS"]"
                           Color="Color.Primary"
                           Class="mb-2" />

                <MudSwitch @bind-Value="_junctionsAsDirs"
                           Label="@L["FolderDialog_JunctionsAsDirs"]"
                           Color="Color.Primary"
                           Class="mb-2" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
                    @L["FolderDialog_JunctionsAsDirsHint"]
                </MudText>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["FolderDialog_Cancel"]</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(!_isValid || _isSubmitting)">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @(IsEditMode ? L["FolderDialog_Save"] : L["FolderDialog_AddFolderButton"])
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>
    /// Existing folder for edit mode. If null, dialog is in add mode.
    /// </summary>
    [Parameter]
    public FolderConfig? Folder { get; set; }

    private bool IsEditMode => Folder != null;

    private MudForm _form = null!;
    private bool _isValid;
    private bool _isSubmitting;

    // General
    private string _folderId = string.Empty;
    private string _label = string.Empty;
    private string _path = string.Empty;

    // Sharing
    private HashSet<string> _selectedDevices = new();

    // File Versioning
    private string _versioningType = "none";
    private string _versioningPath = string.Empty;
    private int _cleanupIntervalS = 3600;
    private int _cleanoutDays = 0;
    private int _keepVersions = 5;
    private int _maxAgeDays = 365;
    private string _externalCommand = string.Empty;

    // Advanced - Folder Type
    private string _folderType = "sendreceive";
    private string _pullOrder = "random";

    // Advanced - Scanning
    private bool _fsWatcherEnabled = true;
    private double _fsWatcherDelayS = 10;
    private int _rescanIntervalS = 3600;

    // Advanced - Disk & Permissions
    private double _minDiskFreeValue = 1;
    private string _minDiskFreeUnit = "%";
    private bool _ignorePerms = false;
    private bool _ignoreDelete = false;

    // Advanced - Other
    private bool _autoNormalize = true;
    private int _maxConflicts = 10;
    private int _maxConcurrentWrites = 16;
    private bool _caseSensitiveFS = false;
    private bool _junctionsAsDirs = false;

    protected override void OnInitialized()
    {
        if (IsEditMode)
        {
            LoadFromFolder(Folder!);
        }
        else
        {
            _folderId = GenerateFolderId();
        }
    }

    private void LoadFromFolder(FolderConfig folder)
    {
        // General
        _folderId = folder.Id;
        _label = folder.Label ?? string.Empty;
        _path = folder.Path;

        // Sharing
        _selectedDevices = folder.Devices?.Select(d => d.DeviceId).ToHashSet() ?? new();

        // Folder Type
        _folderType = folder.Type ?? "sendreceive";
        _pullOrder = folder.Order ?? "random";

        // Scanning
        _fsWatcherEnabled = folder.FsWatcherEnabled;
        _fsWatcherDelayS = folder.FsWatcherDelayS;
        _rescanIntervalS = folder.RescanIntervalS;

        // Disk & Permissions
        _minDiskFreeValue = folder.MinDiskFree?.Value ?? 1;
        _minDiskFreeUnit = folder.MinDiskFree?.Unit ?? "%";
        _ignorePerms = folder.IgnorePerms;
        _ignoreDelete = folder.IgnoreDelete;

        // Other
        _autoNormalize = folder.AutoNormalize;
        _maxConflicts = folder.MaxConflicts;
        _maxConcurrentWrites = folder.MaxConcurrentWrites;
        _caseSensitiveFS = folder.CaseSensitiveFs;
        _junctionsAsDirs = folder.JunctionsAsDirs;

        // Versioning
        if (folder.Versioning != null && !string.IsNullOrEmpty(folder.Versioning.Type))
        {
            _versioningType = folder.Versioning.Type;
            var p = folder.Versioning.Params;
            if (p != null)
            {
                if (p.TryGetValue("cleanoutDays", out var cleanoutDays))
                    int.TryParse(cleanoutDays, out _cleanoutDays);
                if (p.TryGetValue("keep", out var keep))
                    int.TryParse(keep, out _keepVersions);
                if (p.TryGetValue("maxAge", out var maxAge) && int.TryParse(maxAge, out var maxAgeSec))
                    _maxAgeDays = maxAgeSec / 86400;
                if (p.TryGetValue("command", out var command))
                    _externalCommand = command;
                if (p.TryGetValue("fsPath", out var fsPath))
                    _versioningPath = fsPath;
            }
        }
    }

    private static string GenerateFolderId()
    {
        const string chars = "abcdefghijklmnopqrstuvwxyz0123456789";
        var random = new Random();
        var part1 = new string(Enumerable.Range(0, 5).Select(_ => chars[random.Next(chars.Length)]).ToArray());
        var part2 = new string(Enumerable.Range(0, 5).Select(_ => chars[random.Next(chars.Length)]).ToArray());
        return $"{part1}-{part2}";
    }

    private string? ValidateFolderId(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return L["FolderDialog_FolderIdRequired"];

        if (value.Contains(' '))
            return L["FolderDialog_FolderIdNoSpaces"];

        if (!System.Text.RegularExpressions.Regex.IsMatch(value, @"^[a-zA-Z0-9_\-\.]+$"))
            return L["FolderDialog_FolderIdInvalidChars"];

        return null;
    }

    private void ToggleDevice(string deviceId, bool selected)
    {
        if (selected)
            _selectedDevices.Add(deviceId);
        else
            _selectedDevices.Remove(deviceId);
    }

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        _isSubmitting = true;
        StateHasChanged();

        try
        {
            var folder = new FolderConfig
            {
                Id = _folderId,
                Label = _label,
                Path = _path,
                Type = _folderType,
                Order = _pullOrder,
                RescanIntervalS = _rescanIntervalS,
                FsWatcherEnabled = _fsWatcherEnabled,
                FsWatcherDelayS = _fsWatcherDelayS,
                IgnorePerms = _ignorePerms,
                IgnoreDelete = _ignoreDelete,
                AutoNormalize = _autoNormalize,
                MaxConflicts = _maxConflicts,
                MaxConcurrentWrites = _maxConcurrentWrites,
                CaseSensitiveFs = _caseSensitiveFS,
                JunctionsAsDirs = _junctionsAsDirs,
                MinDiskFree = new MinDiskFree
                {
                    Value = _minDiskFreeValue,
                    Unit = _minDiskFreeUnit
                },
                Devices = _selectedDevices.Select(id => new FolderDevice { DeviceId = id }).ToArray()
            };

            // Preserve paused state when editing
            if (IsEditMode)
            {
                folder.Paused = Folder!.Paused;
            }

            // Add versioning config if enabled
            if (_versioningType != "none")
            {
                folder.Versioning = new VersioningConfig
                {
                    Type = _versioningType,
                    Params = GetVersioningParams()
                };
            }

            if (IsEditMode)
            {
                await ApiClient.UpdateFolderAsync(folder);
                Snackbar.Add(string.Format(L["FolderDialog_SavedMessage"], folder.DisplayName), Severity.Success);
            }
            else
            {
                await ApiClient.AddFolderAsync(folder);
                Snackbar.Add(string.Format(L["FolderDialog_AddedMessage"], folder.DisplayName), Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(folder));
        }
        catch (Exception ex)
        {
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            var action = IsEditMode ? L["FolderDialog_ActionSave"] : L["FolderDialog_ActionAdd"];
            Snackbar.Add(string.Format(L["FolderDialog_ErrorMessage"], action, ErrorHelper.GetUserFriendlyMessage(ex)), Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private Dictionary<string, string>? GetVersioningParams()
    {
        return _versioningType switch
        {
            "trashcan" => new Dictionary<string, string>
            {
                ["cleanoutDays"] = _cleanoutDays.ToString()
            },
            "simple" => new Dictionary<string, string>
            {
                ["keep"] = _keepVersions.ToString(),
                ["cleanoutDays"] = _cleanoutDays.ToString()
            },
            "staggered" => new Dictionary<string, string>
            {
                ["maxAge"] = (_maxAgeDays * 86400).ToString() // Convert days to seconds
            },
            "external" => new Dictionary<string, string>
            {
                ["command"] = _externalCommand
            },
            _ => null
        };
    }

    private void Cancel() => MudDialog.Cancel();
}
