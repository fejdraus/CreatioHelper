@using CreatioHelper.WebUI.Models
@inject IApiClient ApiClient
@inject ISnackbar Snackbar
@inject IStringLocalizer<Localization> L

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(IsEditMode ? Icons.Material.Filled.Edit : Icons.Material.Filled.Add)" Class="mr-2" />
            @(IsEditMode ? L["WebServer_EditSite"] : L["WebServer_AddSite"])
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField @bind-Value="_displayName"
                          Label="@L["WebServer_DisplayName"]"
                          Required="true"
                          RequiredError="@L["WebServer_DisplayNameRequired"]"
                          ReadOnly="@IsEditMode"
                          Immediate="true"
                          Class="mb-4" />

            <MudSelect T="string"
                       Value="_type"
                       ValueChanged="OnTypeChanged"
                       Label="@L["WebServer_ManagedBy"]"
                       Class="mb-4">
                <MudSelectItem Value="@("IIS")">@L["WebServer_TypeIis"]</MudSelectItem>
                <MudSelectItem Value="@("Service")">@L["WebServer_TypeService"]</MudSelectItem>
            </MudSelect>

            <MudSelect T="string"
                       @bind-SelectedValues="_selectedFolderIds"
                       MultiSelection="true"
                       MultiSelectionTextFunc="@GetLinkedFoldersText"
                       Label="@L["WebServer_LinkedFolders"]"
                       Class="mb-4">
                @foreach (var folder in _folders.Where(IsFolderVisible))
                {
                    <MudSelectItem T="string" Value="@folder.Id">@folder.DisplayName</MudSelectItem>
                }
            </MudSelect>

            <MudTextField @bind-Value="_serviceName"
                          Label="@(_type == "IIS" ? L["WebServer_IisSiteName"] : L["WebServer_ServiceName"])"
                          Required="true"
                          RequiredError="@L["WebServer_HostNameRequired"]"
                          ReadOnly="@(_type == "IIS")"
                          HelperText="@(_type == "IIS" ? L["WebServer_IisSiteNameHint"] : null)"
                          Immediate="true" />

            @if (_type == "IIS")
            {
                <MudTextField @bind-Value="_appPool"
                              Label="@L["WebServer_AppPool"]"
                              HelperText="@L["WebServer_AppPoolHint"]"
                              ReadOnly="true"
                              Class="mt-2" />
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        @if (_type == "IIS")
        {
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Search"
                       Class="mr-auto"
                       Disabled="@(_detecting || !_selectedFolderIds.Any())"
                       OnClick="DetectByFolder">
                @L["WebServer_DetectByFolder"]
            </MudButton>
        }
        <MudButton OnClick="Cancel">@L["Common_Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(!_isValid || _saving)"
                   OnClick="Submit">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @(IsEditMode ? L["Common_Save"] : L["WebServer_AddSite"])
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public bool IsEditMode { get; set; }
    [Parameter] public WebSiteInfoDto? EditSite { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _saving;
    private bool _detecting;

    private string _displayName = string.Empty;
    private string _type = "IIS";
    private string _serviceName = string.Empty;
    private string _appPool = string.Empty;
    private IReadOnlyCollection<string> _selectedFolderIds = new List<string>();

    private FolderConfig[] _folders = Array.Empty<FolderConfig>();
    private readonly Dictionary<string, string?> _folderSites = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _folders = await ApiClient.GetFoldersAsync();
        }
        catch
        {
            _folders = Array.Empty<FolderConfig>();
        }

        if (IsEditMode && EditSite != null)
        {
            _displayName = EditSite.Name;
            _type = EditSite.WebServerType == WebServerKindDto.Iis ? "IIS" : "Service";
            _serviceName = EditSite.ServiceName;
            _appPool = EditSite.AppPool;
            _selectedFolderIds = EditSite.FolderIds.ToList();
        }

        await LoadFolderSitesAsync();
    }

    private async Task LoadFolderSitesAsync()
    {
        try
        {
            var paths = _folders
                .Where(f => !string.IsNullOrEmpty(f.Path))
                .Select(f => f.Path)
                .Distinct()
                .ToList();
            if (paths.Count == 0)
            {
                return;
            }

            var batch = await ApiClient.DetectIisSitesAsync(paths);
            if (batch?.Sites == null)
            {
                return;
            }

            foreach (var folder in _folders)
            {
                if (!string.IsNullOrEmpty(folder.Path) && batch.Sites.TryGetValue(folder.Path, out var site))
                {
                    _folderSites[folder.Id] = site;
                }
            }
        }
        catch
        {
            // Filtering by site is best-effort; ignore failures (e.g. no elevation)
        }
    }

    private string? GetLockedSite()
    {
        if (_type != "IIS")
        {
            return null;
        }

        foreach (var id in _selectedFolderIds)
        {
            if (_folderSites.TryGetValue(id, out var site) && !string.IsNullOrEmpty(site))
            {
                return site;
            }
        }

        return null;
    }

    private bool IsFolderVisible(FolderConfig folder)
    {
        var locked = GetLockedSite();
        if (locked == null || _selectedFolderIds.Contains(folder.Id))
        {
            return true;
        }

        return _folderSites.TryGetValue(folder.Id, out var site) && site == locked;
    }

    private string GetLinkedFoldersText(IReadOnlyList<string> selected)
        => string.Join(", ", selected.Select(id => _folders.FirstOrDefault(f => f.Id == id)?.DisplayName ?? id));

    private async Task DetectByFolder()
    {
        var folders = _selectedFolderIds
            .Select(id => _folders.FirstOrDefault(f => f.Id == id))
            .Where(f => f != null && !string.IsNullOrEmpty(f!.Path))
            .ToList();
        if (folders.Count == 0)
        {
            return;
        }

        _detecting = true;
        try
        {
            var requiresElevation = false;
            var detectedSites = new List<string>();
            var detectedPool = string.Empty;
            foreach (var folder in folders)
            {
                var detected = await ApiClient.DetectIisSiteAsync(folder!.Path);
                if (!string.IsNullOrEmpty(detected?.SiteName))
                {
                    if (!detectedSites.Contains(detected.SiteName))
                    {
                        detectedSites.Add(detected.SiteName);
                        detectedPool = detected.AppPool;
                    }
                }
                else if (detected?.RequiresElevation == true)
                {
                    requiresElevation = true;
                }
            }

            if (detectedSites.Count == 1)
            {
                _serviceName = detectedSites[0];
                _appPool = detectedPool;
                if (string.IsNullOrWhiteSpace(_displayName))
                {
                    _displayName = detectedSites[0];
                }
                Snackbar.Add(L["WebServer_DetectedSite", detectedSites[0]], Severity.Success);
            }
            else if (detectedSites.Count > 1)
            {
                Snackbar.Add(L["WebServer_DetectMultipleSites", string.Join(", ", detectedSites)], Severity.Warning);
            }
            else
            {
                Snackbar.Add(requiresElevation ? L["WebServer_DetectRequiresAdmin"] : L["WebServer_DetectNotFound"], Severity.Warning);
            }
        }
        catch
        {
            Snackbar.Add(L["WebServer_DetectNotFound"], Severity.Warning);
        }
        finally
        {
            _detecting = false;
        }
    }

    private void OnTypeChanged(string type)
    {
        _type = type;
        if (_type != "IIS")
        {
            _appPool = string.Empty;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid)
        {
            return;
        }

        _saving = true;
        try
        {
            var dto = new SiteRegistrationDto
            {
                DisplayName = _displayName,
                Type = _type,
                ServiceName = _serviceName,
                AppPool = _type == "IIS" ? (_appPool ?? string.Empty) : string.Empty,
                FolderIds = _selectedFolderIds.ToList()
            };

            if (IsEditMode)
            {
                await ApiClient.UpdateSiteAsync(_displayName, dto);
                Snackbar.Add(L["WebServer_SiteSaved", _displayName], Severity.Success);
            }
            else
            {
                await ApiClient.RegisterSiteAsync(dto);
                Snackbar.Add(L["WebServer_SiteSaved", _displayName], Severity.Success);
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add(L["WebServer_SiteSaveFailed", ex.Message], Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
