@inject IApiClient ApiClient
@inject ISnackbar Snackbar
@inject StateContainer State
@inject IStringLocalizer<Localization> L
@inject IErrorMessageHelper ErrorHelper
@inject NavigationManager Navigation

<MudDialog Style="max-height: 90vh;">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(IsEditMode ? Icons.Material.Filled.Edit : Icons.Material.Filled.DevicesOther)" Class="mr-2" />
            @(IsEditMode ? L["DeviceDialog_EditDevice"] : L["DeviceDialog_AddDevice"])
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true">
            @* ===== GENERAL TAB ===== *@
            <MudTabPanel Text="@L["DeviceDialog_TabGeneral"]" Icon="@Icons.Material.Filled.Info" Class="pa-4">
                <MudForm @ref="_form" @bind-IsValid="@_isValid">
                    <MudTextField @bind-Value="_deviceId"
                                  Label="@L["DeviceDialog_DeviceId"]"
                                  HelperText="@(IsEditMode ? L["DeviceDialog_DeviceIdCannotChange"] : L["DeviceDialog_DeviceIdHelper"])"
                                  Required="true"
                                  RequiredError="@L["DeviceDialog_DeviceIdRequired"]"
                                  Immediate="true"
                                  ReadOnly="@IsEditMode"
                                  Validation="@(new Func<string, string?>(ValidateDeviceId))"
                                  Class="mb-4"
                                  Style="font-family: monospace;" />

                    <MudTextField @bind-Value="_name"
                                  Label="@L["DeviceDialog_DeviceName"]"
                                  HelperText="@L["DeviceDialog_DeviceNameHelper"]"
                                  Class="mb-4" />

                    <MudTextField @bind-Value="_addressesText"
                                  Label="@L["DeviceDialog_Addresses"]"
                                  HelperText="@L["DeviceDialog_AddressesHelper"]"
                                  Placeholder="dynamic"
                                  Class="mb-4" />
                </MudForm>
            </MudTabPanel>

            @* ===== SHARING TAB ===== *@
            <MudTabPanel Text="@L["DeviceDialog_TabSharing"]" Icon="@Icons.Material.Filled.Folder" Class="pa-4">
                <MudText Typo="Typo.body2" Class="mb-4">
                    @L["DeviceDialog_SelectFolders"]
                </MudText>

                @if (State.Folders.Length == 0)
                {
                    <MudAlert Severity="Severity.Info">
                        @L["DeviceDialog_NoFoldersConfigured"]
                    </MudAlert>
                }
                else
                {
                    <MudList T="string" Dense="true">
                        @foreach (var folder in State.Folders)
                        {
                            <MudListItem>
                                <MudCheckBox T="bool"
                                             Value="@_selectedFolders.Contains(folder.Id)"
                                             ValueChanged="@(v => ToggleFolder(folder.Id, v))"
                                             Label="@folder.DisplayName"
                                             Color="Color.Primary" />
                            </MudListItem>
                        }
                    </MudList>
                }
            </MudTabPanel>

            @* ===== ADVANCED TAB ===== *@
            <MudTabPanel Text="@L["DeviceDialog_TabAdvanced"]" Icon="@Icons.Material.Filled.Settings" Class="pa-4">
                <MudSelect @bind-Value="_compression"
                           Label="@L["DeviceDialog_Compression"]"
                           HelperText="@L["DeviceDialog_CompressionHelper"]"
                           Class="mb-4">
                    <MudSelectItem Value="@("metadata")">@L["DeviceDialog_CompressionMetadata"]</MudSelectItem>
                    <MudSelectItem Value="@("always")">@L["DeviceDialog_CompressionAlways"]</MudSelectItem>
                    <MudSelectItem Value="@("never")">@L["DeviceDialog_CompressionNever"]</MudSelectItem>
                </MudSelect>

                <MudDivider Class="my-4" />

                <MudSwitch @bind-Value="_introducer"
                           Label="@L["DeviceDialog_Introducer"]"
                           Color="Color.Primary"
                           Class="mb-2" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
                    @L["DeviceDialog_IntroducerDesc"]
                </MudText>

                @if (_introducer)
                {
                    <MudSwitch @bind-Value="_skipIntroductionRemovals"
                               Label="@L["DeviceDialog_SkipIntroductionRemovals"]"
                               Color="Color.Primary"
                               Class="mb-2" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
                        @L["DeviceDialog_SkipIntroductionRemovalsDesc"]
                    </MudText>
                }

                <MudDivider Class="my-4" />

                <MudSwitch @bind-Value="_autoAcceptFolders"
                           Label="@L["DeviceDialog_AutoAcceptFolders"]"
                           Color="Color.Primary"
                           Class="mb-2" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
                    @L["DeviceDialog_AutoAcceptFoldersDesc"]
                </MudText>

                <MudDivider Class="my-4" />

                <MudTextField @bind-Value="_allowedNetworksText"
                              Label="@L["DeviceDialog_AllowedNetworks"]"
                              HelperText="@L["DeviceDialog_AllowedNetworksHelper"]"
                              Placeholder="192.168.0.0/16, 10.0.0.0/8"
                              Class="mb-4" />
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["DeviceDialog_Cancel"]</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(!_isValid || _isSubmitting)">
            @if (_isSubmitting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @(IsEditMode ? L["DeviceDialog_Save"] : L["DeviceDialog_AddDevice"])
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public DeviceConfig? Device { get; set; }

    private bool IsEditMode => Device != null;

    private MudForm _form = null!;
    private bool _isValid;
    private bool _isSubmitting;

    // General
    private string _deviceId = string.Empty;
    private string _name = string.Empty;
    private string _addressesText = "dynamic";

    // Sharing
    private HashSet<string> _selectedFolders = new();

    // Advanced
    private string _compression = "metadata";
    private bool _introducer;
    private bool _skipIntroductionRemovals;
    private bool _autoAcceptFolders;
    private string _allowedNetworksText = string.Empty;

    protected override void OnInitialized()
    {
        if (IsEditMode)
        {
            LoadFromDevice(Device!);
        }
    }

    private void LoadFromDevice(DeviceConfig device)
    {
        _deviceId = device.DeviceId;
        _name = device.Name;
        _addressesText = string.Join(", ", device.Addresses);
        _compression = device.Compression;
        _introducer = device.Introducer;
        _skipIntroductionRemovals = device.SkipIntroductionRemovals;
        _allowedNetworksText = string.Join(", ", device.AllowedNetworks);

        // Find folders that include this device
        _selectedFolders = State.Folders
            .Where(f => f.Devices?.Any(d => d.DeviceId == device.DeviceId) == true)
            .Select(f => f.Id)
            .ToHashSet();
    }

    private string? ValidateDeviceId(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return L["DeviceDialog_DeviceIdRequired"];

        // Basic validation - should be like XXXXXXX-XXXXXXX-... format
        var trimmed = value.Trim().ToUpperInvariant();
        if (trimmed.Length < 7)
            return L["DeviceDialog_DeviceIdTooShort"];

        // Check for valid characters (A-Z, 0-9, -)
        if (!System.Text.RegularExpressions.Regex.IsMatch(trimmed, @"^[A-Z0-9\-]+$"))
            return L["DeviceDialog_DeviceIdInvalidChars"];

        return null;
    }

    private void ToggleFolder(string folderId, bool selected)
    {
        if (selected)
            _selectedFolders.Add(folderId);
        else
            _selectedFolders.Remove(folderId);
    }

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        _isSubmitting = true;
        StateHasChanged();

        try
        {
            var addresses = _addressesText
                .Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(a => a.Trim())
                .Where(a => !string.IsNullOrEmpty(a))
                .ToArray();

            if (addresses.Length == 0)
                addresses = ["dynamic"];

            var allowedNetworks = _allowedNetworksText
                .Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(n => n.Trim())
                .Where(n => !string.IsNullOrEmpty(n))
                .ToArray();

            var device = new DeviceConfig
            {
                DeviceId = _deviceId.Trim().ToUpperInvariant(),
                Name = _name,
                Addresses = addresses,
                Compression = _compression,
                Introducer = _introducer,
                SkipIntroductionRemovals = _skipIntroductionRemovals,
                AllowedNetworks = allowedNetworks,
                Paused = IsEditMode ? Device!.Paused : false
            };

            if (IsEditMode)
            {
                await ApiClient.UpdateDeviceAsync(device);
                Snackbar.Add(string.Format(L["DeviceDialog_DeviceSaved"], device.DisplayName), Severity.Success);
            }
            else
            {
                await ApiClient.AddDeviceAsync(device);
                Snackbar.Add(string.Format(L["DeviceDialog_DeviceAdded"], device.DisplayName), Severity.Success);
            }

            // Update folder sharing
            await UpdateFolderSharingAsync(device.DeviceId);

            MudDialog.Close(DialogResult.Ok(device));
        }
        catch (Exception ex)
        {
            if (ErrorHelper.IsAuthenticationError(ex))
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            var errorMsg = IsEditMode
                ? string.Format(L["DeviceDialog_FailedToSave"], ErrorHelper.GetUserFriendlyMessage(ex))
                : string.Format(L["DeviceDialog_FailedToAdd"], ErrorHelper.GetUserFriendlyMessage(ex));
            Snackbar.Add(errorMsg, Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task UpdateFolderSharingAsync(string deviceId)
    {
        // Update each folder's device list based on selection
        foreach (var folder in State.Folders)
        {
            var currentDevices = folder.Devices?.ToList() ?? new List<FolderDevice>();
            var hasDevice = currentDevices.Any(d => d.DeviceId == deviceId);
            var shouldHaveDevice = _selectedFolders.Contains(folder.Id);

            if (hasDevice != shouldHaveDevice)
            {
                if (shouldHaveDevice)
                {
                    currentDevices.Add(new FolderDevice { DeviceId = deviceId });
                }
                else
                {
                    currentDevices.RemoveAll(d => d.DeviceId == deviceId);
                }

                folder.Devices = currentDevices.ToArray();

                try
                {
                    await ApiClient.UpdateFolderAsync(folder);
                }
                catch (Exception ex)
                {
                    if (ErrorHelper.IsAuthenticationError(ex))
                    {
                        Navigation.NavigateTo("/login", forceLoad: true);
                        return;
                    }
                    Snackbar.Add(string.Format(L["DeviceDialog_FailedToUpdateFolder"], folder.DisplayName, ErrorHelper.GetUserFriendlyMessage(ex)), Severity.Warning);
                }
            }
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
